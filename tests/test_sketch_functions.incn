"""Test: RFC 025 typed sketch logical-value helper surface."""

from std.testing import assert_raises
from aggregate_builders import AggregateKind, aggregate_measure_output_name
from functions import col, hll_deserialize, hll_estimate, hll_merge, hll_serialize, hll_sketch
from function_registry import function_ref_for
from projection_builders import column_expr_function_name, column_expr_name, column_expr_option_value
from sketch_types import (
    SKETCH_FAMILY_OPTION,
    SKETCH_FORMAT_OPTION,
    SKETCH_PRECISION_OPTION,
    SKETCH_VALUE_DOMAIN_OPTION,
    SketchFamily,
    SketchSerializationFormat,
    SketchValueDomain,
    hll_type,
    sketch_col,
    sketch_types_compatible,
)


def _call_hll_type_with_invalid_precision() -> None:
    """Build invalid HLL metadata for ValueError assertions."""
    hll_type(precision=0)
    return


def test_sketch_functions__hll_type_preserves_merge_compatibility_metadata() -> None:
    # -- Arrange / Act --
    left = hll_type(SketchValueDomain.IntegerIdentifier, precision=12)
    right = hll_type(SketchValueDomain.IntegerIdentifier, precision=12)
    different_precision = hll_type(SketchValueDomain.IntegerIdentifier, precision=14)

    # -- Assert --
    assert left.family == SketchFamily.HyperLogLog, "hll_type should identify the portable sketch family"
    assert left.value_domain == SketchValueDomain.IntegerIdentifier, "hll_type should preserve the value domain"
    assert left.precision == 12, "hll_type should preserve the precision"
    assert left.format == SketchSerializationFormat.InqlHllV1, "hll_type should preserve the serialization format"
    assert sketch_types_compatible(left, right), "matching HLL logical types should be merge-compatible"
    assert not sketch_types_compatible(left, different_precision), "precision is part of sketch merge compatibility"


def test_sketch_functions__hll_type_rejects_non_positive_precision() -> None:
    # -- Arrange / Act / Assert --
    assert_raises[ValueError](_call_hll_type_with_invalid_precision)


def test_sketch_functions__hll_sketch_builds_typed_aggregate_measure() -> None:
    # -- Arrange / Act --
    measure = hll_sketch(col("user_id"), value_domain=SketchValueDomain.IntegerIdentifier, precision=12)

    # -- Assert --
    assert measure.kind == AggregateKind.HllSketch, "hll_sketch should use its own aggregate kind"
    assert measure.function_ref == function_ref_for("hll_sketch"), "hll_sketch should preserve registry identity"
    assert measure.canonical_name == "hll_sketch", "hll_sketch should preserve canonical name"
    assert measure.has_expr, "hll_sketch should require an input expression"
    assert column_expr_name(measure.expr) == "user_id", "hll_sketch should preserve the input expression"
    assert aggregate_measure_output_name(measure) == "hll_sketch_user_id_integer_identifier_p12", "hll_sketch should expose sketch parameters when they affect compatibility"
    match measure.sketch_type:
        Some(sketch_type) =>
            assert sketch_type.family == SketchFamily.HyperLogLog, "hll_sketch output should be typed as HyperLogLog"
            assert sketch_type.value_domain == SketchValueDomain.IntegerIdentifier, "hll_sketch should preserve value domain"
            assert sketch_type.precision == 12, "hll_sketch should preserve precision"
        None =>
            assert false, "hll_sketch should carry sketch output metadata"


def test_sketch_functions__hll_sketch_accepts_literal_source_values() -> None:
    # -- Arrange / Act --
    measure = hll_sketch("anonymous-user", precision=12)

    # -- Assert --
    assert measure.kind == AggregateKind.HllSketch, "hll_sketch should accept primitive values through the typed input surface"
    assert aggregate_measure_output_name(measure) == "hll_sketch_expr_p12", "literal inputs should use the scalar fallback output label"
    match measure.sketch_type:
        Some(sketch_type) =>
            assert sketch_type.precision == 12, "literal hll_sketch inputs should preserve sketch precision"
        None =>
            assert false, "hll_sketch should carry sketch output metadata for literal inputs"


def test_sketch_functions__hll_merge_preserves_typed_sketch_metadata() -> None:
    # -- Arrange --
    sketch = sketch_col("daily_users_hll", hll_type(precision=12))

    # -- Act --
    measure = hll_merge(sketch)

    # -- Assert --
    assert measure.kind == AggregateKind.HllMerge, "hll_merge should use its own aggregate kind"
    assert measure.function_ref == function_ref_for("hll_merge"), "hll_merge should preserve registry identity"
    assert column_expr_name(measure.expr) == "daily_users_hll", "hll_merge should preserve the input sketch expression"
    assert aggregate_measure_output_name(measure) == "hll_merge_daily_users_hll_p12", "hll_merge should expose non-default sketch precision in output names"
    match measure.sketch_type:
        Some(sketch_type) =>
            assert sketch_type.precision == 12, "hll_merge should preserve input sketch precision"
        None =>
            assert false, "hll_merge should carry sketch output metadata"


def test_sketch_functions__default_hll_output_name_remains_compact() -> None:
    # -- Arrange / Act --
    measure = hll_sketch(col("user_id"))

    # -- Assert --
    assert aggregate_measure_output_name(measure) == "hll_sketch_user_id", "default HLL metadata should not make noisy column names"


def test_sketch_functions__hll_scalar_helpers_preserve_sketch_options() -> None:
    # -- Arrange --
    sketch = sketch_col("users_hll", hll_type(SketchValueDomain.IntegerIdentifier, precision=12))

    # -- Act --
    estimate = hll_estimate(sketch)
    serialized = hll_serialize(sketch)

    # -- Assert --
    assert column_expr_function_name(estimate) == "hll_estimate", "hll_estimate should be a registry-backed scalar helper"
    assert column_expr_option_value(estimate, SKETCH_FAMILY_OPTION) == "hyperloglog", "hll_estimate should carry sketch family"
    assert column_expr_option_value(estimate, SKETCH_VALUE_DOMAIN_OPTION) == "integer_identifier", "hll_estimate should carry value domain"
    assert column_expr_option_value(estimate, SKETCH_PRECISION_OPTION) == "12", "hll_estimate should carry precision"
    assert column_expr_option_value(estimate, SKETCH_FORMAT_OPTION) == "inql_hll_v1", "hll_estimate should carry format"
    assert column_expr_function_name(serialized) == "hll_serialize", "hll_serialize should be a registry-backed scalar helper"
    assert column_expr_option_value(serialized, SKETCH_PRECISION_OPTION) == "12", "hll_serialize should carry precision"


def test_sketch_functions__hll_deserialize_returns_typed_sketch_expr() -> None:
    # -- Arrange / Act --
    sketch = hll_deserialize(col("users_hll_payload"), value_domain=SketchValueDomain.IntegerIdentifier, precision=12)

    # -- Assert --
    assert column_expr_function_name(sketch.expr) == "hll_deserialize", "hll_deserialize should lower through a scalar application"
    assert sketch.sketch_type.family == SketchFamily.HyperLogLog, "hll_deserialize should return a typed HLL sketch"
    assert sketch.sketch_type.value_domain == SketchValueDomain.IntegerIdentifier, "hll_deserialize should preserve value domain"
    assert sketch.sketch_type.precision == 12, "hll_deserialize should preserve precision"
    assert column_expr_option_value(sketch.expr, SKETCH_PRECISION_OPTION) == "12", "hll_deserialize should carry precision in scalar options"


def test_sketch_functions__hll_deserialize_accepts_string_payload_values() -> None:
    # -- Arrange / Act --
    sketch = hll_deserialize("opaque_payload", precision=12)

    # -- Assert --
    assert column_expr_function_name(sketch.expr) == "hll_deserialize", "hll_deserialize should accept string payload values"
    assert sketch.sketch_type.precision == 12, "hll_deserialize should preserve sketch precision for literal payloads"
