def _rfc018_registry_names() -> list[str]:
    """Return the remaining RFC 018 canonical names added after the initial PR #44 math slice."""
    return ["sqrt", "power", "exp", "ln", "log", "log10", "sign", "least", "greatest", "sin", "cos", "tan", "asin", "acos", "atan", "atan2", "degrees", "radians", "char_length", "octet_length", "upper", "lower", "trim", "ltrim", "rtrim", "substring", "position", "overlay", "concat", "concat_ws", "replace", "translate", "repeat", "left", "right", "lpad", "rpad", "split_part", "encode", "decode", "base64", "unbase64", "hex", "unhex", "regexp_like", "regexp_replace", "regexp_extract", "current_date", "current_time", "current_timestamp", "date_part", "date_trunc", "time_trunc", "date_add", "date_sub", "date_diff", "timestamp_diff", "to_date", "to_time", "to_timestamp", "from_unixtime", "unix_seconds", "unix_millis", "unix_micros", "make_date", "make_time", "make_timestamp", "last_day"]


def _expected_all_registry_names() -> list[str]:
    """Return the complete expected registered helper surface."""
    mut names = _expected_registry_names()
    names.extend(_rfc018_registry_names())
    return names


