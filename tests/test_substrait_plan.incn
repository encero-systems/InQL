def test_plan__window_rel_lowers_multiple_projections_with_shared_boundary() -> None:
    # -- Arrange --
    _register_window_orders_schema()
    base = read_named_table_rel("orders_window")

    # -- Act --
    windowed = window_rel_of_columns(base, ["customer_id", "amount"], [_row_number_projection(), _rank_projection()])
    plan = plan_from_root_relation(windowed, ["customer_id", "amount", "row_num", "amount_rank"])

    # -- Assert --
    assert relation_kind_name(windowed) == "ConsistentPartitionWindowRel", "shared-boundary window projections should share one relation"
    assert relation_output_columns(windowed) == ["customer_id", "amount", "row_num", "amount_rank"], "window output aliases should be preserved in relation output"
    assert window_function_names(windowed) == ["row_number", "rank"], "window relation should lower both window functions"
    assert plan_has_extension_urn(plan, FUNCTION_EXTENSION_URI), "multi-window plans should register the shared function extension URN"


def test_plan__window_rel_declares_scalar_extensions_from_window_expressions() -> None:
    # -- Arrange --
    _register_window_orders_schema()
    base = read_named_table_rel("orders_window")
    spec = window().partition_by([coalesce([col("customer_id"), lit("unknown")])]).order_by([col("amount")])
    projection = window_projection("adjusted_sum", sum(add(col("amount"), lit(1))).over(spec))

    # -- Act --
    windowed = window_rel_of_columns(base, ["customer_id", "amount"], [projection])
    plan = plan_from_root_relation(windowed, ["customer_id", "amount", "adjusted_sum"])
    extension_functions = plan_extension_function_names(plan)

    # -- Assert --
    assert extension_functions.contains("sum"), "windowed aggregate function should be declared"
    assert extension_functions.contains("add"), "scalar function inside window arguments should be declared"
    assert extension_functions.contains("coalesce"), "scalar function inside window partition expressions should be declared"


def test_plan__window_rel_rejects_multiple_projection_boundary_mismatch() -> None:
    # -- Arrange --
    _register_window_orders_schema()
    base = read_named_table_rel("orders_window")
    different_spec = window().partition_by([col("customer_id")]).order_by([col("amount")])
    mismatched = window_projection("dense_amount_rank", dense_rank().over(different_spec))

    # -- Act --
    result = try_window_rel_of_columns(base, ["customer_id", "amount"], [_row_number_projection(), mismatched])

    # -- Assert --
    assert_is_err(result, "different window boundaries should require a separate relation")


def test_plan__window_rel_rejects_scalar_expression_boundary_mismatch() -> None:
    # -- Arrange --
    _register_window_orders_schema()
    base = read_named_table_rel("orders_window")
    first_spec = window().partition_by([add(col("amount"), lit(1))]).order_by([col("amount")])
    second_spec = window().partition_by([sub(col("amount"), lit(1))]).order_by([col("amount")])
    first = window_projection("row_num", row_number().over(first_spec))
    second = window_projection("amount_rank", rank().over(second_spec))

    # -- Act --
    result = try_window_rel_of_columns(base, ["customer_id", "amount"], [first, second])

    # -- Assert --
    assert_is_err(result, "different scalar partition expressions should require a separate relation")


def test_plan__offset_value_distribution_and_aggregate_windows_lower_to_substrait() -> None:
    # -- Arrange --
    _register_window_orders_schema()
    base = read_named_table_rel("orders_window")
    spec = window().partition_by([col("customer_id")]).order_by([desc(col("amount"))])
    running_spec = spec.rows_between(unbounded_preceding_bound(), current_row_bound())
    projections = [window_projection("percent_rank", percent_rank().over(spec)), window_projection(
        "cume_dist",
        cume_dist().over(spec),
    ), window_projection("tile", ntile(2).over(spec)), window_projection("lag_amount", lag(col("amount")).over(spec)), window_projection(
        "lead_amount",
        lead(col("amount"), 1, lit(0)).over(spec),
    ), window_projection("first_amount", first_value(col("amount")).over(spec)), window_projection(
        "last_amount",
        last_value(col("amount")).over(spec),
    ), window_projection("second_amount", nth_value(col("amount"), 2).over(spec)), window_projection(
        "running_amount",
        sum(col("amount")).over(running_spec),
    )]

    # -- Act / Assert --
    for projection in projections:
        windowed = window_rel_of_columns(base.clone(), ["customer_id", "amount"], [projection])
        names = window_function_names(windowed)
        assert len(names) == 1, "each analytic helper should lower to one window function"
        assert relation_kind_name(windowed) == "ConsistentPartitionWindowRel", "analytic helper should lower through the window relation"


def test_plan__set_rel_uses_operation_enum() -> None:
    # -- Arrange --
    left = read_named_table_rel("orders_current")
    right = read_named_table_rel("orders_archive")
    union_rel = set_rel(left, right, "Union")

    # -- Act --
    union_plan = plan_from_root_relation(union_rel, ["id"])

    # -- Assert --
    assert relation_kind_name(union_rel) == "SetRel", "set combinator must produce SetRel root"
    assert plan_encoded_len(union_plan) > 0, "set plan should still encode"
    assert plan_contains_relation_kind(union_plan, "ReadRel"), "set traversal should still reach child reads"


def test_plan__enum_backed_join_and_set_builders_expose_boundary_facts() -> None:
    # -- Arrange --
    left_join_rel = join_rel_of_kind(
        read_named_table_rel("orders"),
        read_named_table_rel("customers"),
        true,
        SubstraitJoinKind.Left,
    )
    union_distinct_rel = set_rel_of_kind(
        read_named_table_rel("orders_current"),
        read_named_table_rel("orders_archive"),
        SubstraitSetOperation.UnionDistinct,
    )

    # -- Act --
    join_kind = relation_kind_name(left_join_rel)
    set_kind = set_operation_name(union_distinct_rel)

    # -- Assert --
    assert join_kind == "JoinRel", "enum-backed join builder should still emit a JoinRel root"
    assert set_kind == "UnionDistinct", "enum-backed set builder should preserve the selected set operation"


def test_plan__reference_rel_preserves_subtree_ordinal() -> None:
    # -- Arrange --
    rel = reference_rel(7)

    # -- Act --
    kind = relation_kind_name(rel)
    ordinal = reference_subtree_ordinal(rel)

    # -- Assert --
    assert kind == "ReferenceRel", "reference builder should still expose ReferenceRel root kind"
    assert ordinal == 7, "reference builder should preserve the requested subtree ordinal"


def test_plan__extension_urns_are_surfaced() -> None:
    # -- Arrange --
    extension_uri = EXPLODE_EXTENSION_URI
    rel = extension_single_rel(read_named_table_rel("orders"), extension_uri)
    nested = extension_single_rel(
        extension_single_rel(read_named_table_rel("orders"), EXPLODE_EXTENSION_URI),
        POSEXPLODE_EXTENSION_URI,
    )

    # -- Act --
    plan = plan_from_root_relation(rel, ["id"])
    nested_plan = plan_from_root_relation(nested, ["id", "position", "value"])

    # -- Assert --
    assert plan_has_extension_urn(plan, extension_uri), "extension relation should populate extension URNs"
    assert plan_contains_relation_kind(plan, "ExtensionSingleRel"), "extension root should remain inspectable"
    assert plan_has_extension_urn(nested_plan, EXPLODE_EXTENSION_URI), "nested extension plans should include child extension URNs"
    assert plan_has_extension_urn(nested_plan, POSEXPLODE_EXTENSION_URI), "nested extension plans should include root extension URNs"
    assert plan_extension_urn_count(nested_plan) == 2, "different relation extension URIs should be declared once each"
    assert plan_extension_urn_anchor_at(nested_plan, 0) != plan_extension_urn_anchor_at(nested_plan, 1), "relation extension URNs should use distinct anchors"


def test_plan__generator_payload_declares_scalar_extension_dependencies() -> None:
    # -- Arrange --
