"""Structured local plan inspection over Prism-backed lazy plans."""

from aggregate_builders import AggregateMeasure
from dataset import LazyFrame
from evidence import (
    AdapterRequirement,
    AdapterRequirementCapability,
    AdapterRequirementGuarantee,
    EvidenceArtifactStatus,
    InspectionArtifact,
    LineageConfidence,
    LineageEdge,
    LineageGraph,
    LineageRelationshipKind,
    LineageTransformationKind,
    MetadataAttachment,
    MetadataLifecycle,
    MetadataPayload,
    MetadataSource,
    MetadataVisibility,
    SemanticTarget,
    SemanticTargetKind,
    UnsupportedEvidence,
)
from governance import (
    GovernedAttribute,
    GovernedAttributeConfidence,
    GovernedAttributeScope,
    GovernedAttributeSource,
    GovernedAttributeStatus,
    PolicyCheckpoint,
    PolicyCheckpointAction,
    PolicyCheckpointKind,
    governed_attribute,
    policy_checkpoint,
)
from metadata import inql_version
from functions.registry import function_registry_entry_by_name
from prism import prism_plan_id
from prism.output_columns import authored_output_schema, rewritten_output_schema
from prism.rewrite import derive_rewritten_view, rewrite_explain
from prism.store import node_at, reachable_node_ids
from prism.types import PrismNode, PrismNodeKind, PrismOptimizedView, PrismStoreId
from projection_builders import ColumnExpr, ColumnRefExpr, ScalarFunctionApplicationExpr, untyped_column_expr
from scalar_schema import ScalarColumnSpec
from std.collections import OrderedSet
from window_builders import WindowProjection

pub const INSPECTION_SCHEMA_VERSION: str = "inql.inspection.v0.1"
pub const LINEAGE_RULE_VERSION: str = "inql.lineage.prism.v0.1"


@derive(Clone)
pub enum InspectionNodeKind(str):
    """Public node-kind names used in local plan inspection records."""

    ReadNamedTable = "ReadNamedTable"
    Filter = "Filter"
    Join = "Join"
    Project = "Project"
    SelectProject = "SelectProject"
    GroupBy = "GroupBy"
    Aggregate = "Aggregate"
    Generate = "Generate"
    Window = "Window"
    OrderBy = "OrderBy"
    Limit = "Limit"


@derive(Clone)
pub model PlanNodeInspection:
    """Inspectable Prism node record with typed node kind, stable target, and output schema facts."""

    pub target: SemanticTarget
    pub kind: InspectionNodeKind
    pub input_target_ids: list[str]
    pub output_fields: list[SemanticTarget]


@derive(Clone)
pub model PlanInspection:
    """Structured local inspection record for one Prism-backed lazy plan."""

    pub schema_version: str
    pub inql_version: str
    pub plan_id: str
    pub plan_target: SemanticTarget
    pub root_target: SemanticTarget
    pub authored_node_count: int
    pub rewritten_node_count: int
    pub rewrite_rule_names: list[str]
    pub output_schema: list[ScalarColumnSpec]
    pub output_fields: list[SemanticTarget]
    pub authored_nodes: list[PlanNodeInspection]
    pub rewritten_nodes: list[PlanNodeInspection]
    pub lineage: LineageGraph
    pub adapter_requirements: list[AdapterRequirement]
    pub attachments: list[MetadataAttachment]
    pub governed_attributes: list[GovernedAttribute]
    pub policy_checkpoints: list[PolicyCheckpoint]
    pub artifacts: list[InspectionArtifact]
    pub unsupported_evidence: list[UnsupportedEvidence]
    pub diagnostics: list[str]


model _SchemaSnapshot:
    """Cached output schema for one inspected Prism node."""

    node_id: int
    schema: list[ScalarColumnSpec]


class _AuthoredInspectionContext:
    """Plan-local cache for authored Prism schema lookups."""

    store_id: PrismStoreId
    schemas: list[_SchemaSnapshot]

    @staticmethod
    def new(store_id: PrismStoreId, node_ids: list[int]) -> Self:
        """Return an authored inspection context with reachable node schemas precomputed."""
        mut schemas: list[_SchemaSnapshot] = []
        for node_id in node_ids:
            schemas.append(_SchemaSnapshot(node_id=node_id, schema=authored_output_schema(store_id, node_id)))
        return _AuthoredInspectionContext(store_id=store_id, schemas=schemas)

    def node(self, node_id: int) -> PrismNode:
        """Return one authored Prism node."""
        return node_at(self.store_id, node_id)

    def schema(self, node_id: int) -> list[ScalarColumnSpec]:
        """Return a cached authored output schema."""
        for snapshot in self.schemas:
            if snapshot.node_id == node_id:
                return snapshot.schema
        return authored_output_schema(self.store_id, node_id)


class _RewrittenInspectionContext:
    """Plan-local cache for rewritten Prism schema lookups."""

    view: PrismOptimizedView
    schemas: list[_SchemaSnapshot]

    @staticmethod
    def new(view: PrismOptimizedView) -> Self:
        """Return a rewritten inspection context with rewritten node schemas precomputed."""
        mut schemas: list[_SchemaSnapshot] = []
        for node in view.nodes:
            schemas.append(_SchemaSnapshot(node_id=node.node_id, schema=rewritten_output_schema(view, node.node_id)))
        return _RewrittenInspectionContext(view=view, schemas=schemas)

    def schema(self, node_id: int) -> list[ScalarColumnSpec]:
        """Return a cached rewritten output schema."""
        for snapshot in self.schemas:
            if snapshot.node_id == node_id:
                return snapshot.schema
        return rewritten_output_schema(self.view, node_id)

    def node_count(self) -> int:
        """Return the rewritten node count for inspection summaries."""
        return len(self.view.nodes)

    def nodes(self) -> list[PrismNode]:
        """Return rewritten Prism nodes in stable rewritten order."""
        return self.view.nodes

    def origin_node_id(self, rewritten_node_id: int) -> int:
        """Return the authored origin node id for one rewritten node."""
        return self.view.origin_node_ids[rewritten_node_id]


pub def inspect_plan[T with Clone](data: LazyFrame[T]) -> PlanInspection:
    """
    Inspect one lazy plan without executing it or binding a backend.

    The returned record contains plan-local semantic targets, authored and rewritten Prism node summaries, output
    schema facts, typed metadata attachments, lineage edges, artifact-family summaries, and explicit unsupported
    evidence markers. Target identifiers are stable for the inspected Prism store/tip snapshot, but they are not global
    catalog identifiers.
    """
    store_id = data._cursor.store_id
    tip_id = data._cursor.tip_id
    plan_id = _plan_id(store_id, tip_id)
    plan_target = _semantic_target(SemanticTargetKind.Plan, plan_id, plan_id, "plan", plan_id, "plan", None, None)
    authored_ids = reachable_node_ids(store_id, tip_id)
    authored_context = _AuthoredInspectionContext.new(store_id, authored_ids)
    rewritten_view = derive_rewritten_view(store_id, tip_id)
    rewritten_context = _RewrittenInspectionContext.new(rewritten_view)
    explain = rewrite_explain(store_id, tip_id)
    tip_output_schema = authored_context.schema(tip_id)
    output_fields = _field_targets_for_schema(plan_id, tip_id, tip_output_schema)
    lineage = _lineage_graph_for_authored_plan(plan_id, authored_context, authored_ids)
    adapter_requirements = _adapter_requirements_for_authored_plan(
        plan_id,
        plan_target,
        authored_context,
        authored_ids,
        lineage,
    )
    attachments = _metadata_attachments(plan_target, output_fields, tip_output_schema)
    governed_attributes = _governed_attributes_from_metadata(attachments)
    policy_checkpoints = _policy_checkpoints_for_inspection(plan_target, governed_attributes)
    authored_nodes = _authored_node_inspections(plan_id, authored_context, authored_ids)
    rewritten_nodes = _rewritten_node_inspections(plan_id, rewritten_context)
    unsupported = _unsupported_evidence_markers()
    artifacts = _artifact_summaries(
        len(authored_nodes),
        len(lineage.edges),
        len(tip_output_schema),
        len(attachments),
        len(governed_attributes),
        len(policy_checkpoints),
        len(adapter_requirements),
        len(unsupported),
    )
    return PlanInspection(
        schema_version=INSPECTION_SCHEMA_VERSION,
        inql_version=inql_version(),
        plan_id=plan_id,
        plan_target=plan_target,
        root_target=_authored_node_target(plan_id, authored_context.node(tip_id)),
        authored_node_count=len(authored_ids),
        rewritten_node_count=rewritten_context.node_count(),
        rewrite_rule_names=explain.applied_rule_names,
        output_schema=tip_output_schema,
        output_fields=output_fields,
        authored_nodes=authored_nodes,
        rewritten_nodes=rewritten_nodes,
        lineage=lineage,
        adapter_requirements=adapter_requirements,
        attachments=attachments,
        governed_attributes=governed_attributes,
        policy_checkpoints=policy_checkpoints,
        artifacts=artifacts,
        unsupported_evidence=unsupported,
        diagnostics=[],
    )


pub def inspect_lineage[T with Clone](data: LazyFrame[T]) -> LineageGraph:
    """Return the Prism lineage graph for one lazy plan."""
    store_id = data._cursor.store_id
    tip_id = data._cursor.tip_id
    authored_ids = reachable_node_ids(store_id, tip_id)
    context = _AuthoredInspectionContext.new(store_id, authored_ids)
    return _lineage_graph_for_authored_plan(_plan_id(store_id, tip_id), context, authored_ids)


def _authored_node_inspections(
    plan_id: str,
    context: _AuthoredInspectionContext,
    authored_ids: list[int],
) -> list[PlanNodeInspection]:
    """Build authored Prism node inspection records for reachable nodes."""
    mut records: list[PlanNodeInspection] = []
    for node_id in authored_ids:
        node = context.node(node_id)
        records.append(
            PlanNodeInspection(
                target=_authored_node_target(plan_id, node),
                kind=_inspection_node_kind(node.kind),
                input_target_ids=[_authored_node_id(plan_id, input_id) for input_id in node.input_ids],
                output_fields=_field_targets_for_schema(plan_id, node_id, context.schema(node_id)),
            ),
        )
    return records


def _rewritten_node_inspections(plan_id: str, context: _RewrittenInspectionContext) -> list[PlanNodeInspection]:
    """Build rewritten Prism node inspection records for the canonical rewritten view."""
    mut records: list[PlanNodeInspection] = []
    for node in context.nodes():
        records.append(
            PlanNodeInspection(
                target=_rewritten_node_target(plan_id, node, context.origin_node_id(node.node_id)),
                kind=_inspection_node_kind(node.kind),
                input_target_ids=[_rewritten_node_id(plan_id, input_id) for input_id in node.input_ids],
                output_fields=_field_targets_for_schema(plan_id, node.node_id, context.schema(node.node_id)),
            ),
        )
    return records


def _inspection_node_kind(kind: PrismNodeKind) -> InspectionNodeKind:
    """Map internal Prism node kinds into the public inspection vocabulary."""
    match kind:
        PrismNodeKind.ReadNamedTable => return InspectionNodeKind.ReadNamedTable
        PrismNodeKind.Filter => return InspectionNodeKind.Filter
        PrismNodeKind.Join => return InspectionNodeKind.Join
        PrismNodeKind.Project => return InspectionNodeKind.Project
        PrismNodeKind.SelectProject => return InspectionNodeKind.SelectProject
        PrismNodeKind.GroupBy => return InspectionNodeKind.GroupBy
        PrismNodeKind.Aggregate => return InspectionNodeKind.Aggregate
        PrismNodeKind.Generate => return InspectionNodeKind.Generate
        PrismNodeKind.Window => return InspectionNodeKind.Window
        PrismNodeKind.OrderBy => return InspectionNodeKind.OrderBy
        PrismNodeKind.Limit => return InspectionNodeKind.Limit


def _adapter_requirements_for_authored_plan(
    plan_id: str,
    plan_target: SemanticTarget,
    context: _AuthoredInspectionContext,
    authored_ids: list[int],
    lineage: LineageGraph,
) -> list[AdapterRequirement]:
    """Infer adapter requirements from plan-inspection evidence without binding a backend."""
    mut requirements: list[AdapterRequirement] = []
    _append_adapter_requirement_once(
        requirements,
        plan_target,
        AdapterRequirementCapability.NullSemantics,
        AdapterRequirementGuarantee.Required,
        "plan execution requires adapter null semantics for scalar and relational evaluation",
        _plan_evidence_ref(plan_id),
    )
    if len(lineage.edges) > 0:
        _append_adapter_requirement_once(
            requirements,
            plan_target,
            AdapterRequirementCapability.LineagePreservation,
            AdapterRequirementGuarantee.Preferred,
            "lineage evidence exists and may need adapter preservation across execution boundaries",
            f"{plan_id}:lineage_graph",
        )
    for node_id in authored_ids:
        _append_node_adapter_requirements(requirements, plan_id, context.node(node_id))
    return requirements


def _append_node_adapter_requirements(
    mut requirements: list[AdapterRequirement],
    plan_id: str,
    node: PrismNode,
) -> None:
    """Append adapter requirements implied by one authored Prism node and its expressions."""
    target = _authored_node_target(plan_id, node)
    evidence_ref = _node_evidence_ref(plan_id, node.node_id)
    function_names = _node_scalar_function_names(node)
    match node.kind:
        PrismNodeKind.Filter =>
            _append_adapter_requirement_once(
                requirements,
                target,
                AdapterRequirementCapability.RowFilter,
                AdapterRequirementGuarantee.Required,
                "filter nodes require adapter row-filter execution",
                evidence_ref,
            )
        PrismNodeKind.OrderBy =>
            _append_adapter_requirement_once(
                requirements,
                target,
                AdapterRequirementCapability.OrderedExecution,
                AdapterRequirementGuarantee.Required,
                "order-by nodes require ordered adapter execution",
                evidence_ref,
            )
        PrismNodeKind.Window =>
            if _window_node_requires_ordering(node):
                _append_adapter_requirement_once(
                    requirements,
                    target,
                    AdapterRequirementCapability.OrderedExecution,
                    AdapterRequirementGuarantee.Required,
                    "window specifications with ordering require ordered adapter execution",
                    evidence_ref,
                )
        PrismNodeKind.Aggregate =>
            if _aggregate_node_requires_ordering(node):
                _append_adapter_requirement_once(
                    requirements,
                    target,
                    AdapterRequirementCapability.OrderedExecution,
                    AdapterRequirementGuarantee.Required,
                    "ordered aggregate inputs require ordered adapter execution",
                    evidence_ref,
                )
        _ => pass
    if len(function_names) > 0 or _node_has_direct_function_application(node):
        _append_adapter_requirement_once(
            requirements,
            target,
            AdapterRequirementCapability.ExtensionFunction,
            AdapterRequirementGuarantee.Required,
            "registered helper calls in this node require adapter function-extension coverage",
            evidence_ref,
        )
    if _function_names_include_variant(function_names):
        _append_adapter_requirement_once(
            requirements,
            target,
            AdapterRequirementCapability.VariantSemantics,
            AdapterRequirementGuarantee.Required,
            "variant helper calls in this node require adapter semi-structured value semantics",
            evidence_ref,
        )
    return


def _append_adapter_requirement_once(
    mut requirements: list[AdapterRequirement],
    target: SemanticTarget,
    capability: AdapterRequirementCapability,
    guarantee: AdapterRequirementGuarantee,
    reason: str,
    evidence_ref: str,
) -> None:
    """Append one inferred adapter requirement unless the same target/capability is already present."""
    for requirement in requirements:
        if requirement.target.target_id == target.target_id and requirement.capability == capability:
            return
    requirements.append(
        AdapterRequirement(
            requirement_id=_adapter_requirement_id(target, capability),
            target=target,
            capability=capability,
            guarantee=guarantee,
            reason=reason,
            evidence_refs=[evidence_ref],
        ),
    )
    return


def _adapter_requirement_id(target: SemanticTarget, capability: AdapterRequirementCapability) -> str:
    """Return a stable local identity for one inferred adapter requirement."""
    return f"{target.target_id}:adapter-requirement:{capability.value()}"


def _plan_evidence_ref(plan_id: str) -> str:
    """Return the inspection evidence reference for the full plan."""
    return f"{plan_id}:plan_graph"


def _node_evidence_ref(plan_id: str, node_id: int) -> str:
    """Return the inspection evidence reference for one authored Prism node."""
    return f"{plan_id}:authored_node:{node_id}"


def _node_has_direct_function_application(node: PrismNode) -> bool:
    """Return whether one node carries non-scalar registry-backed applications."""
    if len(node.aggregate_measures) > 0:
        return true
    if len(node.generator_applications) > 0:
        return true
    if len(node.window_projections) > 0:
        return true
    return false


def _function_names_include_variant(function_names: list[str]) -> bool:
    """Return whether any scalar function name belongs to the variant/semi-structured helper family."""
    for function_name in function_names:
        match function_registry_entry_by_name(function_name):
            Some(entry) =>
                if entry.variant.is_variant_aware:
                    return true
            None => pass
    return false


def _node_scalar_function_names(node: PrismNode) -> list[str]:
    """Return unique scalar function names referenced by one Prism node."""
    return _function_names_for_exprs(_node_expressions(node))


def _node_expressions(node: PrismNode) -> list[ColumnExpr]:
    """Collect scalar expressions carried by one authored Prism node."""
    mut expressions: list[ColumnExpr] = []
    match node.kind:
        PrismNodeKind.Filter => expressions.append(node.filter_predicate)
        PrismNodeKind.Join => expressions.append(node.join_predicate)
        PrismNodeKind.Project =>
            for assignment in node.projection_assignments:
                expressions.append(assignment.expr)
        PrismNodeKind.SelectProject =>
            for assignment in node.projection_assignments:
                expressions.append(assignment.expr)
        PrismNodeKind.GroupBy => expressions.extend(node.group_columns)
        PrismNodeKind.Aggregate =>
            expressions.extend(node.group_columns)
            for measure in node.aggregate_measures:
                expressions.extend(measure.arguments)
                if measure.has_filter:
                    expressions.append(measure.filter_expr)
                expressions.extend(measure.ordering)
        PrismNodeKind.Generate =>
            for generator in node.generator_applications:
                expressions.extend(generator.arguments)
        PrismNodeKind.Window =>
            for projection in node.window_projections:
                expressions.extend(projection.application.arguments)
                expressions.extend(projection.application.spec.partition_columns)
                expressions.extend(projection.application.spec.sort_columns)
        PrismNodeKind.OrderBy => expressions.extend(node.sort_columns)
        _ => pass
    return expressions


def _function_names_for_exprs(expressions: list[ColumnExpr]) -> list[str]:
    """Return unique registry-backed scalar function names referenced by expressions."""
    mut function_names = OrderedSet[str]()
    for expr in expressions:
        for function_name in _expr_function_names(expr):
            function_names.add(function_name)
    return function_names.to_list()


def _expr_function_names(expr: ColumnExpr) -> list[str]:
    """Return unique registry-backed scalar function names referenced by one expression tree."""
    match untyped_column_expr(expr):
        ScalarFunctionApplicationExpr(application) =>
            mut names = OrderedSet[str]()
            names.add(application.canonical_name)
            for argument in application.arguments:
                for function_name in _expr_function_names(argument):
                    names.add(function_name)
            return names.to_list()
        _ => return []


def _window_node_requires_ordering(node: PrismNode) -> bool:
    """Return whether any window projection carries an ordering requirement."""
    for projection in node.window_projections:
        if projection.application.requires_ordering:
            return true
        if len(projection.application.spec.sort_columns) > 0:
            return true
    return false


def _aggregate_node_requires_ordering(node: PrismNode) -> bool:
    """Return whether aggregate measures carry ordered-input modifiers."""
    for measure in node.aggregate_measures:
        if len(measure.ordering) > 0:
            return true
    return false


def _lineage_graph_for_authored_plan(
    plan_id: str,
    context: _AuthoredInspectionContext,
    authored_ids: list[int],
) -> LineageGraph:
    """Extract a conservative first lineage graph from authored Prism nodes."""
    mut edges: list[LineageEdge] = []
    for node_id in authored_ids:
        edges.extend(_lineage_edges_for_node(plan_id, context, context.node(node_id)))
    return LineageGraph(plan_id=plan_id, rule_version=LINEAGE_RULE_VERSION, edges=edges)


def _lineage_edges_for_node(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return semantic lineage edges for one authored Prism node."""
    match node.kind:
        PrismNodeKind.ReadNamedTable => return _read_root_edges(plan_id, context, node)
        PrismNodeKind.Filter => return _filter_edges(plan_id, context, node)
        PrismNodeKind.Join => return _join_edges(plan_id, context, node)
        PrismNodeKind.Project => return _project_edges(plan_id, context, node)
        PrismNodeKind.SelectProject => return _select_project_edges(plan_id, context, node)
        PrismNodeKind.GroupBy => return _group_by_edges(plan_id, context, node)
        PrismNodeKind.Aggregate => return _aggregate_edges(plan_id, context, node)
        PrismNodeKind.Generate => return _generate_edges(plan_id, context, node)
        PrismNodeKind.Window => return _window_edges(plan_id, context, node)
        PrismNodeKind.OrderBy => return _order_by_edges(plan_id, context, node)
        PrismNodeKind.Limit => return _passthrough_value_edges(plan_id, context, node)


def _read_root_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Attach read-root targets to the fields introduced by a read node."""
    source = _semantic_target(
        SemanticTargetKind.ReadRoot,
        plan_id,
        _read_root_id(plan_id, node.named_table),
        "read_root",
        f"read_root/{node.named_table}",
        node.named_table,
        Some(node.node_id),
        None,
    )
    mut edges: list[LineageEdge] = []
    for field in _field_targets_for_schema(plan_id, node.node_id, context.schema(node.node_id)):
        edges.append(_edge(source, field, LineageRelationshipKind.Value, LineageTransformationKind.Identity))
    return edges


def _filter_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return passthrough value lineage plus control lineage from the predicate."""
    mut edges = _passthrough_value_edges(plan_id, context, node)
    relation_output = _relation_output_target(plan_id, node)
    edges.extend(
        _dependency_edges(
            plan_id,
            context,
            node.input_ids[0],
            node.node_id,
            [node.filter_predicate],
            relation_output,
            LineageRelationshipKind.Control,
            LineageTransformationKind.Filter,
        ),
    )
    return edges


def _join_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return join predicate lineage and value passthrough lineage from both sides."""
    mut edges: list[LineageEdge] = []
    join_output_schema = context.schema(node.node_id)
    left_schema = context.schema(node.input_ids[0])
    right_schema = context.schema(node.input_ids[1])
    for idx, column in enumerate(left_schema):
        edges.append(
            _edge(
                _field_target(plan_id, node.input_ids[0], idx, column.name),
                _field_target(plan_id, node.node_id, idx, column.name),
                LineageRelationshipKind.Value,
                LineageTransformationKind.Identity,
            ),
        )
    for idx, column in enumerate(right_schema):
        right_output_idx = len(left_schema) + idx
        right_output_name = join_output_schema[right_output_idx].name
        edges.append(
            _edge(
                _field_target(plan_id, node.input_ids[1], idx, column.name),
                _field_target(plan_id, node.node_id, right_output_idx, right_output_name),
                LineageRelationshipKind.Value,
                LineageTransformationKind.Identity,
            ),
        )
    edges.extend(_join_predicate_edges(plan_id, context, node))
    return edges


def _join_predicate_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Resolve join predicate dependencies against both join inputs."""
    relation_output = _relation_output_target(plan_id, node)
    left_input_id = node.input_ids[0]
    right_input_id = node.input_ids[1]
    left_schema = context.schema(left_input_id)
    right_schema = context.schema(right_input_id)
    mut edges: list[LineageEdge] = []
    for name in _dependency_names([node.join_predicate]):
        left_idx = _field_index(left_schema, name)
        right_idx = _field_index(right_schema, name)
        left_count = _field_match_count(left_schema, name)
        right_count = _field_match_count(right_schema, name)
        if left_count == 1:
            edges.append(
                _dependency_edge(
                    _field_target(plan_id, left_input_id, left_idx, name),
                    relation_output,
                    LineageRelationshipKind.Join,
                    LineageTransformationKind.Join,
                    _expression_ref(plan_id, node.node_id, name),
                    LineageConfidence.Exact,
                ),
            )
        elif left_count > 1:
            edges.append(
                _dependency_edge(
                    _field_target(plan_id, left_input_id, -1, name),
                    relation_output,
                    LineageRelationshipKind.Join,
                    LineageTransformationKind.Join,
                    _expression_ref(plan_id, node.node_id, name),
                    LineageConfidence.Conservative,
                ),
            )
        if right_count == 1:
            edges.append(
                _dependency_edge(
                    _field_target(plan_id, right_input_id, right_idx, name),
                    relation_output,
                    LineageRelationshipKind.Join,
                    LineageTransformationKind.Join,
                    _expression_ref(plan_id, node.node_id, name),
                    LineageConfidence.Exact,
                ),
            )
        elif right_count > 1:
            edges.append(
                _dependency_edge(
                    _field_target(plan_id, right_input_id, -1, name),
                    relation_output,
                    LineageRelationshipKind.Join,
                    LineageTransformationKind.Join,
                    _expression_ref(plan_id, node.node_id, name),
                    LineageConfidence.Conservative,
                ),
            )
        if left_count == 0 and right_count == 0:
            edges.append(
                _dependency_edge(
                    _field_target(plan_id, left_input_id, -1, name),
                    relation_output,
                    LineageRelationshipKind.Join,
                    LineageTransformationKind.Join,
                    _expression_ref(plan_id, node.node_id, name),
                    LineageConfidence.Conservative,
                ),
            )
    return edges


def _project_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return add-or-replace projection lineage over the current schema bindings."""
    mut edges = _passthrough_value_edges(plan_id, context, node)
    project_output_schema = context.schema(node.node_id)
    for assignment in node.projection_assignments:
        project_output_idx = _field_index(project_output_schema, assignment.output_name)
        if project_output_idx >= 0:
            edges.extend(
                _field_edges_from_expression(
                    plan_id,
                    context,
                    node.input_ids[0],
                    node.node_id,
                    assignment.expr,
                    project_output_idx,
                    assignment.output_name,
                    LineageRelationshipKind.Value,
                ),
            )
    return edges


def _select_project_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return exclusive SELECT projection lineage."""
    mut edges: list[LineageEdge] = []
    for idx, assignment in enumerate(node.projection_assignments):
        edges.extend(
            _field_edges_from_expression(
                plan_id,
                context,
                node.input_ids[0],
                node.node_id,
                assignment.expr,
                idx,
                assignment.output_name,
                LineageRelationshipKind.Value,
            ),
        )
    return edges


def _group_by_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return grouping lineage from group expressions to grouped output fields."""
    mut edges: list[LineageEdge] = []
    group_output_schema = context.schema(node.node_id)
    for idx, expr in enumerate(node.group_columns):
        edges.extend(
            _field_edges_from_expression(
                plan_id,
                context,
                node.input_ids[0],
                node.node_id,
                expr,
                idx,
                group_output_schema[idx].name,
                LineageRelationshipKind.Grouping,
            ),
        )
    return edges


def _field_edges_from_expression(
    plan_id: str,
    context: _AuthoredInspectionContext,
    source_node_id: int,
    evidence_node_id: int,
    expr: ColumnExpr,
    output_idx: int,
    output_name: str,
    relationship: LineageRelationshipKind,
) -> list[LineageEdge]:
    """Connect one scalar expression to one output field target."""
    return _dependency_edges(
        plan_id,
        context,
        source_node_id,
        evidence_node_id,
        [expr],
        _field_target(plan_id, evidence_node_id, output_idx, output_name),
        relationship,
        _expression_transformation(expr),
    )


def _aggregate_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return grouping-prefix and aggregate-measure lineage."""
    mut edges: list[LineageEdge] = []
    aggregate_output_schema = context.schema(node.node_id)
    grouping_prefix_count = len(aggregate_output_schema) - len(node.aggregate_measures)
    if grouping_prefix_count > 0:
        edges.extend(_aggregate_grouping_prefix_edges(plan_id, context, node, grouping_prefix_count))
    for idx, measure in enumerate(node.aggregate_measures):
        measure_output_idx = grouping_prefix_count + idx
        measure_destination = _field_target(
            plan_id,
            node.node_id,
            measure_output_idx,
            aggregate_output_schema[measure_output_idx].name,
        )
        edges.extend(_aggregate_measure_edges(plan_id, context, node, measure, measure_destination))
    return edges


def _aggregate_grouping_prefix_edges(
    plan_id: str,
    context: _AuthoredInspectionContext,
    node: PrismNode,
    grouping_prefix_count: int,
) -> list[LineageEdge]:
    """Preserve grouping lineage for grouped aggregate prefix fields."""
    aggregate_input_node = context.node(node.input_ids[0])
    mut group_columns: list[ColumnExpr] = []
    if len(node.group_columns) > 0:
        group_columns = node.group_columns
    elif aggregate_input_node.kind == PrismNodeKind.GroupBy:
        group_columns = aggregate_input_node.group_columns
    mut edges: list[LineageEdge] = []
    for idx in range(grouping_prefix_count):
        if idx < len(group_columns):
            output_name = context.schema(node.node_id)[idx].name
            mut source_input_id = node.input_ids[0]
            if aggregate_input_node.kind == PrismNodeKind.GroupBy:
                source_input_id = aggregate_input_node.input_ids[0]
            edges.extend(
                _field_edges_from_expression(
                    plan_id,
                    context,
                    source_input_id,
                    node.node_id,
                    group_columns[idx],
                    idx,
                    output_name,
                    LineageRelationshipKind.Grouping,
                ),
            )
    return edges


def _aggregate_measure_edges(
    plan_id: str,
    context: _AuthoredInspectionContext,
    node: PrismNode,
    measure: AggregateMeasure,
    destination: SemanticTarget,
) -> list[LineageEdge]:
    """Return lineage edges for one aggregate measure output."""
    aggregate_input_id = _aggregate_input_id(context, node)
    if measure.has_expr:
        return _dependency_edges(
            plan_id,
            context,
            aggregate_input_id,
            node.node_id,
            measure.arguments,
            destination,
            LineageRelationshipKind.Value,
            LineageTransformationKind.Aggregate,
        )
    return [_edge(
        _relation_output_target(plan_id, context.node(aggregate_input_id)),
        destination,
        LineageRelationshipKind.Value,
        LineageTransformationKind.Aggregate,
    )]


def _aggregate_input_id(context: _AuthoredInspectionContext, node: PrismNode) -> int:
    """Return the scalar-input node id for aggregate measures, skipping explicit GroupBy scaffolding."""
    aggregate_input_node = context.node(node.input_ids[0])
    if aggregate_input_node.kind == PrismNodeKind.GroupBy:
        return aggregate_input_node.input_ids[0]
    return node.input_ids[0]


def _generate_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return generator lineage and preserved input field lineage."""
    mut edges = _passthrough_value_edges(plan_id, context, node)
    if len(node.generator_applications) == 0:
        return edges
    generator = node.generator_applications[0]
    generator_output_schema = context.schema(node.node_id)
    for output_name in generator.output_columns:
        generator_output_idx = _field_index(generator_output_schema, output_name)
        if generator_output_idx >= 0:
            generator_destination = _field_target(plan_id, node.node_id, generator_output_idx, output_name)
            edges.extend(
                _dependency_edges(
                    plan_id,
                    context,
                    node.input_ids[0],
                    node.node_id,
                    generator.arguments,
                    generator_destination,
                    LineageRelationshipKind.Value,
                    LineageTransformationKind.Generator,
                ),
            )
    return edges


def _window_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return passthrough value lineage plus window-output dependency edges."""
    mut edges = _passthrough_value_edges(plan_id, context, node)
    for projection in node.window_projections:
        edges.extend(_window_projection_edges(plan_id, context, node, projection))
    return edges


def _window_projection_edges(
    plan_id: str,
    context: _AuthoredInspectionContext,
    node: PrismNode,
    projection: WindowProjection,
) -> list[LineageEdge]:
    """Return lineage edges for one named window output column."""
    window_output_idx = _field_index(context.schema(node.node_id), projection.output_name)
    if window_output_idx < 0:
        return []
    window_destination = _field_target(plan_id, node.node_id, window_output_idx, projection.output_name)
    mut expressions: list[ColumnExpr] = []
    expressions.extend(projection.application.arguments)
    expressions.extend(projection.application.spec.partition_columns)
    expressions.extend(projection.application.spec.sort_columns)
    return _dependency_edges(
        plan_id,
        context,
        node.input_ids[0],
        node.node_id,
        expressions,
        window_destination,
        LineageRelationshipKind.Window,
        LineageTransformationKind.Window,
    )


def _order_by_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return passthrough value lineage plus sort dependency edges."""
    mut edges = _passthrough_value_edges(plan_id, context, node)
    edges.extend(
        _dependency_edges(
            plan_id,
            context,
            node.input_ids[0],
            node.node_id,
            node.sort_columns,
            _relation_output_target(plan_id, node),
            LineageRelationshipKind.Sort,
            LineageTransformationKind.Expression,
        ),
    )
    return edges


def _passthrough_value_edges(plan_id: str, context: _AuthoredInspectionContext, node: PrismNode) -> list[LineageEdge]:
    """Return identity value lineage for node kinds that preserve field slots."""
    passthrough_input_schema = context.schema(node.input_ids[0])
    passthrough_output_schema = context.schema(node.node_id)
    mut edges: list[LineageEdge] = []
    for idx, column in enumerate(passthrough_input_schema):
        if idx < len(passthrough_output_schema):
            edges.append(
                _edge(
                    _field_target(plan_id, node.input_ids[0], idx, column.name),
                    _field_target(plan_id, node.node_id, idx, passthrough_output_schema[idx].name),
                    LineageRelationshipKind.Value,
                    LineageTransformationKind.Identity,
                ),
            )
    return edges


def _dependency_edges(
    plan_id: str,
    context: _AuthoredInspectionContext,
    source_node_id: int,
    evidence_node_id: int,
    expressions: list[ColumnExpr],
    destination: SemanticTarget,
    relationship: LineageRelationshipKind,
    transformation: LineageTransformationKind,
) -> list[LineageEdge]:
    """Build lineage edges from scalar column dependencies to one destination target."""
    source_schema = context.schema(source_node_id)
    mut edges: list[LineageEdge] = []
    for name in _dependency_names(expressions):
        mut source_idx = _field_index(source_schema, name)
        mut confidence = LineageConfidence.Exact
        if _field_match_count(source_schema, name) != 1:
            source_idx = -1
            confidence = LineageConfidence.Conservative
        source = _field_target(plan_id, source_node_id, source_idx, name)
        edges.append(
            _dependency_edge(
                source,
                destination,
                relationship,
                transformation,
                _expression_ref(plan_id, evidence_node_id, name),
                confidence,
            ),
        )
    return edges


def _dependency_names(expressions: list[ColumnExpr]) -> list[str]:
    """Return unique column-reference names found across expression dependencies."""
    mut dependency_names = OrderedSet[str]()
    for expr in expressions:
        for dependency_name in _expr_dependency_names(expr):
            dependency_names.add(dependency_name)
    return dependency_names.to_list()


def _expr_dependency_names(expr: ColumnExpr) -> list[str]:
    """Return unique column-reference names found inside one scalar expression."""
    match untyped_column_expr(expr):
        ColumnRefExpr(column) => return [column.column_name]
        ScalarFunctionApplicationExpr(application) =>
            mut names = OrderedSet[str]()
            for argument in application.arguments:
                for dependency_name in _expr_dependency_names(argument):
                    names.add(dependency_name)
            return names.to_list()
        _ => return []


def _field_targets_for_schema(plan_id: str, node_id: int, schema: list[ScalarColumnSpec]) -> list[SemanticTarget]:
    """Build field targets for one node's output schema."""
    return [_field_target(plan_id, node_id, idx, column.name) for idx, column in enumerate(schema)]


def _field_target(plan_id: str, node_id: int, ordinal: int, name: str) -> SemanticTarget:
    """Build one field semantic target."""
    mut ordinal_text = str(ordinal)
    mut ordinal_value: Option[int] = Some(ordinal)
    if ordinal < 0:
        ordinal_text = str("unknown")
        ordinal_value = None
    return _semantic_target(
        SemanticTargetKind.Field,
        plan_id,
        _target_id(plan_id, "field", f"node-{node_id}/field-{ordinal_text}/{name}"),
        f"authored-node:{node_id}",
        f"authored/{node_id}/field/{ordinal_text}",
        name,
        Some(node_id),
        ordinal_value,
    )


def _relation_output_target(plan_id: str, node: PrismNode) -> SemanticTarget:
    """Build one relation-output target for a Prism node."""
    return _semantic_target(
        SemanticTargetKind.RelationOutput,
        plan_id,
        _target_id(plan_id, "relation-output", f"node-{node.node_id}"),
        f"authored-node:{node.node_id}",
        f"authored/{node.node_id}/output",
        node.kind.value(),
        Some(node.node_id),
        None,
    )


def _authored_node_target(plan_id: str, node: PrismNode) -> SemanticTarget:
    """Build one authored Prism node target."""
    return _semantic_target(
        SemanticTargetKind.AuthoredPrismNode,
        plan_id,
        _authored_node_id(plan_id, node.node_id),
        "authored",
        f"authored/{node.node_id}",
        node.kind.value(),
        Some(node.node_id),
        None,
    )


def _rewritten_node_target(plan_id: str, node: PrismNode, origin_node_id: int) -> SemanticTarget:
    """Build one rewritten Prism node target that preserves authored origin in its path."""
    return _semantic_target(
        SemanticTargetKind.RewrittenPrismNode,
        plan_id,
        _rewritten_node_id(plan_id, node.node_id),
        "rewritten",
        f"rewritten/{node.node_id}/origin/{origin_node_id}",
        node.kind.value(),
        Some(node.node_id),
        None,
    )


def _semantic_target(
    kind: SemanticTargetKind,
    plan_id: str,
    target_id: str,
    scope_id: str,
    path: str,
    name: str,
    node_id: Option[int],
    ordinal: Option[int],
) -> SemanticTarget:
    """Build one semantic target under the provided local plan id."""
    return SemanticTarget(
        kind=kind,
        target_id=target_id,
        plan_id=plan_id,
        scope_id=scope_id,
        path=path,
        name=name,
        node_id=node_id,
        ordinal=ordinal,
    )


def _edge(
    source: SemanticTarget,
    destination: SemanticTarget,
    relationship: LineageRelationshipKind,
    transformation: LineageTransformationKind,
) -> LineageEdge:
    """Build one exact lineage edge without an expression subtarget reference."""
    return LineageEdge(
        source=source,
        destination=destination,
        relationship=relationship,
        transformation=transformation,
        expression_ref="",
        confidence=LineageConfidence.Exact,
        evidence_refs=[],
    )


def _dependency_edge(
    source: SemanticTarget,
    destination: SemanticTarget,
    relationship: LineageRelationshipKind,
    transformation: LineageTransformationKind,
    expression_ref: str,
    confidence: LineageConfidence,
) -> LineageEdge:
    """Build one dependency lineage edge with a scalar expression reference."""
    return LineageEdge(
        source=source,
        destination=destination,
        relationship=relationship,
        transformation=transformation,
        expression_ref=expression_ref,
        confidence=confidence,
        evidence_refs=[],
    )


def _artifact_summaries(
    plan_node_count: int,
    lineage_edge_count: int,
    schema_field_count: int,
    metadata_attachment_count: int,
    governed_attribute_count: int,
    policy_checkpoint_count: int,
    adapter_requirement_count: int,
    unsupported_count: int,
) -> list[InspectionArtifact]:
    """Return deterministic inspection artifact-family summaries."""
    mut artifacts: list[InspectionArtifact] = []
    artifacts.append(_artifact("plan_graph", EvidenceArtifactStatus.Computed, plan_node_count))
    artifacts.append(_artifact("lineage_graph", EvidenceArtifactStatus.Computed, lineage_edge_count))
    artifacts.append(_artifact("schema_flow", EvidenceArtifactStatus.Computed, schema_field_count))
    artifacts.append(_artifact("metadata_attachments", EvidenceArtifactStatus.Computed, metadata_attachment_count))
    artifacts.append(_artifact("governed_attributes", EvidenceArtifactStatus.Computed, governed_attribute_count))
    artifacts.append(_artifact("policy_checkpoints", EvidenceArtifactStatus.Computed, policy_checkpoint_count))
    artifacts.append(_artifact("adapter_requirements", EvidenceArtifactStatus.Computed, adapter_requirement_count))
    artifacts.append(_artifact("diagnostics", EvidenceArtifactStatus.Computed, 0))
    artifacts.append(_artifact("unsupported_evidence", EvidenceArtifactStatus.Computed, unsupported_count))
    return artifacts


def _metadata_attachments(
    plan_target: SemanticTarget,
    output_fields: list[SemanticTarget],
    output_schema: list[ScalarColumnSpec],
) -> list[MetadataAttachment]:
    """Return typed metadata attachments that are known during local plan inspection."""
    mut attachments: list[MetadataAttachment] = []
    attachments.append(
        _public_attachment(
            plan_target,
            "inql.inspection",
            "schema_version",
            INSPECTION_SCHEMA_VERSION,
            MetadataLifecycle.Analyzed,
            MetadataSource.InQL,
        ),
    )
    attachments.append(
        _public_attachment(
            plan_target,
            "inql.lineage",
            "rule_version",
            LINEAGE_RULE_VERSION,
            MetadataLifecycle.Analyzed,
            MetadataSource.Prism,
        ),
    )
    for idx, column in enumerate(output_schema):
        if idx < len(output_fields):
            if let Some(kind) = column.kind:
                attachments.append(
                    _public_attachment(
                        output_fields[idx],
                        "inql.schema",
                        "substrait_primitive_kind",
                        kind.value(),
                        MetadataLifecycle.Analyzed,
                        MetadataSource.Prism,
                    ),
                )
    return attachments


def _governed_attributes_from_metadata(attachments: list[MetadataAttachment]) -> list[GovernedAttribute]:
    """Promote local schema metadata into conservative governed attributes."""
    mut attributes: list[GovernedAttribute] = []
    for attachment in attachments:
        if attachment.namespace == "inql.schema" and attachment.key == "substrait_primitive_kind":
            attributes.append(
                governed_attribute(
                    attachment.target,
                    "schema.substrait_primitive_kind",
                    attachment.payload.value,
                    value_schema="inql.governance.schema-primitive-kind.v0.1",
                    scope=GovernedAttributeScope.Field,
                    source=GovernedAttributeSource.Lineage,
                    confidence=GovernedAttributeConfidence.Exact,
                    status=GovernedAttributeStatus.Inferred,
                    evidence_refs=[_metadata_evidence_ref(attachment)],
                ),
            )
    return attributes


def _policy_checkpoints_for_inspection(
    plan_target: SemanticTarget,
    governed_attributes: list[GovernedAttribute],
) -> list[PolicyCheckpoint]:
    """Record that inspection observed governed evidence but did not enforce policy."""
    if len(governed_attributes) == 0:
        return []
    mut evidence_refs: list[str] = []
    for attribute in governed_attributes:
        evidence_refs.append(attribute.attribute_id)
    return [policy_checkpoint(
        plan_target,
        PolicyCheckpointKind.Planning,
        PolicyCheckpointAction.Observe,
        "inql.policy.local-inspection",
        "governed_evidence_observed",
        evidence_refs=evidence_refs,
    )]


def _metadata_evidence_ref(attachment: MetadataAttachment) -> str:
    """Return a stable local evidence reference for one metadata attachment."""
    return f"metadata:{attachment.target.target_id}:{attachment.namespace}:{attachment.key}"


def _public_attachment(
    target: SemanticTarget,
    namespace: str,
    key: str,
    value: str,
    lifecycle: MetadataLifecycle,
    source: MetadataSource,
) -> MetadataAttachment:
    """Build one public string metadata attachment with an explicit payload schema."""
    return MetadataAttachment(
        target=target,
        namespace=namespace,
        key=key,
        payload=MetadataPayload(schema="inql.metadata.string.v0.1", value=value),
        lifecycle=lifecycle,
        source=source,
        visibility=MetadataVisibility.Public,
        evidence_refs=[],
    )


def _artifact(family: str, status: EvidenceArtifactStatus, record_count: int) -> InspectionArtifact:
    """Build one artifact-family summary."""
    return InspectionArtifact(
        family=family,
        schema_version=INSPECTION_SCHEMA_VERSION,
        status=status,
        record_count=record_count,
    )


def _unsupported_evidence_markers() -> list[UnsupportedEvidence]:
    """Return explicit evidence families intentionally absent from this local Prism-only slice."""
    mut markers: list[UnsupportedEvidence] = []
    markers.append(
        UnsupportedEvidence(family="semantic_profiles", reason="local inspection does not infer semantic profiles"),
    )
    markers.append(
        UnsupportedEvidence(family="ingress_mappings", reason="this plan did not enter through an ingress frontend"),
    )
    markers.append(
        UnsupportedEvidence(family="client_session_context", reason="lazy plan inspection has no client session target"),
    )
    markers.append(
        UnsupportedEvidence(family="frontend_coverage", reason="frontend coverage records are not implemented yet"),
    )
    return markers


def _expression_transformation(expr: ColumnExpr) -> LineageTransformationKind:
    """Classify direct references precisely and leave scalar function lineage policy conservative."""
    match untyped_column_expr(expr):
        ColumnRefExpr(_) => return LineageTransformationKind.Identity
        ScalarFunctionApplicationExpr(_) => return LineageTransformationKind.Unknown
        _ => return LineageTransformationKind.Expression


def _field_match_count(schema: list[ScalarColumnSpec], name: str) -> int:
    """Return how many fields in one schema have the provided display name."""
    mut count = 0
    for column in schema:
        if column.name == name:
            count += 1
    return count


def _field_index(schema: list[ScalarColumnSpec], name: str) -> int:
    """Return the first matching field index, or `-1` when not present."""
    for idx, column in enumerate(schema):
        if column.name == name:
            return idx
    return -1


def _plan_id(store_id: PrismStoreId, tip_id: int) -> str:
    """Build a local deterministic plan id for one Prism store/tip snapshot."""
    return prism_plan_id(store_id, tip_id)


def _target_id(plan_id: str, kind: str, path: str) -> str:
    """Build one target id under a plan id."""
    return f"{plan_id}:target:{kind}:{path}"


def _authored_node_id(plan_id: str, node_id: int) -> str:
    """Build one authored-node target id."""
    return _target_id(plan_id, "authored-node", f"{node_id}")


def _rewritten_node_id(plan_id: str, node_id: int) -> str:
    """Build one rewritten-node target id."""
    return _target_id(plan_id, "rewritten-node", f"{node_id}")


def _read_root_id(plan_id: str, table_name: str) -> str:
    """Build one read-root target id."""
    return _target_id(plan_id, "read-root", table_name)


def _expression_ref(plan_id: str, node_id: int, dependency_name: str) -> str:
    """Build a stable expression-reference string for a dependency found in a node expression."""
    return _target_id(plan_id, "scalar-expression", f"node-{node_id}/{dependency_name}")
