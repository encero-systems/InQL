pub def approx_count_distinct(expr: ColumnExpr) -> AggregateMeasure:
    """Build one approximate distinct-count aggregate measure over a scalar expression."""
    return AggregateMeasure(
        kind=AggregateKind.ApproxCountDistinct,
        function_ref=function_ref_for("approx_count_distinct"),
        canonical_name="approx_count_distinct",
        expr=expr,
        arguments=[expr],
        has_expr=true,
        is_distinct=false,
        filter_expr=col_expr(""),
        has_filter=false,
        ordering=[],
        sketch_type=None,
    )


pub def approx_percentile(expr: ColumnExpr, percentile: float, accuracy: int = 10000) -> AggregateMeasure:
    """Build one approximate percentile aggregate measure over a numeric scalar expression."""
    if percentile < 0.0 or percentile > 1.0:
        return raise_value_error("approx_percentile percentile must be between 0.0 and 1.0")
    if accuracy <= 0:
        return raise_value_error("approx_percentile accuracy must be positive")
    return AggregateMeasure(
        kind=AggregateKind.ApproxPercentile,
        function_ref=function_ref_for("approx_percentile"),
        canonical_name="approx_percentile",
        expr=expr,
        arguments=[expr, float_expr(percentile), int_expr(accuracy)],
        has_expr=true,
        is_distinct=false,
        filter_expr=col_expr(""),
        has_filter=false,
        ordering=[],
        sketch_type=None,
    )


pub def hll_sketch(
    expr: ColumnExpr,
    value_domain: SketchValueDomain = SketchValueDomain.StringIdentifier,
    precision: int = 14,
) -> AggregateMeasure:
    """Build one HyperLogLog sketch aggregate measure."""
    sketch_type = hll_type(value_domain=value_domain, precision=precision)
    return AggregateMeasure(
        kind=AggregateKind.HllSketch,
        function_ref=function_ref_for("hll_sketch"),
        canonical_name="hll_sketch",
        expr=expr,
        arguments=[expr, int_expr(precision)],
        has_expr=true,
        is_distinct=false,
        filter_expr=col_expr(""),
        has_filter=false,
        ordering=[],
        sketch_type=Some(sketch_type),
    )


pub def hll_merge(sketch: SketchExpr) -> AggregateMeasure:
    """Build one HyperLogLog sketch merge aggregate measure."""
    checked = require_hll_sketch(sketch, "hll_merge")
    return AggregateMeasure(
        kind=AggregateKind.HllMerge,
        function_ref=function_ref_for("hll_merge"),
        canonical_name="hll_merge",
        expr=checked.expr,
        arguments=[checked.expr],
        has_expr=true,
        is_distinct=false,
        filter_expr=col_expr(""),
        has_filter=false,
        ordering=[],
        sketch_type=Some(checked.sketch_type),
    )


pub def aggregate_measure_output_name(measure: AggregateMeasure) -> str:
    """Return the logical output column name for one aggregate measure."""
    mut output_name = measure.kind.value()
    if measure.is_distinct and measure.has_expr:
        output_name = output_name + "_distinct_" + scalar_expr_output_name(measure.expr, "expr")
    elif measure.has_expr:
        output_name = output_name + "_" + scalar_expr_output_name(measure.expr, "expr")
    if measure.kind == AggregateKind.ApproxPercentile:
        output_name = output_name + _approx_percentile_output_suffix(measure)
    output_name = output_name + _sketch_output_suffix(measure)
    if measure.has_filter:
        output_name = output_name + "_filtered"
    if len(measure.ordering) > 0:
        output_name = output_name + "_ordered"
    return output_name


def _approx_percentile_output_suffix(measure: AggregateMeasure) -> str:
    """Return the percentile/accuracy suffix for approximate percentile output names."""
    if len(measure.arguments) < 3:
        return ""
    percentile = _aggregate_literal_name(measure.arguments[1])
    accuracy = _aggregate_literal_name(measure.arguments[2])
    return f"_p{percentile}_a{accuracy}"


def _sketch_output_suffix(measure: AggregateMeasure) -> str:
    """Return the non-default sketch-compatibility suffix for output names."""
    match measure.sketch_type:
        Some(sketch_type) =>
            mut suffix = ""
            if sketch_type.value_domain != SketchValueDomain.StringIdentifier:
                suffix = suffix + "_" + sketch_type.value_domain.value()
            if sketch_type.precision != 14:
                suffix = suffix + f"_p{sketch_type.precision}"
            if sketch_type.format.value() != "inql_hll_v1":
                suffix = suffix + "_" + sketch_type.format.value()
            return suffix
        None => return ""


def _aggregate_literal_name(expr: ColumnExpr) -> str:
    """Return one output-name-safe literal label for aggregate parameters."""
    match untyped_column_expr(expr):
        IntLiteralExpr(literal) => return f"{literal.value}"
        FloatLiteralExpr(literal) => return f"{literal.value}".replace(".", "_")
        _ => return scalar_expr_output_name(expr, "expr")


pub def aggregate_measure_output_names(measures: list[AggregateMeasure]) -> list[str]:
    """Return logical output column names for aggregate measures in declaration order."""
    return [aggregate_measure_output_name(measure) for measure in measures]


module tests:
    from projection_builders import int_expr
    def test_count_default_is_distinct_from_literal_expressions() -> None:
        rows = count()
        literal = count(int_expr(1))

        assert not rows.has_expr
        assert literal.has_expr
