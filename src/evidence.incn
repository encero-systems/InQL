"""Shared relational evidence record types used by inspection and future governance surfaces."""


@derive(Clone)
pub enum SemanticTargetKind(str):
    """Semantic target categories shared by evidence APIs."""

    Plan = "plan"
    IngressRequest = "ingress_request"
    ClientSession = "client_session"
    IngressNode = "ingress_node"
    IngressExpression = "ingress_expression"
    AnalyzerBinding = "analyzer_binding"
    AuthoredPrismNode = "authored_prism_node"
    RewrittenPrismNode = "rewritten_prism_node"
    RelationOutput = "relation_output"
    Field = "field"
    ScalarExpression = "scalar_expression"
    AggregateMeasure = "aggregate_measure"
    WindowExpression = "window_expression"
    GeneratorOutput = "generator_output"
    ReadRoot = "read_root"
    GovernedAttribute = "governed_attribute"
    QualityAssertion = "quality_assertion"
    QualityObservation = "quality_observation"
    PolicyCheckpoint = "policy_checkpoint"
    PolicyDecision = "policy_decision"
    AdapterRequirement = "adapter_requirement"
    CoverageRecord = "coverage_record"
    SemanticProfile = "semantic_profile"
    ProfileAssessment = "profile_assessment"
    ExecutionAttempt = "execution_attempt"


@derive(Clone)
pub enum MetadataLifecycle(str):
    """Lifecycle phase for one metadata attachment."""

    Authored = "authored"
    Planned = "planned"
    Analyzed = "analyzed"
    Rewritten = "rewritten"
    Lowered = "lowered"
    Bound = "bound"
    Executed = "executed"
    Exported = "exported"
    Imported = "imported"


@derive(Clone)
pub enum MetadataSource(str):
    """Source family for one metadata attachment."""

    InQL = "inql"
    User = "user"
    Prism = "prism"
    Session = "session"
    Adapter = "adapter"
    FunctionRegistry = "function_registry"
    QualityEngine = "quality_engine"
    PolicyEngine = "policy_engine"
    ExternalCatalog = "external_catalog"
    ImportedArtifact = "imported_artifact"


@derive(Clone)
pub enum MetadataVisibility(str):
    """Visibility policy for one metadata attachment."""

    Public = "public"
    Internal = "internal"
    Sensitive = "sensitive"
    Redacted = "redacted"


@derive(Clone)
pub enum LineageRelationshipKind(str):
    """Relationship kinds in an evidence lineage graph."""

    Value = "value"
    Control = "control"
    Grouping = "grouping"
    Join = "join"
    Sort = "sort"
    Window = "window"
    Policy = "policy"
    Quality = "quality"


@derive(Clone)
pub enum LineageTransformationKind(str):
    """Transformation kinds attached to lineage edges."""

    Identity = "identity"
    Expression = "expression"
    Aggregate = "aggregate"
    Window = "window"
    Generator = "generator"
    Filter = "filter"
    Join = "join"
    Mask = "mask"
    FormatParse = "format_parse"
    NestedAccess = "nested_access"
    SemiStructuredAccess = "semi_structured_access"
    Opaque = "opaque"
    Unknown = "unknown"


@derive(Clone)
pub enum LineageConfidence(str):
    """Confidence classes for lineage extraction."""

    Exact = "exact"
    Conservative = "conservative"
    Unknown = "unknown"


@derive(Clone)
pub enum EvidenceArtifactStatus(str):
    """Whether one evidence artifact family was computed or explicitly unavailable."""

    Computed = "computed"
    Unsupported = "unsupported"


@derive(Clone)
pub enum ExecutionOperationKind(str):
    """Session operation families that can emit execution observations."""

    Execute = "execute"
    Collect = "collect"
    Write = "write"


@derive(Clone)
pub enum ExecutionObservationStatus(str):
    """Terminal status for one observed execution attempt."""

    Success = "success"
    Failure = "failure"
    Cancelled = "cancelled"
    Skipped = "skipped"
    Unsupported = "unsupported"


@derive(Clone)
pub enum ExecutionDiagnosticSeverity(str):
    """Severity class for one structured execution diagnostic."""

    Info = "info"
    Warning = "warning"
    Error = "error"


@derive(Clone)
pub enum AdapterRequirementCapability(str):
    """Adapter capability families that can be required by a semantic plan or evidence policy."""

    ExtensionFunction = "extension_function"
    VariantSemantics = "variant_semantics"
    DecimalSemantics = "decimal_semantics"
    NullSemantics = "null_semantics"
    LineagePreservation = "lineage_preservation"
    AuditEmission = "audit_emission"
    RowFilter = "row_filter"
    ColumnMask = "column_mask"
    AggregateThreshold = "aggregate_threshold"
    RegionBinding = "region_binding"
    OrderedExecution = "ordered_execution"
    SnapshotCapture = "snapshot_capture"
    CanonicalDigest = "canonical_digest"
    CrossRelationReconciliation = "cross_relation_reconciliation"
    IncrementalWatermark = "incremental_watermark"
    VerificationEventStream = "verification_event_stream"
    WaiverRecording = "waiver_recording"
    CryptographicQueryProof = "cryptographic_query_proof"


@derive(Clone)
pub enum AdapterRequirementGuarantee(str):
    """How strongly one semantic target depends on an adapter capability."""

    Required = "required"
    Preferred = "preferred"
    Optional = "optional"


@derive(Clone)
pub enum AdapterCoverageState(str):
    """Adapter coverage state for one explicit requirement."""

    Covered = "covered"
    PartiallyCovered = "partially_covered"
    Uncovered = "uncovered"
    Unknown = "unknown"


@derive(Clone)
pub model SemanticTarget:
    """
    One stable local evidence anchor for a plan, node, relation output, field, or expression.

    `node_id` and `ordinal` are optional because not every semantic target is tied to a Prism node or field slot.
    Target identity must come from `target_id`; positions are only structured context for consumers that can use them.
    """

    pub kind: SemanticTargetKind
    pub target_id: str
    pub plan_id: str
    pub scope_id: str
    pub path: str
    pub name: str
    pub node_id: Option[int]
    pub ordinal: Option[int]


@derive(Clone)
pub model ExecutionDiagnostic:
    """One structured diagnostic attached to an execution observation or coverage record."""

    pub severity: ExecutionDiagnosticSeverity
    pub code: str
    pub message: str
    pub target: Option[SemanticTarget]


@derive(Clone)
pub model AdapterRequirement:
    """One explicit adapter capability requirement anchored to a semantic target."""

    pub requirement_id: str
    pub target: SemanticTarget
    pub capability: AdapterRequirementCapability
    pub guarantee: AdapterRequirementGuarantee
    pub reason: str
    pub evidence_refs: list[str]


@derive(Clone)
pub model AdapterCoverageRecord:
    """One adapter coverage answer for an explicit adapter requirement."""

    pub coverage_id: str
    pub requirement: AdapterRequirement
    pub adapter_name: str
    pub adapter_version: Option[str]
    pub semantic_profile_id: Option[str]
    pub state: AdapterCoverageState
    pub diagnostics: list[ExecutionDiagnostic]
    pub evidence_refs: list[str]


@derive(Clone)
pub model ExecutionObservation:
    """
    Runtime evidence for one session execution attempt.

    Wall-clock timestamps are Unix nanoseconds from `std.datetime.runtime.SystemTime`; duration is monotonic elapsed
    nanoseconds from `std.datetime.runtime.Instant`, so consumers can sort attempts and measure runtime separately.
    """

    pub observation_id: str
    pub attempt_target: SemanticTarget
    pub plan_target: SemanticTarget
    pub context_targets: list[SemanticTarget]
    pub operation: ExecutionOperationKind
    pub status: ExecutionObservationStatus
    pub backend_name: str
    pub adapter_version: Option[str]
    pub requested_semantic_profile_id: Option[str]
    pub observed_semantic_profile_id: Option[str]
    pub started_at_unix_nanoseconds: int
    pub ended_at_unix_nanoseconds: int
    pub duration_nanoseconds: int
    pub row_count: Option[int]
    pub byte_count: Option[int]
    pub trace_ids: list[str]
    pub diagnostics: list[ExecutionDiagnostic]
    pub coverage_records: list[AdapterCoverageRecord]
    pub evidence_refs: list[str]


@derive(Clone)
pub model MetadataPayload:
    """Schema-versioned typed payload stored as a compact string value for this evidence slice."""

    pub schema: str
    pub value: str


@derive(Clone)
pub model MetadataAttachment:
    """Typed metadata attachment anchored to one semantic target."""

    pub target: SemanticTarget
    pub namespace: str
    pub key: str
    pub payload: MetadataPayload
    pub lifecycle: MetadataLifecycle
    pub source: MetadataSource
    pub visibility: MetadataVisibility
    pub evidence_refs: list[str]


@derive(Clone)
pub model LineageEdge:
    """One lineage edge between semantic targets."""

    pub source: SemanticTarget
    pub destination: SemanticTarget
    pub relationship: LineageRelationshipKind
    pub transformation: LineageTransformationKind
    pub expression_ref: str
    pub confidence: LineageConfidence
    pub evidence_refs: list[str]


@derive(Clone)
pub model LineageGraph:
    """Lineage graph returned by local plan inspection and future evidence collectors."""

    pub plan_id: str
    pub rule_version: str
    pub edges: list[LineageEdge]


@derive(Clone)
pub model InspectionArtifact:
    """One deterministic local artifact-family summary."""

    pub family: str
    pub schema_version: str
    pub status: EvidenceArtifactStatus
    pub record_count: int


@derive(Clone)
pub model UnsupportedEvidence:
    """Explicit marker for evidence families that an inspection path cannot compute."""

    pub family: str
    pub reason: str
