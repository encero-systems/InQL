"""
Relation and plan introspection helpers for the Substrait surface.

This module owns best-effort output-column inference, public relation/read/set naming, subtree traversal, and the
inspection utilities used by tests, dataset carriers, and conformance validation.
"""

from rust::std::boxed import Box
from rust::std::primitive import i32 as RustI32
from rust::substrait::proto import (
    AggregateRel,
    ConsistentPartitionWindowRel,
    Expression,
    FunctionArgument,
    FunctionOption,
    Plan,
    ReadRel,
    Rel,
    RelCommon,
)
from rust::substrait::proto::aggregate_rel import Measure
from rust::substrait::proto::aggregate_function import AggregationInvocation
from rust::substrait::proto::expression import RexType
from rust::substrait::proto::expression::literal import LiteralType
from rust::substrait::proto::extensions::simple_extension_declaration import MappingType
from rust::substrait::proto::function_argument import ArgType
from rust::substrait::proto::plan_rel import RelType as PlanRelType
from rust::substrait::proto::read_rel import NamedTable as ReadNamedTable, ReadType
from rust::substrait::proto::rel import RelType
from rust::substrait::proto::rel_common import Direct, EmitKind
from rust::substrait::proto::set_rel import SetOp
from rust::substrait::proto::sort_field import SortDirection, SortKind
from aggregate_builders import AggregateMeasure, aggregate_measure_output_name
from sketch_types import SKETCH_FAMILY_OPTION, SKETCH_FORMAT_OPTION, SKETCH_PRECISION_OPTION, SKETCH_VALUE_DOMAIN_OPTION
from substrait.expr_lowering import field_index_from_expression, project_output_columns_with_emit, rust_u32_to_int
from substrait.extensions import aggregate_function_name_from_anchor, window_function_name_from_anchor
from substrait.function_extensions import (
    EXPLODE_EXTENSION_URI,
    EXPLODE_OUTER_EXTENSION_URI,
    FLATTEN_EXTENSION_URI,
    INLINE_EXTENSION_URI,
    INLINE_OUTER_EXTENSION_URI,
    POSEXPLODE_EXTENSION_URI,
    POSEXPLODE_OUTER_EXTENSION_URI,
    STACK_EXTENSION_URI,
)
from substrait.generator_payload import decode_generator_extension_payload
from substrait.schema_registry import named_table_columns, unknown_named_struct
from substrait.traversal import relation_children
from substrait.window_metadata import WINDOW_OUTPUT_NAME_OPTION


def _malformed_root_rel() -> Rel:
    """Build one placeholder read relation when a plan root is structurally missing."""
    read = ReadRel(
        common=Some(RelCommon(hint=None, advanced_extension=None, emit_kind=Some(EmitKind.Direct(Direct())))),
        base_schema=Some(unknown_named_struct()),
        filter=None,
        best_effort_filter=None,
        projection=None,
        advanced_extension=None,
        read_type=Some(ReadType.NamedTable(ReadNamedTable(names=["__malformed_plan__"], advanced_extension=None))),
    )
    return Rel(rel_type=Some(RelType.Read(Box.new(read))))


def _set_op_value(value: SetOp) -> RustI32:
    """Convert one Substrait `SetOp` enum variant into its stored Rust `i32` discriminant."""
    return value.into()


def _aggregation_invocation_value(value: AggregationInvocation) -> RustI32:
    """Convert one Substrait aggregation invocation into its stored Rust `i32` discriminant."""
    return value.into()


def _measure_has_filter(measure: Measure) -> bool:
    """Return whether one aggregate measure carries an aggregate-local filter."""
    match measure.filter:
        Some(_) => return true
        None => return false


def _measure_output_name(measure: AggregateMeasure) -> str:
    """Return the projected output column name for one aggregate measure."""
    return aggregate_measure_output_name(measure)


pub def aggregate_measure_output_names(measures: list[AggregateMeasure]) -> list[str]:
    """Return projected output column names for one aggregate-measure list."""
    return [_measure_output_name(measure) for measure in measures]


pub def aggregate_group_columns(rel: Rel) -> list[str]:
    """Return grouping output column names when `rel` is an aggregate root, otherwise empty."""
    match rel.rel_type:
        Some(RelType.Aggregate(aggregate_rel)) =>
            input_columns = _aggregate_input_columns(aggregate_rel.as_ref().clone())
            return _grouping_output_columns(input_columns, aggregate_rel.grouping_expressions)
        _ => return []


def _aggregate_input_columns(aggregate_rel: AggregateRel) -> list[str]:
    """Resolve the current input-column names feeding one aggregate relation."""
    match aggregate_rel.input:
        Some(child) => return relation_output_columns(child.as_ref().clone())
        None => return []


def _grouping_output_columns(input_columns: list[str], grouping_expressions: list[Expression]) -> list[str]:
    """Resolve grouping output names from field-reference expressions against one input-column list."""
    mut columns: list[str] = []
    for idx, expr in enumerate(grouping_expressions):
        field_index = field_index_from_expression(expr)
        if field_index >= 0 and field_index < len(input_columns):
            columns.append(input_columns[field_index])
        else:
            columns.append(f"group_{idx}")
    return columns


def _aggregate_measure_output_name(input_columns: list[str], measure: Measure) -> str:
    """Resolve one aggregate output name from the lowered Substrait aggregate measure payload."""
    measure_has_filter = _measure_has_filter(measure.clone())
    if let Some(agg_fn) = measure.measure:
        function_name = aggregate_function_name_from_anchor(agg_fn.function_reference)
        is_distinct = agg_fn.invocation == _aggregation_invocation_value(AggregationInvocation.Distinct)
        is_approx_percentile = function_name == "approx_percentile"
        mut output_name = function_name
        if len(agg_fn.arguments) > 0:
            if is_distinct:
                output_name = output_name + "_distinct"
            if let Some(ArgType.Value(expr)) = agg_fn.arguments[0].arg_type:
                field_index = field_index_from_expression(expr)
                if field_index >= 0 and field_index < len(input_columns):
                    output_name = output_name + "_" + input_columns[field_index]
        if is_approx_percentile:
            output_name = output_name + _approx_percentile_measure_suffix(agg_fn.arguments)
        output_name = output_name + _sketch_measure_suffix(agg_fn.options)
        if measure_has_filter:
            output_name = output_name + "_filtered"
        if len(agg_fn.sorts) > 0:
            output_name = output_name + "_ordered"
        return output_name
    return ""


def _approx_percentile_measure_suffix(arguments: list[FunctionArgument]) -> str:
    """Return the percentile/accuracy suffix for an approximate percentile Substrait measure."""
    if len(arguments) < 3:
        return ""
    percentile = _measure_literal_argument_name(arguments[1])
    accuracy = _measure_literal_argument_name(arguments[2])
    return f"_p{percentile}_a{accuracy}"


def _sketch_measure_suffix(options: list[FunctionOption]) -> str:
    """Return the non-default sketch-compatibility suffix from Substrait function options."""
    family = _function_option_value(options, SKETCH_FAMILY_OPTION)
    if family == "":
        return ""
    mut suffix = ""
    value_domain = _function_option_value(options, SKETCH_VALUE_DOMAIN_OPTION)
    precision = _function_option_value(options, SKETCH_PRECISION_OPTION)
    format = _function_option_value(options, SKETCH_FORMAT_OPTION)
    if value_domain != "" and value_domain != "string_identifier":
        suffix = suffix + "_" + value_domain
    if precision != "" and precision != "14":
        suffix = suffix + "_p" + precision
    if format != "" and format != "inql_hll_v1":
        suffix = suffix + "_" + format
    return suffix


def _measure_literal_argument_name(argument: FunctionArgument) -> str:
    """Return one output-name-safe literal label for aggregate parameter arguments."""
    match argument.arg_type:
        Some(ArgType.Value(expr)) => return _literal_expression_output_name(expr)
        _ => return "expr"


def _literal_expression_output_name(expr: Expression) -> str:
    """Return a stable label for literal expressions used as aggregate parameters."""
    match expr.rex_type:
        Some(RexType.Literal(literal)) =>
            match literal.literal_type:
                Some(LiteralType.I64(value)) => return f"{value}"
                Some(LiteralType.Fp64(value)) => return f"{value}".replace(".", "_")
                _ => return "expr"
        _ => return "expr"


def _aggregate_measure_output_columns(input_columns: list[str], measures: list[Measure]) -> list[str]:
    """Resolve aggregate output names in declaration order for one aggregate relation."""
    mut columns: list[str] = []
    for measure in measures:
        output_name = _aggregate_measure_output_name(input_columns, measure)
        if len(output_name) > 0:
            columns.append(output_name)
    return columns


def _aggregate_output_columns(aggregate_rel: AggregateRel) -> list[str]:
    """Return grouped-column names followed by aggregate output names for one aggregate relation."""
    input_columns = _aggregate_input_columns(aggregate_rel)
    mut columns = _grouping_output_columns(input_columns, aggregate_rel.grouping_expressions)
    columns.extend(_aggregate_measure_output_columns(input_columns, aggregate_rel.measures))
    return columns


def _window_input_columns(window_rel: ConsistentPartitionWindowRel) -> list[str]:
    """Resolve the current input-column names feeding one window relation."""
    match window_rel.input:
        Some(child) => return relation_output_columns(child.as_ref().clone())
        None => return []


def _window_output_columns(window_rel: ConsistentPartitionWindowRel) -> list[str]:
    """Return input-column names followed by lowered window output aliases."""
    mut columns = _window_input_columns(window_rel.clone())
    for idx, window_function in enumerate(window_rel.window_functions):
        output_name = _window_function_output_name(window_function.options)
        if len(output_name) > 0:
            columns.append(output_name)
        else:
            function_name = window_function_name_from_anchor(window_function.function_reference)
            if len(function_name) > 0:
                columns.append(function_name)
            else:
                columns.append(f"window_{idx}")
    return columns


def _window_function_output_name(options: list[FunctionOption]) -> str:
    """Return the InQL output alias encoded on one lowered window function."""
    for option in options:
        if option.name == WINDOW_OUTPUT_NAME_OPTION and len(option.preference) > 0:
            return option.preference[0]
    return ""


def _window_function_names_for_rel(window_rel: ConsistentPartitionWindowRel) -> list[str]:
    """Return lowered window-function names in declaration order."""
    return [window_function_name_from_anchor(fun.function_reference) for fun in window_rel.window_functions]


def _relation_output_columns(rel: Rel) -> list[str]:
    """Return the current best-effort output column names for one relation subtree."""
    match rel.rel_type.clone():
        Some(RelType.Read(read_rel)) =>
            match read_rel.read_type:
                Some(ReadType.NamedTable(named_table)) =>
                    if len(named_table.names) == 0:
                        return []
                    return named_table_columns(named_table.names[0])
                _ => return []
        Some(RelType.Filter(filter_rel)) =>
            match filter_rel.input:
                Some(child) => return _relation_output_columns(child.as_ref().clone())
                None => return []
        Some(RelType.Project(project_rel)) =>
            mut input_columns: list[str] = []
            match project_rel.input.clone():
                Some(child) =>
                    input_columns = _relation_output_columns(child.as_ref().clone())
                None =>
                    input_columns = []

            return project_output_columns_with_emit(input_columns, project_rel.as_ref().clone())
        Some(RelType.Sort(sort_rel)) =>
            match sort_rel.input:
                Some(child) => return _relation_output_columns(child.as_ref().clone())
                None => return []
        Some(RelType.Fetch(fetch_rel)) =>
            match fetch_rel.input:
                Some(child) => return _relation_output_columns(child.as_ref().clone())
                None => return []
        Some(RelType.ExtensionSingle(extension_rel)) =>
            match extension_rel.input:
                Some(child) =>
                    input_columns = _relation_output_columns(child.as_ref().clone())
                    match extension_rel.detail:
                        Some(detail) =>
                            return _extension_single_output_columns(input_columns, detail.type_url, detail.value)
                        None => return input_columns
                None => return []
        Some(RelType.Join(join_rel)) =>
            mut names: list[str] = []
            if let Some(left) = join_rel.left:
                names.extend(_relation_output_columns(left.as_ref().clone()))
            if let Some(right) = join_rel.right:
                names.extend(_relation_output_columns(right.as_ref().clone()))
            return names
        Some(RelType.Cross(cross_rel)) =>
            mut names: list[str] = []
            if let Some(left) = cross_rel.left:
                names.extend(_relation_output_columns(left.as_ref().clone()))
            if let Some(right) = cross_rel.right:
                names.extend(_relation_output_columns(right.as_ref().clone()))
            return names
        Some(RelType.Set(set_rel)) =>
            if len(set_rel.inputs) == 0:
                return []
            return _relation_output_columns(set_rel.inputs[0])
        Some(RelType.Aggregate(aggregate_rel)) => return _aggregate_output_columns(aggregate_rel.as_ref().clone())
        Some(RelType.Window(window_rel)) => return _window_output_columns(window_rel.as_ref().clone())
        _ => return []


pub def relation_output_columns(rel: Rel) -> list[str]:
    """Return best-effort logical output columns for one relation subtree."""
    return _relation_output_columns(rel)


pub def window_function_names(rel: Rel) -> list[str]:
    """Return lowered window-function names when `rel` is a window root."""
    match rel.rel_type:
        Some(RelType.Window(window_rel)) => return _window_function_names_for_rel(window_rel.as_ref().clone())
        _ => return []


pub def window_partition_count(rel: Rel) -> int:
    """Return the number of partition expressions when `rel` is a window root."""
    match rel.rel_type:
        Some(RelType.Window(window_rel)) => return len(window_rel.partition_expressions)
        _ => return 0


pub def window_sort_count(rel: Rel) -> int:
    """Return the number of sort expressions when `rel` is a window root."""
    match rel.rel_type:
        Some(RelType.Window(window_rel)) => return len(window_rel.sorts)
        _ => return 0


def _extension_single_output_columns(input_columns: list[str], extension_uri: str, payload: bytes) -> list[str]:
    """Return best-effort output columns for known extension-single relation encodings."""
    mut columns: list[str] = []
    columns.extend(input_columns)
    # Prefer the RFC 021 payload when present. Some low-level extension-boundary tests still create URI-only nodes, so
    # retain the URI fallback below for those structurally valid but less informative relations.
    if let Ok(decoded) = decode_generator_extension_payload(payload):
        columns.extend(decoded.output_columns)
        return columns
    if extension_uri == EXPLODE_EXTENSION_URI or extension_uri == EXPLODE_OUTER_EXTENSION_URI:
        columns.append("value")
    elif extension_uri == POSEXPLODE_EXTENSION_URI or extension_uri == POSEXPLODE_OUTER_EXTENSION_URI:
        columns.append("position")
        columns.append("value")
    elif extension_uri == FLATTEN_EXTENSION_URI:
        columns.append("value")
    elif extension_uri == INLINE_EXTENSION_URI or extension_uri == INLINE_OUTER_EXTENSION_URI or extension_uri == STACK_EXTENSION_URI:
        columns.append("value")
    return columns


pub def aggregate_measure_function_names(rel: Rel) -> list[str]:
    """Return aggregate function names used by a top-level AggregateRel, otherwise empty."""
    match rel.rel_type:
        Some(RelType.Aggregate(aggregate_rel)) =>
            mut names: list[str] = []
            for measure in aggregate_rel.measures:
                if let Some(agg_fn) = measure.measure:
                    names.append(aggregate_function_name_from_anchor(agg_fn.function_reference))
            return names
        _ => return []


def _aggregation_invocation_name(value: RustI32) -> str:
    """Return the stable aggregate invocation name for one Substrait enum value."""
    if value == _aggregation_invocation_value(AggregationInvocation.Distinct):
        return "Distinct"
    if value == _aggregation_invocation_value(AggregationInvocation.All):
        return "All"
    return "Unspecified"


pub def aggregate_measure_invocation_names(rel: Rel) -> list[str]:
    """Return aggregate invocation names used by a top-level AggregateRel, otherwise empty."""
    match rel.rel_type:
        Some(RelType.Aggregate(aggregate_rel)) =>
            mut names: list[str] = []
            for measure in aggregate_rel.measures:
                if let Some(agg_fn) = measure.measure:
                    names.append(_aggregation_invocation_name(agg_fn.invocation))
            return names
        _ => return []


pub def aggregate_measure_filter_flags(rel: Rel) -> list[bool]:
    """Return whether each top-level aggregate measure carries an aggregate-local filter."""
    match rel.rel_type:
        Some(RelType.Aggregate(aggregate_rel)) =>
            return [_measure_has_filter(measure) for measure in aggregate_rel.measures]
        _ => return []


pub def aggregate_measure_sort_counts(rel: Rel) -> list[int]:
    """Return sort-field counts for each top-level aggregate measure."""
    match rel.rel_type:
        Some(RelType.Aggregate(aggregate_rel)) =>
            mut counts: list[int] = []
            for measure in aggregate_rel.measures:
                if let Some(agg_fn) = measure.measure:
                    counts.append(len(agg_fn.sorts))
            return counts
        _ => return []


pub def aggregate_measure_option_value(rel: Rel, measure_index: int, option_name: str) -> str:
    """Return one aggregate function option value from a top-level AggregateRel, or empty when absent."""
    match rel.rel_type:
        Some(RelType.Aggregate(aggregate_rel)) =>
            mut current_index = 0
            for measure in aggregate_rel.measures:
                if current_index == measure_index:
                    if let Some(agg_fn) = measure.measure:
                        return _function_option_value(agg_fn.options, option_name)
                    return ""
                current_index += 1
            return ""
        _ => return ""


def _function_option_value(options: list[FunctionOption], option_name: str) -> str:
    """Return one Substrait function option preference value, or empty when absent."""
    for option in options:
        if option.name == option_name and len(option.preference) > 0:
            return option.preference[0]
    return ""


pub def root_rel(plan: Plan) -> Rel:
    """Return the logical root relation from a plan."""
    if len(plan.relations) == 0:
        return _malformed_root_rel()
    relation = plan.relations[0]
    match relation.rel_type:
        Some(rel_type) =>
            match rel_type:
                PlanRelType.Root(root) =>
                    match root.input:
                        Some(rel) => return rel
                        None => return _malformed_root_rel()
                PlanRelType.Rel(rel) => return rel
                _ => return _malformed_root_rel()
        _ => return _malformed_root_rel()


pub def root_names(plan: Plan) -> list[str]:
    """Return declared root output names from one plan, or empty when absent."""
    if len(plan.relations) == 0:
        return []
    relation = plan.relations[0]
    match relation.rel_type:
        Some(rel_type) =>
            match rel_type:
                PlanRelType.Root(root) => return root.names
                _ => return []
        _ => return []


pub def relation_kind_name(rel: Rel) -> str:
    """Return the public Substrait relation-kind label for one `Rel` node."""
    match rel.rel_type:
        Some(RelType.Read(_)) => return "ReadRel"
        Some(RelType.Filter(_)) => return "FilterRel"
        Some(RelType.Project(_)) => return "ProjectRel"
        Some(RelType.Join(_)) => return "JoinRel"
        Some(RelType.Cross(_)) => return "CrossRel"
        Some(RelType.Aggregate(_)) => return "AggregateRel"
        Some(RelType.Window(_)) => return "ConsistentPartitionWindowRel"
        Some(RelType.Sort(_)) => return "SortRel"
        Some(RelType.Fetch(_)) => return "FetchRel"
        Some(RelType.Set(_)) => return "SetRel"
        Some(RelType.Reference(_)) => return "ReferenceRel"
        Some(RelType.ExtensionSingle(_)) => return "ExtensionSingleRel"
        Some(RelType.ExtensionLeaf(_)) => return "ExtensionLeafRel"
        Some(RelType.ExtensionMulti(_)) => return "ExtensionMultiRel"
        _ => return "UnknownRel"


pub def read_kind_name(rel: Rel) -> str:
    """Return the read-root kind label for one relation."""
    match rel.rel_type:
        Some(RelType.Read(read)) =>
            match read.read_type:
                Some(ReadType.NamedTable(_)) => return "NamedTable"
                Some(ReadType.LocalFiles(_)) => return "LocalFiles"
                Some(ReadType.VirtualTable(_)) => return "VirtualTable"
                _ => return "ReadRel"
        _ => return "Unknown"


pub def read_named_table_name(rel: Rel) -> str:
    """Return the first named-table identifier for ReadRel(NamedTable), or empty when not applicable."""
    match rel.rel_type:
        Some(RelType.Read(read_rel)) =>
            match read_rel.read_type:
                Some(ReadType.NamedTable(named_table)) =>
                    if len(named_table.names) == 0:
                        return ""
                    return named_table.names[0]
                _ => return ""
        _ => return ""


pub def source_named_table_name(rel: Rel) -> str:
    """Return the first reachable named-table identifier in one relation subtree, or empty when absent."""
    direct_name = read_named_table_name(rel.clone())
    if len(direct_name) > 0:
        return direct_name
    for child in relation_children(rel):
        child_name = source_named_table_name(child)
        if len(child_name) > 0:
            return child_name
    return ""


pub def set_operation_name(rel: Rel) -> str:
    """Return the public Substrait set-operation label for one `SetRel` node."""
    match rel.rel_type:
        Some(RelType.Set(set_rel)) =>
            if set_rel.op == _set_op_value(SetOp.MinusPrimary):
                return "MinusPrimary"
            elif set_rel.op == _set_op_value(SetOp.IntersectionPrimary):
                return "IntersectPrimary"
            elif set_rel.op == _set_op_value(SetOp.IntersectionMultiset):
                return "IntersectMultiset"
            elif set_rel.op == _set_op_value(SetOp.MinusMultiset):
                return "MinusMultiset"
            elif set_rel.op == _set_op_value(SetOp.UnionDistinct):
                return "UnionDistinct"
            elif set_rel.op == _set_op_value(SetOp.UnionAll):
                return "UnionAll"
            return "UnknownSetOp"
        _ => return "NotSet"


def _sort_direction_name(value: RustI32) -> str:
    """Return a stable Substrait sort-direction name for test and diagnostics."""
    asc_nulls_first: RustI32 = SortDirection.AscNullsFirst.into()
    asc_nulls_last: RustI32 = SortDirection.AscNullsLast.into()
    desc_nulls_first: RustI32 = SortDirection.DescNullsFirst.into()
    desc_nulls_last: RustI32 = SortDirection.DescNullsLast.into()
    if value == asc_nulls_first:
        return "AscNullsFirst"
    if value == asc_nulls_last:
        return "AscNullsLast"
    if value == desc_nulls_first:
        return "DescNullsFirst"
    if value == desc_nulls_last:
        return "DescNullsLast"
    return "Unknown"


pub def sort_field_count(rel: Rel) -> int:
    """Return the number of sort fields on one SortRel, or zero for non-sort relations."""
    match rel.rel_type:
        Some(RelType.Sort(sort_rel)) => return len(sort_rel.sorts)
        _ => return 0


pub def sort_field_direction_name(rel: Rel, index: int) -> str:
    """Return the direction/null-placement name for one SortRel field."""
    match rel.rel_type:
        Some(RelType.Sort(sort_rel)) =>
            if index < 0 or index >= len(sort_rel.sorts):
                return "Unknown"
            match sort_rel.sorts[index].sort_kind:
                Some(SortKind.Direction(direction)) => return _sort_direction_name(direction)
                _ => return "Unknown"
        _ => return "Unknown"


pub def sort_field_expr_index(rel: Rel, index: int) -> int:
    """Return the direct field-reference index used by one SortRel field, or `-1` when not a field reference."""
    match rel.rel_type:
        Some(RelType.Sort(sort_rel)) =>
            if index < 0 or index >= len(sort_rel.sorts):
                return -1
            match sort_rel.sorts[index].expr:
                Some(expr) => return field_index_from_expression(expr)
                None => return -1
        _ => return -1


pub def reference_subtree_ordinal(rel: Rel) -> RustI32:
    """Return the subtree ordinal for one `ReferenceRel`, or `-1` when the input is not a reference."""
    match rel.rel_type:
        Some(RelType.Reference(reference)) => return reference.subtree_ordinal
        _ => return -1


pub def rel_contains_kind(rel: Rel, expected_kind: str) -> bool:
    """Return whether one relation subtree contains the requested public kind label."""
    if relation_kind_name(rel) == expected_kind:
        return true
    for child in relation_children(rel):
        if rel_contains_kind(child, expected_kind):
            return true
    return false


pub def plan_contains_relation_kind(plan: Plan, expected_kind: str) -> bool:
    """Return whether the plan contains a relation with the requested public kind label."""
    return rel_contains_kind(root_rel(plan), expected_kind)


pub def plan_has_extension_urn(plan: Plan, extension_uri: str) -> bool:
    """Return whether one emitted plan already carries the requested extension URI."""
    for urn in plan.extension_urns:
        if urn.urn == extension_uri:
            return true
    return false


pub def plan_extension_urn_count(plan: Plan) -> int:
    """Return the number of extension URN declarations carried by one plan."""
    return len(plan.extension_urns)


pub def plan_extension_urn_anchor_at(plan: Plan, index: int) -> int:
    """Return one extension URN anchor as an Incan integer for tests and diagnostics."""
    if index < 0 or index >= len(plan.extension_urns):
        return -1
    return rust_u32_to_int(plan.extension_urns[index].extension_urn_anchor)


pub def plan_extension_function_names(plan: Plan) -> list[str]:
    """Return extension-function declaration names carried by one plan."""
    mut names: list[str] = []
    for declaration in plan.extensions:
        match declaration.mapping_type:
            Some(MappingType.ExtensionFunction(function)) => names.append(function.name)
            _ => pass
    return names
