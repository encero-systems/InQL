    mergeable=true,
    result_interpretation="typed HyperLogLog sketch state",
)
pub const HLL_ESTIMATE_APPROXIMATION_POLICY: FunctionApproximationPolicy = FunctionApproximationPolicy(
    is_approximate=true,
