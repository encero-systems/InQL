@derive(Clone, Eq)
pub model SubstraitMapping:
    """Portable interchange mapping metadata for one registered function."""

    pub kind: SubstraitMappingKind
    pub uri: str
    pub function_name: str
    pub anchor: u32
    pub rewrite: str
    pub detail: str


@derive(Clone)
pub model FunctionSpec:
    """Machine-readable function facts supplied to the registry decorator."""

    pub canonical_name: Option[str]
    pub namespace: str
    pub policy_category: FunctionPolicyCategory
    pub function_class: FunctionClass
    pub aliases: list[str]
    pub alias_policy: FunctionAliasPolicy
    pub lifecycle: FunctionLifecycle
    pub determinism: FunctionDeterminism
    pub null_behavior: FunctionNullBehavior
    pub error_behavior: FunctionErrorBehavior
    pub aggregate_modifiers: AggregateModifierPolicy
    pub approximation: FunctionApproximationPolicy
    pub sketch: FunctionSketchPolicy
    pub variant: FunctionVariantPolicy
    pub substrait: SubstraitMapping


@derive(Clone)
pub model FunctionRegistryEntry:
    """Runtime projection for one registered InQL function."""

    pub function_ref: str
    pub namespace: str
    pub canonical_name: str
    pub policy_category: FunctionPolicyCategory
    pub function_class: FunctionClass
    pub aliases: list[str]
    pub alias_policy: FunctionAliasPolicy
    pub lifecycle: FunctionLifecycle
    pub determinism: FunctionDeterminism
    pub null_behavior: FunctionNullBehavior
    pub error_behavior: FunctionErrorBehavior
    pub aggregate_modifiers: AggregateModifierPolicy
    pub approximation: FunctionApproximationPolicy
    pub sketch: FunctionSketchPolicy
    pub variant: FunctionVariantPolicy
    pub substrait: SubstraitMapping


@derive(Clone)
pub model RejectedFunctionPolicy:
    """Documented rejection metadata for a likely compatibility request that is not a function entry."""

    pub requested_name: str
    pub policy_category: FunctionPolicyCategory
    pub reason: str
    pub alternative: str


@derive(Clone)
pub class FunctionRegistry:
    """Mutable package-owned function registry populated by declaration-site decorators."""

    pub entries: list[FunctionRegistryEntry]

    @staticmethod
    def new() -> Self:
        """Return an empty function registry."""
        return FunctionRegistry(entries=[])

    def _add_entry(mut self, canonical_name: str, spec: FunctionSpec) -> None:
        """Record one registry entry or fail fast on invalid duplicate metadata."""
        assert _valid_canonical_name(canonical_name), (f"function canonical name must be one non-empty identifier segment, found `{canonical_name}`")
        assert _valid_namespace(spec.namespace), f"function namespace must be non-empty, found `{spec.namespace}`"
        mut seen_aliases: list[str] = []
        for alias in spec.aliases:
            assert _valid_canonical_name(alias), f"function alias must be one non-empty identifier segment, found `{alias}`"
            assert alias != canonical_name, f"function alias `{alias}` duplicates canonical name `{canonical_name}`"
            assert not _contains_string(seen_aliases, alias), f"duplicate function alias `{alias}`"
            seen_aliases.append(alias)

        function_ref = namespaced_function_ref(spec.namespace, canonical_name)
        for entry in self.entries:
            if entry.function_ref == function_ref:
                assert _entry_matches_spec(entry, canonical_name, spec), f"conflicting duplicate function reference `{function_ref}`"
                return
            if entry.namespace == spec.namespace:
                assert entry.canonical_name != canonical_name, f"duplicate canonical function name `{canonical_name}` in namespace `{spec.namespace}`"
                for alias in spec.aliases:
                    assert entry.canonical_name != alias, f"function alias `{alias}` conflicts with canonical function name in namespace `{spec.namespace}`"
                for existing_alias in entry.aliases:
                    assert existing_alias != canonical_name, f"canonical function name `{canonical_name}` conflicts with alias in namespace `{spec.namespace}`"
                    for alias in spec.aliases:
                        assert existing_alias != alias, f"duplicate function alias `{alias}` in namespace `{spec.namespace}`"

        self.entries.append(
            FunctionRegistryEntry(
                function_ref=function_ref,
                namespace=spec.namespace,
                canonical_name=canonical_name,
                policy_category=spec.policy_category,
                function_class=spec.function_class,
                aliases=spec.aliases,
                alias_policy=spec.alias_policy,
                lifecycle=spec.lifecycle,
                determinism=spec.determinism,
                null_behavior=spec.null_behavior,
                error_behavior=spec.error_behavior,
                aggregate_modifiers=spec.aggregate_modifiers,
                approximation=spec.approximation,
                sketch=spec.sketch,
                variant=spec.variant,
                substrait=spec.substrait,
            ),
        )
        return

    def _add_alias(
        mut self,
        namespace: str,
        canonical_name: str,
        alias_name: str,
        alias_policy: FunctionAliasPolicy,
    ) -> None:
        """Attach one real public alias name to an existing canonical registry entry."""
        assert _valid_namespace(namespace), f"function namespace must be non-empty, found `{namespace}`"
        assert _valid_canonical_name(canonical_name), f"function canonical name must be one non-empty identifier segment, found `{canonical_name}`"
        assert _valid_canonical_name(alias_name), f"function alias must be one non-empty identifier segment, found `{alias_name}`"
        assert alias_name != canonical_name, f"function alias `{alias_name}` duplicates canonical name `{canonical_name}`"
        for entry in self.entries:
            if entry.namespace == namespace and entry.canonical_name == alias_name:
                assert false, f"function alias `{alias_name}` conflicts with canonical function name in namespace `{namespace}`"
            if entry.namespace == namespace and _contains_string(entry.aliases, alias_name):
                if entry.canonical_name == canonical_name and entry.alias_policy == alias_policy:
                    return
                assert false, f"duplicate function alias `{alias_name}` in namespace `{namespace}`"
        for idx in range(len(self.entries)):
            entry = self.entries[idx]
            if entry.namespace == namespace and entry.canonical_name == canonical_name:
                mut aliases = entry.aliases
                aliases.append(alias_name)
                self.entries[idx] = FunctionRegistryEntry(
                    function_ref=entry.function_ref,
                    namespace=entry.namespace,
                    canonical_name=entry.canonical_name,
                    policy_category=entry.policy_category,
                    function_class=entry.function_class,
                    aliases=aliases,
                    alias_policy=alias_policy,
                    lifecycle=entry.lifecycle,
                    determinism=entry.determinism,
                    null_behavior=entry.null_behavior,
                    error_behavior=entry.error_behavior,
                    aggregate_modifiers=entry.aggregate_modifiers,
                    approximation=entry.approximation,
                    sketch=entry.sketch,
                    variant=entry.variant,
                    substrait=entry.substrait,
                )
                return
        assert false, f"missing canonical function `{canonical_name}` for alias `{alias_name}` in namespace `{namespace}`"

    def entry(self, function_ref: str) -> Option[FunctionRegistryEntry]:
        """Return the registry entry for one stable function reference when it is known."""
        for entry in self.entries:
            if entry.function_ref == function_ref:
                return Some(entry)
        return None

    def entry_by_name(self, name: str) -> Option[FunctionRegistryEntry]:
        """Return the core registry entry for one canonical or alias public function name when it is known."""
        return self.entry_by_namespace_and_name(CORE_FUNCTION_NAMESPACE, name)

    def entry_by_namespace_and_name(self, namespace: str, name: str) -> Option[FunctionRegistryEntry]:
        """Return the registry entry for one namespace-qualified canonical or alias function name."""
        for entry in self.entries:
            if entry.namespace == namespace and entry.canonical_name == name:
                return Some(entry)
        for entry in self.entries:
            if entry.namespace == namespace and _contains_string(entry.aliases, name):
                return Some(entry)
        return None

    def function_refs(self) -> list[str]:
        """Return registered function references in stable registry order."""
        return [entry.function_ref for entry in self.entries]

    def canonical_names(self) -> list[str]:
        """Return registered canonical function names in stable registry order."""
        return [entry.canonical_name for entry in self.entries]

    def entry_count(self) -> int:
        """Return the number of registered function entries."""
        return len(self.entries)

    def substrait_mapped_function_refs(self) -> list[str]:
        """Return function references with a concrete Substrait extension mapping."""
        return [entry.function_ref for entry in self.entries if entry.substrait.kind == SubstraitMappingKind.ExtensionFunction]


def _contains_string(values: list[str], target: str) -> bool:
    """Return whether one string list contains the target value."""
    for value in values:
        if value == target:
            return true
    return false


def _entry_matches_spec(entry: FunctionRegistryEntry, canonical_name: str, spec: FunctionSpec) -> bool:
    """Return whether an existing registry entry is an idempotent repeat of one declaration-side spec."""
    return (
        entry.function_ref == namespaced_function_ref(spec.namespace, canonical_name)
        and entry.namespace == spec.namespace
        and entry.canonical_name == canonical_name
        and entry.policy_category == spec.policy_category
        and entry.function_class == spec.function_class
        and entry.aliases == spec.aliases
        and entry.alias_policy == spec.alias_policy
        and entry.lifecycle == spec.lifecycle
        and entry.determinism == spec.determinism
        and entry.null_behavior == spec.null_behavior
        and entry.error_behavior == spec.error_behavior
        and entry.aggregate_modifiers == spec.aggregate_modifiers
        and entry.approximation == spec.approximation
        and entry.sketch == spec.sketch
        and entry.variant == spec.variant
        and entry.substrait == spec.substrait
    )


pub def function_ref_for(canonical_name: str) -> str:
    """Return the durable registry reference for one canonical InQL function name."""
    return namespaced_function_ref(CORE_FUNCTION_NAMESPACE, canonical_name)


pub def namespaced_function_ref(namespace: str, canonical_name: str) -> str:
    """Return the durable registry reference for a function in one explicit namespace."""
    assert _valid_namespace(namespace), f"function namespace must be non-empty, found `{namespace}`"
    assert _valid_canonical_name(canonical_name), (f"function canonical name must be one non-empty identifier segment, found `{canonical_name}`")
    return f"{namespace}.{canonical_name}"


pub def extension_mapping(function_name: str, anchor: u32) -> SubstraitMapping:
    """Build one registered Substrait extension-function mapping."""
    return SubstraitMapping(
        kind=SubstraitMappingKind.ExtensionFunction,
        uri=FUNCTION_EXTENSION_URI,
        function_name=function_name,
        anchor=anchor,
        rewrite="",
        detail="",
    )


pub def relation_extension_mapping(function_name: str, uri: str) -> SubstraitMapping:
    """Build one registered Substrait relation-extension mapping."""
    return SubstraitMapping(
        kind=SubstraitMappingKind.RelationExtension,
        uri=uri,
        function_name=function_name,
        anchor=0,
        rewrite="",
        detail="extension_single",
    )


pub def core_mapping(function_name: str) -> SubstraitMapping:
    """Build one mapping for a built-in Substrait Rex shape rather than an extension function declaration."""
    return SubstraitMapping(
        kind=SubstraitMappingKind.CoreFunction,
        uri="",
        function_name=function_name,
        anchor=0,
        rewrite="",
        detail="",
    )


pub def rewrite_mapping(rewrite: str) -> SubstraitMapping:
    """Build one deterministic Substrait rewrite mapping description."""
    return SubstraitMapping(
        kind=SubstraitMappingKind.Rewrite,
        uri="",
        function_name="",
        anchor=0,
        rewrite=rewrite,
        detail="",
    )


pub def structural_mapping(context: str) -> SubstraitMapping:
    """Build one mapping for helpers lowered by a relation-specific Substrait context."""
    return SubstraitMapping(
        kind=SubstraitMappingKind.StructuralFunction,
        uri="",
        function_name=context,
        anchor=0,
        rewrite="",
        detail="",
    )


pub def sort_field_mapping(direction: str) -> SubstraitMapping:
    """Build one structural sort-field mapping with explicit direction/null-placement detail."""
    return SubstraitMapping(
        kind=SubstraitMappingKind.StructuralFunction,
        uri="",
        function_name="sort_field",
        anchor=0,
        rewrite="",
        detail=direction,
    )


"""Build one deterministic core-import function spec."""

