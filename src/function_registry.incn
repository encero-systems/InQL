"""
Package-owned function registry metadata for the current public InQL function surface.

Public helpers register themselves with declaration-side registry decorators. The decorator owns non-derivable machine
metadata and records one runtime entry while returning the helper unchanged. Function signatures and canonical names
usually come from checked public helper metadata. Decorator metadata may override the canonical name only when the
source helper name is constrained by the host language, such as the `modulo(...)` helper for canonical `mod`.
"""

from substrait.function_extensions import FUNCTION_EXTENSION_URI

pub const CORE_FUNCTION_NAMESPACE: str = "inql.functions"


@derive(Clone)
pub enum FunctionPolicyCategory(str):
    """InQL RFC 024 portability and extension-policy category for one function-like metadata item."""

    PortableCore = "portable_core"
    ExtensionOnly = "extension_only"
    CompatibilityAlias = "compatibility_alias"
    EngineSpecific = "engine_specific"
    Rejected = "rejected"


@derive(Clone)
pub enum FunctionClass(str):
    """High-level semantic category for one registered function."""

    Scalar = "scalar"
    Aggregate = "aggregate"
    Ordering = "ordering"
    Window = "window"
    Generator = "generator"
    TableValued = "table_valued"
    PartitionTransform = "partition_transform"


@derive(Clone)
pub enum FunctionAliasPolicy(str):
    """Import policy for compatibility names associated with a registered function."""

    CoreImport = "core_import"
    OptInCompatibility = "opt_in_compatibility"


@derive(Clone)
pub enum FunctionDeterminism(str):
    """Determinism category used by optimization and documentation tools."""

    Deterministic = "deterministic"
    Nondeterministic = "nondeterministic"


@derive(Clone)
pub enum FunctionNullBehavior(str):
    """Normalized null behavior category for one registered function."""

    DependsOnInputs = "depends_on_inputs"
    NullSkippingAggregate = "null_skipping_aggregate"
    NonNullLiteral = "non_null_literal"
    Predicate = "predicate"


@derive(Clone)
pub enum FunctionErrorBehavior(str):
    """Normalized error behavior category for one registered function."""

    Typechecked = "typechecked"
    InvalidInputDiagnostic = "invalid_input_diagnostic"


@derive(Clone)
pub enum FunctionInputType(str):
    """Primitive input contract used to validate value-or-column helper arguments."""

    Any = "any"
    Bool = "bool"
    Int = "int"
    Float = "float"
    Number = "number"
    String = "string"
    Timestamp = "timestamp"
    Temporal = "temporal"


@derive(Clone, Eq)
pub enum SubstraitMappingKind(str):
    """Substrait interchange category for one portable InQL function."""

    CoreFunction = "core_function"
    ExtensionFunction = "extension_function"
    RelationExtension = "relation_extension"
    Rewrite = "rewrite"
    StructuralFunction = "structural_function"


@derive(Clone, Eq)
pub model FunctionVersion:
    """One InQL package version used by function lifecycle metadata."""

    pub major: int
    pub minor: int


@derive(Clone, Eq)
pub model FunctionChange:
    """One versioned user-visible function contract change."""

    pub version: FunctionVersion
    pub note: str


@derive(Clone, Eq)
pub model FunctionDeprecation:
    """Deprecation metadata for one function when it is no longer preferred."""

    pub since: FunctionVersion
    pub note: str
    pub replacement: str


pub const v0_1: FunctionVersion = FunctionVersion(major=0, minor=1)
pub const v0_2: FunctionVersion = FunctionVersion(major=0, minor=2)
pub const v0_3: FunctionVersion = FunctionVersion(major=0, minor=3)


@derive(Clone, Eq)
pub model FunctionLifecycle:
    """Version lifecycle facts attached to one function registry entry."""

    pub since: FunctionVersion
    pub changed: list[FunctionChange]
    pub deprecated: Option[FunctionDeprecation]


@derive(Clone, Eq)
pub model AggregateModifierPolicy:
    """Aggregate-specific modifier support recorded with registry metadata."""

    pub allows_distinct: bool
    pub allows_filter: bool
    pub allows_ordered_input: bool


pub const NO_AGGREGATE_MODIFIERS: AggregateModifierPolicy = AggregateModifierPolicy(
    allows_distinct=false,
    allows_filter=false,
    allows_ordered_input=false,
)
pub const CORE_AGGREGATE_MODIFIERS: AggregateModifierPolicy = AggregateModifierPolicy(
    allows_distinct=true,
    allows_filter=true,
    allows_ordered_input=false,
)
pub const APPROXIMATE_AGGREGATE_MODIFIERS: AggregateModifierPolicy = AggregateModifierPolicy(
    allows_distinct=false,
    allows_filter=true,
    allows_ordered_input=false,
)


