def _diff_adapter_requirements(
    before_items: list[AdapterRequirement],
    after_items: list[AdapterRequirement],
) -> list[PlanDiffRecord]:
    """Compare adapter requirements by target and capability."""
    mut records: list[PlanDiffRecord] = []
    for before in before_items:
        key = _requirement_key(before)
        match _requirement_by_key(after_items, key):
            Some(after) =>
                if _requirement_signature(before) != _requirement_signature(after):
                    records.append(
                        _record(
                            PlanDiffChangeFamily.AdapterRequirement,
                            PlanDiffChangeKind.Changed,
                            PlanDiffCompatibility.PotentiallyBreaking,
                            PlanDiffConfidence.Conservative,
                            key,
                            Some(after.target),
                            Some(before.target.target_id),
                            Some(after.target.target_id),
                            _requirement_signature(before),
                            _requirement_signature(after),
                            "adapter requirement changed",
                            _merge_refs(before.evidence_refs, after.evidence_refs),
                        ),
                    )
            None =>
                records.append(
                    _record(
                        PlanDiffChangeFamily.AdapterRequirement,
                        PlanDiffChangeKind.Removed,
                        PlanDiffCompatibility.PotentiallyBreaking,
                        PlanDiffConfidence.Conservative,
                        key,
                        Some(before.target),
                        Some(before.target.target_id),
                        None,
                        _requirement_signature(before),
                        "",
                        "adapter requirement was removed",
                        before.evidence_refs,
                    ),
                )
    for after in after_items:
        key = _requirement_key(after)
        match _requirement_by_key(before_items, key):
            Some(_) => pass
            None =>
                records.append(
                    _record(
                        PlanDiffChangeFamily.AdapterRequirement,
                        PlanDiffChangeKind.Added,
                        PlanDiffCompatibility.PotentiallyBreaking,
                        PlanDiffConfidence.Conservative,
                        key,
                        Some(after.target),
                        None,
                        Some(after.target.target_id),
                        "",
                        _requirement_signature(after),
                        "adapter requirement was added",
                        after.evidence_refs,
                    ),
                )
    return records


