"""Structured local plan diffs and blast-radius inputs."""

from bundle import BundleEvidenceSection, GovernedPlanBundle
from dataset import LazyFrame
from evidence import (
    AdapterCoverageRecord,
    AdapterRequirement,
    ExecutionDiagnostic,
    ExecutionObservation,
    LineageEdge,
    MetadataAttachment,
    SemanticTarget,
    UnsupportedEvidence,
)
from governance import GovernedAttribute, PolicyCheckpoint
from inspect import PlanInspection, PlanNodeInspection, inspect_plan
from quality import QualityAssertion, QualityObservation
from scalar_schema import ScalarColumnSpec

pub const PLAN_DIFF_SCHEMA_VERSION: str = "inql.plan-diff.v0.1"
pub const BLAST_RADIUS_INPUT_SCHEMA_VERSION: str = "inql.blast-radius-input.v0.1"


@derive(Clone)
pub enum PlanDiffChangeFamily(str):
    """Evidence families that the local plan diff can classify."""

    ArtifactCompatibility = "artifact_compatibility"
    OutputField = "output_field"
    OutputSchema = "output_schema"
    PlanNode = "plan_node"
    Lineage = "lineage"
    MetadataAttachment = "metadata_attachment"
    GovernedAttribute = "governed_attribute"
    PolicyCheckpoint = "policy_checkpoint"
    AdapterRequirement = "adapter_requirement"
    CoverageRecord = "coverage_record"
    QualityAssertion = "quality_assertion"
    QualityObservation = "quality_observation"
    ExecutionObservation = "execution_observation"
    BundleSection = "bundle_section"
    UnsupportedEvidence = "unsupported_evidence"
    EvidenceReference = "evidence_reference"


@derive(Clone)
pub enum PlanDiffChangeKind(str):
    """How one evidence fact changed between two artifacts."""

    Added = "added"
    Removed = "removed"
    Changed = "changed"
    Renamed = "renamed"
    Unchanged = "unchanged"
    Unknown = "unknown"


@derive(Clone)
pub enum PlanDiffCompatibility(str):
    """Conservative local compatibility class for one diff record."""

    Compatible = "compatible"
    PotentiallyBreaking = "potentially_breaking"
    Breaking = "breaking"
    Unknown = "unknown"


@derive(Clone)
pub enum PlanDiffConfidence(str):
    """Confidence that a diff record identifies the semantic change precisely."""

    Exact = "exact"
    Conservative = "conservative"
    Unknown = "unknown"


@derive(Clone)
pub model PlanDiffRecord:
    """One structured change between two InQL evidence artifacts."""

    pub record_id: str
    pub family: PlanDiffChangeFamily
    pub kind: PlanDiffChangeKind
    pub compatibility: PlanDiffCompatibility
    pub confidence: PlanDiffConfidence
    pub name: str
    pub target: Option[SemanticTarget]
    pub before_target_id: Option[str]
    pub after_target_id: Option[str]
    pub before_value: str
    pub after_value: str
    pub reason: str
    pub evidence_refs: list[str]


@derive(Clone)
pub model BlastRadiusInput:
    """
    Local downstream-impact input derived from one diff record.

    This is not a global impact answer. It names local affected targets and requirement changes that downstream tooling
    can combine with its own dependency index.
    """

    pub schema_version: str
    pub input_id: str
    pub diff_record_id: str
    pub family: PlanDiffChangeFamily
    pub compatibility: PlanDiffCompatibility
    pub affected_target_ids: list[str]
    pub requirement_change_ids: list[str]
    pub evidence_refs: list[str]
    pub reason: str


@derive(Clone)
pub model PlanDiff:
    """Structured local comparison between two InQL evidence artifacts."""

    pub schema_version: str
    pub diff_id: str
    pub before_plan_id: str
    pub after_plan_id: str
    pub before_bundle_id: Option[str]
    pub after_bundle_id: Option[str]
    pub records: list[PlanDiffRecord]
    pub blast_radius_inputs: list[BlastRadiusInput]
    pub diagnostics: list[str]

    def is_empty(self) -> bool:
        """Return whether the diff has no change or unknown-impact records."""
        return len(self.records) == 0

    def changed_output_fields(self) -> list[PlanDiffRecord]:
        """Return output-field changes."""
        return _records_for_family(self.records, PlanDiffChangeFamily.OutputField)

    def changed_adapter_requirements(self) -> list[PlanDiffRecord]:
        """Return adapter requirement changes."""
        return _records_for_family(self.records, PlanDiffChangeFamily.AdapterRequirement)

    def changed_lineage(self) -> list[PlanDiffRecord]:
        """Return lineage changes."""
        return _records_for_family(self.records, PlanDiffChangeFamily.Lineage)

    def unknown_impacts(self) -> list[PlanDiffRecord]:
        """Return records where InQL cannot classify impact precisely."""
        mut records: list[PlanDiffRecord] = []
        for record in self.records:
            if record.kind == PlanDiffChangeKind.Unknown or record.compatibility == PlanDiffCompatibility.Unknown:
                records.append(record)
        return records

    def has_breaking_changes(self) -> bool:
        """Return whether any record is locally breaking."""
        for record in self.records:
            if record.compatibility == PlanDiffCompatibility.Breaking:
                return true
        return false


pub def diff_lazy_plans[T with Clone, U with Clone](before: LazyFrame[T], after: LazyFrame[U]) -> PlanDiff:
    """Inspect two lazy plans and compare their structured evidence."""
    return diff_plans(inspect_plan(before), inspect_plan(after))


pub def diff_plans(before: PlanInspection, after: PlanInspection) -> PlanDiff:
    """Compare two plan inspection artifacts."""
    mut records: list[PlanDiffRecord] = []
    records.extend(_diff_inspection_compatibility(before, after))
    if _inspections_are_compatible(before, after):
        records.extend(
            _diff_output_schema(before.output_schema, before.output_fields, after.output_schema, after.output_fields),
        )
        records.extend(_diff_plan_nodes("authored", before.authored_nodes, after.authored_nodes))
        records.extend(_diff_plan_nodes("rewritten", before.rewritten_nodes, after.rewritten_nodes))
        records.extend(_diff_lineage(before.lineage.edges, after.lineage.edges))
        records.extend(_diff_metadata_attachments(before.attachments, after.attachments))
        records.extend(_diff_governed_attributes(before.governed_attributes, after.governed_attributes))
        records.extend(_diff_policy_checkpoints(before.policy_checkpoints, after.policy_checkpoints))
        records.extend(_diff_adapter_requirements(before.adapter_requirements, after.adapter_requirements))
        records.extend(_diff_unsupported_evidence(before.unsupported_evidence, after.unsupported_evidence))
    return _plan_diff(f"plan-diff:{before.plan_id}:{after.plan_id}", before.plan_id, after.plan_id, None, None, records)


pub def diff_plan_bundles(before: GovernedPlanBundle, after: GovernedPlanBundle) -> PlanDiff:
    """Compare two governed plan bundles."""
    mut records: list[PlanDiffRecord] = []
    if before.schema_version != after.schema_version:
        records.append(
            _unknown_record(
                "bundle_schema_version",
                before.schema_version,
                after.schema_version,
                "bundle schema versions differ; local impact is unknown",
            ),
        )
    else:
        records.extend(
            _diff_output_schema(before.output_schema, before.output_fields, after.output_schema, after.output_fields),
        )
        records.extend(_diff_lineage(before.lineage.edges, after.lineage.edges))
        records.extend(_diff_metadata_attachments(before.attachments, after.attachments))
        records.extend(_diff_governed_attributes(before.governed_attributes, after.governed_attributes))
        records.extend(_diff_policy_checkpoints(before.policy_checkpoints, after.policy_checkpoints))
        records.extend(_diff_adapter_requirements(before.adapter_requirements, after.adapter_requirements))
        records.extend(_diff_coverage_records(before.coverage_records, after.coverage_records))
        records.extend(_diff_quality_assertions(before.quality_assertions, after.quality_assertions))
        records.extend(_diff_quality_observations(before.quality_observations, after.quality_observations))
        records.extend(_diff_execution_observations(before.execution_observations, after.execution_observations))
        records.extend(_diff_bundle_sections(before.sections, after.sections))
        records.extend(_diff_unsupported_evidence(before.unsupported_evidence, after.unsupported_evidence))
        records.extend(_diff_evidence_refs(before.evidence_refs, after.evidence_refs))
    return _plan_diff(
        f"plan-diff:{before.bundle_id}:{after.bundle_id}",
        before.plan_target.plan_id,
        after.plan_target.plan_id,
        Some(before.bundle_id),
        Some(after.bundle_id),
        records,
    )


pub def blast_radius_inputs(diff: PlanDiff) -> list[BlastRadiusInput]:
    """Return local blast-radius input records for one diff."""
    return diff.blast_radius_inputs


def _plan_diff(
    diff_id: str,
    before_plan_id: str,
    after_plan_id: str,
    before_bundle_id: Option[str],
    after_bundle_id: Option[str],
    records: list[PlanDiffRecord],
) -> PlanDiff:
    """Build the final diff and derive local blast-radius records from its changes."""
    return PlanDiff(
        schema_version=PLAN_DIFF_SCHEMA_VERSION,
        diff_id=diff_id,
        before_plan_id=before_plan_id,
        after_plan_id=after_plan_id,
        before_bundle_id=before_bundle_id,
        after_bundle_id=after_bundle_id,
        records=records,
        blast_radius_inputs=_blast_radius_inputs(diff_id, records),
        diagnostics=[],
    )


def _diff_inspection_compatibility(before: PlanInspection, after: PlanInspection) -> list[PlanDiffRecord]:
    """Record unknown impact when inspection schema versions cannot be compared safely."""
    mut records: list[PlanDiffRecord] = []
    if before.schema_version != after.schema_version:
        records.append(
            _unknown_record(
                "inspection_schema_version",
                before.schema_version,
                after.schema_version,
                "inspection schema versions differ; local impact is unknown",
            ),
        )
    return records


def _inspections_are_compatible(before: PlanInspection, after: PlanInspection) -> bool:
    """Return whether two inspection artifacts can be compared by this diff version."""
    return before.schema_version == after.schema_version


def _diff_output_schema(
    before_schema: list[ScalarColumnSpec],
    before_fields: list[SemanticTarget],
    after_schema: list[ScalarColumnSpec],
    after_fields: list[SemanticTarget],
) -> list[PlanDiffRecord]:
    """Compare output fields and schema facts by display name plus ordinal context."""
    mut records = _diff_renamed_output_fields(before_schema, before_fields, after_schema, after_fields)
    for before in before_schema:
        match _scalar_column_by_name(after_schema, before.name):
            Some(after) =>
                if _scalar_column_signature(before) != _scalar_column_signature(after):
                    records.append(
                        _record(
                            PlanDiffChangeFamily.OutputSchema,
                            PlanDiffChangeKind.Changed,
                            PlanDiffCompatibility.Breaking,
                            PlanDiffConfidence.Exact,
                            before.name,
                            _field_target_by_name(after_fields, before.name),
                            Some(_target_id_by_name(before_fields, before.name)),
                            Some(_target_id_by_name(after_fields, before.name)),
                            _scalar_column_signature(before),
                            _scalar_column_signature(after),
                            "output field schema changed",
                            [],
                        ),
                    )
            None =>
                records.append(
                    _record(
                        PlanDiffChangeFamily.OutputField,
                        PlanDiffChangeKind.Removed,
                        PlanDiffCompatibility.Breaking,
                        PlanDiffConfidence.Exact,
                        before.name,
                        _field_target_by_name(before_fields, before.name),
                        Some(_target_id_by_name(before_fields, before.name)),
                        None,
                        _scalar_column_signature(before),
                        "",
                        "output field was removed",
                        [],
                    ),
                )
    for after in after_schema:
        match _scalar_column_by_name(before_schema, after.name):
            Some(_) => pass
            None =>
                records.append(
                    _record(
                        PlanDiffChangeFamily.OutputField,
                        PlanDiffChangeKind.Added,
                        PlanDiffCompatibility.PotentiallyBreaking,
                        PlanDiffConfidence.Exact,
                        after.name,
                        _field_target_by_name(after_fields, after.name),
                        None,
                        Some(_target_id_by_name(after_fields, after.name)),
                        "",
                        _scalar_column_signature(after),
                        "output field was added",
                        [],
                    ),
                )
    return records


def _diff_renamed_output_fields(
    before_schema: list[ScalarColumnSpec],
    before_fields: list[SemanticTarget],
    after_schema: list[ScalarColumnSpec],
    after_fields: list[SemanticTarget],
) -> list[PlanDiffRecord]:
    """Detect ordinal-preserving field-name changes before add/remove records are emitted."""
    mut records: list[PlanDiffRecord] = []
    limit = _min_int(len(before_schema), len(after_schema))
    for idx in range(0, limit):
        before = before_schema[idx]
        after = after_schema[idx]
        if before.name != after.name and _scalar_column_shape(before) == _scalar_column_shape(after):
            records.append(
                _record(
                    PlanDiffChangeFamily.OutputField,
                    PlanDiffChangeKind.Renamed,
                    PlanDiffCompatibility.Breaking,
                    PlanDiffConfidence.Conservative,
                    f"{before.name}->{after.name}",
                    _field_target_by_name(after_fields, after.name),
                    Some(_target_id_by_name(before_fields, before.name)),
                    Some(_target_id_by_name(after_fields, after.name)),
                    before.name,
                    after.name,
                    "output field name changed at the same ordinal",
                    [],
                ),
            )
    return records


def _diff_plan_nodes(
    prefix: str,
    before_nodes: list[PlanNodeInspection],
    after_nodes: list[PlanNodeInspection],
) -> list[PlanDiffRecord]:
    """Compare authored or rewritten node sequences by ordinal and node kind."""
    mut records: list[PlanDiffRecord] = []
    limit = _min_int(len(before_nodes), len(after_nodes))
    for idx in range(0, limit):
        before = before_nodes[idx]
        after = after_nodes[idx]
        if before.kind != after.kind:
            records.append(
                _record(
                    PlanDiffChangeFamily.PlanNode,
                    PlanDiffChangeKind.Changed,
                    PlanDiffCompatibility.PotentiallyBreaking,
                    PlanDiffConfidence.Conservative,
                    f"{prefix}:{idx}",
                    Some(after.target),
                    Some(before.target.target_id),
                    Some(after.target.target_id),
                    before.kind.value(),
                    after.kind.value(),
                    "plan node kind changed at the same ordinal",
                    [],
                ),
            )
    if len(before_nodes) > len(after_nodes):
        for idx in range(limit, len(before_nodes)):
            node = before_nodes[idx]
            records.append(
                _record(
                    PlanDiffChangeFamily.PlanNode,
                    PlanDiffChangeKind.Removed,
                    PlanDiffCompatibility.PotentiallyBreaking,
                    PlanDiffConfidence.Conservative,
                    f"{prefix}:{idx}:{node.kind.value()}",
                    Some(node.target),
                    Some(node.target.target_id),
                    None,
                    node.kind.value(),
                    "",
                    "plan node was removed",
                    [],
                ),
            )
    if len(after_nodes) > len(before_nodes):
        for idx in range(limit, len(after_nodes)):
            node = after_nodes[idx]
            records.append(
                _record(
                    PlanDiffChangeFamily.PlanNode,
                    PlanDiffChangeKind.Added,
                    PlanDiffCompatibility.PotentiallyBreaking,
                    PlanDiffConfidence.Conservative,
                    f"{prefix}:{idx}:{node.kind.value()}",
                    Some(node.target),
                    None,
                    Some(node.target.target_id),
                    "",
                    node.kind.value(),
                    "plan node was added",
                    [],
                ),
            )
    return records


def _diff_lineage(before_edges: list[LineageEdge], after_edges: list[LineageEdge]) -> list[PlanDiffRecord]:
    """Compare lineage by semantic edge signatures rather than target ids tied to one plan id."""
    mut records: list[PlanDiffRecord] = []
    for before in before_edges:
        if not _has_lineage_signature(after_edges, _lineage_signature(before)):
            records.append(
                _record(
                    PlanDiffChangeFamily.Lineage,
                    PlanDiffChangeKind.Removed,
                    PlanDiffCompatibility.PotentiallyBreaking,
                    PlanDiffConfidence.Conservative,
                    _lineage_name(before),
                    Some(before.destination),
                    Some(before.destination.target_id),
                    None,
                    _lineage_signature(before),
                    "",
                    "lineage edge was removed",
                    before.evidence_refs,
                ),
            )
    for after in after_edges:
        if not _has_lineage_signature(before_edges, _lineage_signature(after)):
            records.append(
                _record(
                    PlanDiffChangeFamily.Lineage,
                    PlanDiffChangeKind.Added,
                    PlanDiffCompatibility.PotentiallyBreaking,
                    PlanDiffConfidence.Conservative,
                    _lineage_name(after),
                    Some(after.destination),
                    None,
                    Some(after.destination.target_id),
                    "",
                    _lineage_signature(after),
                    "lineage edge was added",
                    after.evidence_refs,
                ),
            )
    return records


def _diff_metadata_attachments(
    before_items: list[MetadataAttachment],
    after_items: list[MetadataAttachment],
) -> list[PlanDiffRecord]:
    """Compare metadata attachments by target, namespace, and key."""
    mut records: list[PlanDiffRecord] = []
    for before in before_items:
        key = _metadata_key(before)
        match _metadata_by_key(after_items, key):
            Some(after) =>
                if _metadata_signature(before) != _metadata_signature(after):
                    records.append(
                        _changed_record(
                            PlanDiffChangeFamily.MetadataAttachment,
                            key,
                            Some(after.target),
                            _metadata_signature(before),
                            _metadata_signature(after),
                            "metadata attachment changed",
                            _merge_refs(before.evidence_refs, after.evidence_refs),
                        ),
                    )
            None =>
                records.append(
                    _removed_record(
                        PlanDiffChangeFamily.MetadataAttachment,
                        key,
                        Some(before.target),
                        before.evidence_refs,
                    ),
                )
    for after in after_items:
        key = _metadata_key(after)
        match _metadata_by_key(before_items, key):
            Some(_) => pass
            None =>
                records.append(
                    _added_record(PlanDiffChangeFamily.MetadataAttachment, key, Some(after.target), after.evidence_refs),
                )
    return records


