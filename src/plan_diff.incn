def _diff_quality_observations(
    before_items: list[QualityObservation],
    after_items: list[QualityObservation],
) -> list[PlanDiffRecord]:
    """Compare quality observations."""
    mut records: list[PlanDiffRecord] = []
    for before in before_items:
        match _quality_observation_by_id(after_items, before.observation_id):
            Some(after) =>
                if _quality_observation_signature(before) != _quality_observation_signature(after):
                    records.append(
                        _changed_record(
                            PlanDiffChangeFamily.QualityObservation,
                            before.observation_id,
                            Some(after.target),
                            _quality_observation_signature(before),
                            _quality_observation_signature(after),
                            "quality observation changed",
                            _merge_refs(before.evidence_refs, after.evidence_refs),
                        ),
                    )
            None =>
                records.append(
                    _removed_record(
                        PlanDiffChangeFamily.QualityObservation,
                        before.observation_id,
                        Some(before.target),
                        before.evidence_refs,
                    ),
                )
    for after in after_items:
        match _quality_observation_by_id(before_items, after.observation_id):
            Some(_) => pass
            None =>
                records.append(
                    _added_record(
                        PlanDiffChangeFamily.QualityObservation,
                        after.observation_id,
                        Some(after.target),
                        after.evidence_refs,
                    ),
                )
    return records


def _diff_execution_observations(
    before_items: list[ExecutionObservation],
    after_items: list[ExecutionObservation],
) -> list[PlanDiffRecord]:
    """Compare execution observations."""
    mut records: list[PlanDiffRecord] = []
    for before in before_items:
        match _execution_observation_by_id(after_items, before.observation_id):
            Some(after) =>
                if _execution_observation_signature(before) != _execution_observation_signature(after):
                    records.append(
                        _changed_record(
                            PlanDiffChangeFamily.ExecutionObservation,
                            before.observation_id,
                            Some(after.plan_target),
                            _execution_observation_signature(before),
                            _execution_observation_signature(after),
                            "execution observation changed",
                            _merge_refs(before.evidence_refs, after.evidence_refs),
                        ),
                    )
            None =>
                records.append(
                    _removed_record(
                        PlanDiffChangeFamily.ExecutionObservation,
                        before.observation_id,
                        Some(before.plan_target),
                        before.evidence_refs,
                    ),
                )
    for after in after_items:
        match _execution_observation_by_id(before_items, after.observation_id):
            Some(_) => pass
            None =>
                records.append(
                    _added_record(
                        PlanDiffChangeFamily.ExecutionObservation,
                        after.observation_id,
                        Some(after.plan_target),
                        after.evidence_refs,
                    ),
                )
    return records


def _diff_bundle_sections(
    before_items: list[BundleEvidenceSection],
    after_items: list[BundleEvidenceSection],
) -> list[PlanDiffRecord]:
    """Compare bundle evidence section states."""
    mut records: list[PlanDiffRecord] = []
    for before in before_items:
        match _section_by_family(after_items, before.family):
            Some(after) =>
                if _section_signature(before) != _section_signature(after):
                    records.append(
                        _changed_record(
                            PlanDiffChangeFamily.BundleSection,
                            before.family,
                            None,
                            _section_signature(before),
                            _section_signature(after),
                            "bundle evidence section changed",
                            _merge_refs(before.evidence_refs, after.evidence_refs),
                        ),
                    )
            None =>
                records.append(
                    _removed_record(PlanDiffChangeFamily.BundleSection, before.family, None, before.evidence_refs),
                )
    for after in after_items:
        match _section_by_family(before_items, after.family):
            Some(_) => pass
            None => records.append(
                _added_record(PlanDiffChangeFamily.BundleSection, after.family, None, after.evidence_refs),
            )
    return records


def _diff_unsupported_evidence(
    before_items: list[UnsupportedEvidence],
    after_items: list[UnsupportedEvidence],
) -> list[PlanDiffRecord]:
    """Compare explicit unsupported evidence markers."""
    mut records: list[PlanDiffRecord] = []
    for before in before_items:
        match _unsupported_by_family(after_items, before.family):
            Some(after) =>
                if before.reason != after.reason:
                    records.append(
                        _changed_record(
                            PlanDiffChangeFamily.UnsupportedEvidence,
                            before.family,
                            None,
                            before.reason,
                            after.reason,
                            "unsupported evidence reason changed",
                            [],
                        ),
                    )
            None => records.append(_removed_record(PlanDiffChangeFamily.UnsupportedEvidence, before.family, None, []))
    for after in after_items:
        match _unsupported_by_family(before_items, after.family):
            Some(_) => pass
            None => records.append(_added_record(PlanDiffChangeFamily.UnsupportedEvidence, after.family, None, []))
    return records


def _diff_evidence_refs(before_refs: list[str], after_refs: list[str]) -> list[PlanDiffRecord]:
    """Compare bundle-level evidence references."""
    mut records: list[PlanDiffRecord] = []
    for before in before_refs:
        if not _has_string(after_refs, before):
            records.append(_removed_record(PlanDiffChangeFamily.EvidenceReference, before, None, [before]))
    for after in after_refs:
        if not _has_string(before_refs, after):
            records.append(_added_record(PlanDiffChangeFamily.EvidenceReference, after, None, [after]))
    return records


def _blast_radius_inputs(diff_id: str, records: list[PlanDiffRecord]) -> list[BlastRadiusInput]:
    """Derive one conservative local blast-radius input per change record."""
    mut inputs: list[BlastRadiusInput] = []
    for record in records:
        if record.kind != PlanDiffChangeKind.Unchanged:
            inputs.append(
                BlastRadiusInput(
                    schema_version=BLAST_RADIUS_INPUT_SCHEMA_VERSION,
                    input_id=f"blast-radius:{record.record_id}",
                    diff_record_id=record.record_id,
                    family=record.family,
                    compatibility=record.compatibility,
                    affected_target_ids=_record_target_ids(record),
                    requirement_change_ids=_record_requirement_ids(record),
                    evidence_refs=record.evidence_refs,
                    reason=f"{diff_id}: {record.reason}",
                ),
            )
    return inputs


def _record_target_ids(record: PlanDiffRecord) -> list[str]:
    """Collect target ids referenced by one diff record without inventing global consumers."""
    mut ids: list[str] = []
    if let Some(value) = record.before_target_id:
        ids.append(value)
    if let Some(value) = record.after_target_id:
        if not _has_string(ids, value):
            ids.append(value)
    return ids


def _record_requirement_ids(record: PlanDiffRecord) -> list[str]:
    """Return requirement ids when a diff record represents an adapter requirement change."""
    if record.family == PlanDiffChangeFamily.AdapterRequirement:
        return _record_target_ids(record)
    return []


def _unknown_record(name: str, before_value: str, after_value: str, reason: str) -> PlanDiffRecord:
    """Build an explicit unknown-impact record."""
    return _record(
        PlanDiffChangeFamily.ArtifactCompatibility,
        PlanDiffChangeKind.Unknown,
        PlanDiffCompatibility.Unknown,
        PlanDiffConfidence.Unknown,
        name,
        None,
        None,
        None,
        before_value,
        after_value,
        reason,
        [],
    )


def _added_record(
    family: PlanDiffChangeFamily,
    name: str,
    target: Option[SemanticTarget],
    evidence_refs: list[str],
) -> PlanDiffRecord:
    """Build a generic added-record diff for evidence families whose impact is policy-specific."""
    return _record(
        family,
        PlanDiffChangeKind.Added,
        _default_compatibility(family, PlanDiffChangeKind.Added),
        PlanDiffConfidence.Conservative,
        name,
        target,
        None,
        _target_id_from_option(target),
        "",
        name,
        "evidence record was added",
        evidence_refs,
    )


def _removed_record(
    family: PlanDiffChangeFamily,
    name: str,
    target: Option[SemanticTarget],
    evidence_refs: list[str],
) -> PlanDiffRecord:
    """Build a generic removed-record diff for evidence families whose impact is policy-specific."""
    return _record(
        family,
        PlanDiffChangeKind.Removed,
        _default_compatibility(family, PlanDiffChangeKind.Removed),
        PlanDiffConfidence.Conservative,
        name,
        target,
        _target_id_from_option(target),
        None,
        name,
        "",
        "evidence record was removed",
        evidence_refs,
    )


def _changed_record(
    family: PlanDiffChangeFamily,
    name: str,
    target: Option[SemanticTarget],
    before_value: str,
    after_value: str,
    reason: str,
    evidence_refs: list[str],
) -> PlanDiffRecord:
    """Build a generic changed-record diff for evidence families whose impact is policy-specific."""
    target_id = _target_id_from_option(target)
    return _record(
        family,
        PlanDiffChangeKind.Changed,
        _default_compatibility(family, PlanDiffChangeKind.Changed),
        PlanDiffConfidence.Conservative,
        name,
        target,
        target_id,
        target_id,
        before_value,
        after_value,
        reason,
        evidence_refs,
    )


def _record(
    family: PlanDiffChangeFamily,
    kind: PlanDiffChangeKind,
    compatibility: PlanDiffCompatibility,
    confidence: PlanDiffConfidence,
    name: str,
    target: Option[SemanticTarget],
    before_target_id: Option[str],
    after_target_id: Option[str],
    before_value: str,
    after_value: str,
    reason: str,
    evidence_refs: list[str],
) -> PlanDiffRecord:
    """Build one deterministic local diff record."""
    record_id = f"plan-diff:{family.value()}:{kind.value()}:{name}:{before_value}:{after_value}"
    return PlanDiffRecord(
        record_id=record_id,
        family=family,
        kind=kind,
        compatibility=compatibility,
        confidence=confidence,
        name=name,
        target=target,
        before_target_id=before_target_id,
        after_target_id=after_target_id,
        before_value=before_value,
        after_value=after_value,
        reason=reason,
        evidence_refs=evidence_refs,
    )


def _default_compatibility(family: PlanDiffChangeFamily, kind: PlanDiffChangeKind) -> PlanDiffCompatibility:
    """Return conservative compatibility for policy-specific evidence families."""
    if family == PlanDiffChangeFamily.ArtifactCompatibility:
        return PlanDiffCompatibility.Unknown
    if family == PlanDiffChangeFamily.CoverageRecord or family == PlanDiffChangeFamily.QualityAssertion:
        return PlanDiffCompatibility.Unknown
    if family == PlanDiffChangeFamily.QualityObservation or family == PlanDiffChangeFamily.ExecutionObservation:
        return PlanDiffCompatibility.Unknown
    if family == PlanDiffChangeFamily.BundleSection or family == PlanDiffChangeFamily.EvidenceReference:
        return PlanDiffCompatibility.Unknown
    if family == PlanDiffChangeFamily.UnsupportedEvidence:
        return PlanDiffCompatibility.Unknown
    if kind == PlanDiffChangeKind.Removed:
        return PlanDiffCompatibility.PotentiallyBreaking
    return PlanDiffCompatibility.Unknown


def _records_for_family(records: list[PlanDiffRecord], family: PlanDiffChangeFamily) -> list[PlanDiffRecord]:
    """Return records that belong to one family."""
    return [record for record in records if record.family == family]


def _scalar_column_signature(column: ScalarColumnSpec) -> str:
    """Return the comparable full output-column signature."""
    return f"{column.name}:{_scalar_column_shape(column)}"


def _scalar_column_shape(column: ScalarColumnSpec) -> str:
    """Return comparable type/nullability facts for one output column."""
    return f"{_scalar_kind_text(column)}:nullable={column.nullable}"


def _scalar_kind_text(column: ScalarColumnSpec) -> str:
    """Return the scalar primitive kind text, preserving unknown schema as unknown."""
    match column.kind:
        Some(kind) => return kind.value()
        None => return "unknown"


def _scalar_column_by_name(columns: list[ScalarColumnSpec], name: str) -> Option[ScalarColumnSpec]:
    """Return a scalar column by name."""
    for column in columns:
        if column.name == name:
            return Some(column)
    return None


def _field_target_by_name(fields: list[SemanticTarget], name: str) -> Option[SemanticTarget]:
    """Return the first output-field target with the requested name."""
    for field in fields:
        if field.name == name:
            return Some(field)
    return None


def _target_id_by_name(fields: list[SemanticTarget], name: str) -> str:
    """Return a field target id by name, or the display name when the field is absent."""
    for field in fields:
        if field.name == name:
            return field.target_id
    return name


def _target_id_from_option(target: Option[SemanticTarget]) -> Option[str]:
    """Return the target id from an optional semantic target."""
    if let Some(value) = target:
        return Some(value.target_id)
    return None


def _lineage_signature(edge: LineageEdge) -> str:
    """Return the comparable lineage edge signature."""
    return f"{edge.source.kind.value()}:{edge.source.name}->{edge.destination.kind.value()}:{edge.destination.name}:{edge.relationship.value()}:{edge.transformation.value()}:{edge.confidence.value()}"


def _lineage_name(edge: LineageEdge) -> str:
    """Return a concise lineage display name."""
    return f"{edge.source.name}->{edge.destination.name}"


def _has_lineage_signature(edges: list[LineageEdge], signature: str) -> bool:
    """Return whether the lineage edge list contains a signature."""
    for edge in edges:
        if _lineage_signature(edge) == signature:
            return true
    return false


def _metadata_key(item: MetadataAttachment) -> str:
    """Return the semantic key for one metadata attachment."""
    return f"{item.target.kind.value()}:{item.target.name}:{item.namespace}:{item.key}"


def _metadata_signature(item: MetadataAttachment) -> str:
    """Return comparable metadata attachment facts."""
    return f"{_metadata_key(item)}:{item.payload.schema}:{item.payload.value}:{item.lifecycle.value()}:{item.source.value()}:{item.visibility.value()}"


def _metadata_by_key(items: list[MetadataAttachment], key: str) -> Option[MetadataAttachment]:
    """Return a metadata attachment by key."""
    for item in items:
        if _metadata_key(item) == key:
            return Some(item)
    return None


def _attribute_key(item: GovernedAttribute) -> str:
    """Return the semantic key for one governed attribute."""
    return f"{item.target.kind.value()}:{item.target.name}:{item.key}:{item.scope.value()}"


def _attribute_signature(item: GovernedAttribute) -> str:
    """Return comparable governed attribute facts."""
    return f"{_attribute_key(item)}:{item.value.schema}:{item.value.value}:{item.source.value()}:{item.confidence.value()}:{item.status.value()}"


def _attribute_by_key(items: list[GovernedAttribute], key: str) -> Option[GovernedAttribute]:
    """Return a governed attribute by semantic key."""
    for item in items:
        if _attribute_key(item) == key:
            return Some(item)
    return None


def _checkpoint_key(item: PolicyCheckpoint) -> str:
    """Return the semantic key for one policy checkpoint."""
    return f"{item.target.kind.value()}:{item.target.name}:{item.checkpoint.value()}:{item.action.value()}:{item.policy_ref}:{item.reason_code}"


def _checkpoint_signature(item: PolicyCheckpoint) -> str:
    """Return comparable policy checkpoint facts."""
    return f"{_checkpoint_key(item)}:{item.visibility.value()}:{_diagnostics_signature(item.diagnostics)}"


def _checkpoint_by_key(items: list[PolicyCheckpoint], key: str) -> Option[PolicyCheckpoint]:
    """Return a policy checkpoint by semantic key."""
    for item in items:
        if _checkpoint_key(item) == key:
            return Some(item)
    return None


def _requirement_key(item: AdapterRequirement) -> str:
    """Return the semantic key for one adapter requirement."""
    return f"{item.target.kind.value()}:{item.target.name}:{item.capability.value()}"


def _requirement_signature(item: AdapterRequirement) -> str:
    """Return comparable adapter requirement facts."""
    return f"{_requirement_key(item)}:{item.guarantee.value()}:{item.reason}"


def _requirement_by_key(items: list[AdapterRequirement], key: str) -> Option[AdapterRequirement]:
    """Return an adapter requirement by key."""
    for item in items:
        if _requirement_key(item) == key:
            return Some(item)
    return None


def _coverage_signature(item: AdapterCoverageRecord) -> str:
    """Return comparable adapter coverage facts."""
    return f"{item.adapter_name}:{_option_str_text(item.adapter_version)}:{_option_str_text(item.semantic_profile_id)}:{item.state.value()}:{_diagnostics_signature(
        item.diagnostics,
    )}"


def _coverage_by_id(items: list[AdapterCoverageRecord], coverage_id: str) -> Option[AdapterCoverageRecord]:
    """Return an adapter coverage record by id."""
    for item in items:
        if item.coverage_id == coverage_id:
            return Some(item)
    return None


def _quality_assertion_signature(item: QualityAssertion) -> str:
    """Return comparable quality assertion facts."""
    return f"{item.kind.value()}:{item.name}:{item.severity.value()}:{item.mode.value()}:{item.scope.value()}:{_option_int_text(
        item.min_count,
    )}:{_option_int_text(item.max_count)}:{_option_float_text(item.max_rate)}"


def _quality_assertion_by_id(items: list[QualityAssertion], assertion_id: str) -> Option[QualityAssertion]:
    """Return a quality assertion by id."""
    for item in items:
        if item.assertion_id == assertion_id:
            return Some(item)
    return None


def _quality_observation_signature(item: QualityObservation) -> str:
    """Return comparable quality observation facts."""
    return f"{item.assertion.assertion_id}:{item.status.value()}:{len(item.metrics)}:{_diagnostics_signature(
        item.diagnostics,
    )}"


def _quality_observation_by_id(items: list[QualityObservation], observation_id: str) -> Option[QualityObservation]:
    """Return a quality observation by id."""
    for item in items:
        if item.observation_id == observation_id:
            return Some(item)
    return None


def _execution_observation_signature(item: ExecutionObservation) -> str:
    """Return comparable execution observation facts."""
    return f"{item.operation.value()}:{item.status.value()}:{item.backend_name}:{_option_str_text(item.adapter_version)}:{_option_int_text(
        item.row_count,
    )}:{_option_int_text(item.byte_count)}:{_diagnostics_signature(item.diagnostics)}"


def _execution_observation_by_id(
    items: list[ExecutionObservation],
    observation_id: str,
) -> Option[ExecutionObservation]:
    """Return an execution observation by id."""
    for item in items:
        if item.observation_id == observation_id:
            return Some(item)
    return None


def _section_signature(item: BundleEvidenceSection) -> str:
    """Return comparable bundle section facts."""
    return f"{item.requirement.value()}:{item.availability.value()}:{item.record_count}:{item.reason}"


def _section_by_family(items: list[BundleEvidenceSection], family: str) -> Option[BundleEvidenceSection]:
    """Return a bundle section by family."""
    for item in items:
        if item.family == family:
            return Some(item)
    return None


def _unsupported_by_family(items: list[UnsupportedEvidence], family: str) -> Option[UnsupportedEvidence]:
    """Return an unsupported-evidence marker by family."""
    for item in items:
        if item.family == family:
            return Some(item)
    return None


def _diagnostics_signature(diagnostics: list[ExecutionDiagnostic]) -> str:
    """Return a compact diagnostics signature."""
    mut parts: list[str] = []
    for diagnostic in diagnostics:
        parts.append(f"{diagnostic.severity.value()}:{diagnostic.code}:{diagnostic.message}")
    return _join_pipe(parts)


def _option_str_text(value: Option[str]) -> str:
    """Return stable text for optional strings."""
    if let Some(inner) = value:
        return inner
    return ""


def _option_int_text(value: Option[int]) -> str:
    """Return stable text for optional integers."""
    if let Some(inner) = value:
        return f"{inner}"
    return ""


def _option_float_text(value: Option[float]) -> str:
    """Return stable text for optional floats."""
    if let Some(inner) = value:
        return f"{inner}"
    return ""


def _merge_refs(left: list[str], right: list[str]) -> list[str]:
    """Merge evidence references while preserving first-seen order."""
    mut refs: list[str] = []
    for value in left:
        if not _has_string(refs, value):
            refs.append(value)
    for value in right:
        if not _has_string(refs, value):
            refs.append(value)
    return refs


def _has_string(values: list[str], value: str) -> bool:
    """Return whether a string list contains a value."""
    for item in values:
        if item == value:
            return true
    return false


def _join_pipe(values: list[str]) -> str:
    """Join strings with a pipe separator without depending on caller ordering tricks."""
    mut output = ""
    for idx in range(0, len(values)):
        if idx > 0:
            output += "|"
        output += values[idx]
    return output


def _min_int(left: int, right: int) -> int:
    """Return the smaller integer."""
    if left < right:
        return left
    return right
