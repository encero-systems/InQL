"""
Shared declaration-side registry state for public InQL helpers.

Helper modules attach metadata with `@register_function(...)` next to the helper they expose. This module owns the
runtime projection for helpers that have actually been loaded in the current process. Checked API metadata remains the
source for the complete public catalog and helper signatures.
"""

from rust::incan_stdlib::errors import raise_value_error
from function_registry import (
    CORE_FUNCTION_NAMESPACE,
    FunctionAliasPolicy,
    FunctionRegistry,
    FunctionRegistryEntry,
    FunctionSpec,
    SubstraitMapping,
    SubstraitMappingKind,
)
from projection_builders import (
    BoolColumnExpr,
    ColumnExpr,
    FloatColumnExpr,
    IntColumnExpr,
    NumberColumnExpr,
    ScalarFunctionOption,
    StringColumnExpr,
    TemporalColumnExpr,
    TimestampColumnExpr,
    bool_column_expr,
    int_column_expr,
    number_column_expr,
    scalar_function_application,
    str_column_expr,
    temporal_column_expr,
    timestamp_column_expr,
)

pub static function_registry: FunctionRegistry = FunctionRegistry.new()
static _pending_function_specs: list[FunctionSpec] = []


pub def register_function[F](spec: FunctionSpec) -> (F) -> F:
    """Queue one function spec and return the declaration-side registration decorator."""
    _pending_function_specs.append(spec)
    return (func) => _register_pending_function[F](func)


def _register_pending_function[F](func: F) -> F:
    """Register the most recently queued declaration-side spec against the decorated helper name."""
    pending_index = len(_pending_function_specs) - 1
    assert pending_index >= 0, "function registry decorator had no pending spec"
    spec = _pending_function_specs[pending_index]
    mut canonical_name = func.__name__
    if let Some(name) = spec.canonical_name:
        canonical_name = name
    function_registry._add_entry(canonical_name, spec)
    return func


pub def register_function_alias(
    canonical_name: str,
    alias_name: str,
    alias_policy: FunctionAliasPolicy = FunctionAliasPolicy.OptInCompatibility,
) -> None:
    """Record one real public alias name for an already-registered core function."""
    function_registry._add_alias(CORE_FUNCTION_NAMESPACE, canonical_name, alias_name, alias_policy)


pub def registered_substrait_mapping(function_name: str) -> SubstraitMapping:
    """Return the decorator-registered Substrait mapping for one canonical or alias helper name."""
    entry = registered_function_entry(function_name)
    return entry.substrait


pub def registered_function_entry(function_name: str) -> FunctionRegistryEntry:
    """Return the decorator-registered metadata for one canonical or alias helper name."""
    if let Some(entry) = function_registry.entry_by_name(function_name):
        return entry
    message = f"missing function registry entry for `{function_name}`"
    return raise_value_error(message)


pub def registered_application(canonical_name: str, arguments: list[ColumnExpr]) -> ColumnExpr:
    """Build one scalar application using decorator-owned registry metadata."""
    return registered_application_with_options(canonical_name, arguments, [])


pub def registered_application_with_options(
    canonical_name: str,
    arguments: list[ColumnExpr],
    options: list[ScalarFunctionOption],
) -> ColumnExpr:
    """Build one scalar application with non-expression options using decorator-owned registry metadata."""
    entry = registered_function_entry(canonical_name)
    return scalar_function_application(entry.canonical_name, arguments, options)


pub def registered_bool_application(canonical_name: str, arguments: list[ColumnExpr]) -> BoolColumnExpr:
    """Build one scalar application that produces boolean values."""
    return registered_bool_application_with_options(canonical_name, arguments, [])


pub def registered_bool_application_with_options(
    canonical_name: str,
    arguments: list[ColumnExpr],
    options: list[ScalarFunctionOption],
) -> BoolColumnExpr:
    """Build one boolean-producing scalar application with non-expression options."""
    entry = registered_function_entry(canonical_name)
    return bool_column_expr(scalar_function_application(entry.canonical_name, arguments, options))


pub def registered_int_application(canonical_name: str, arguments: list[ColumnExpr]) -> IntColumnExpr:
    """Build one scalar application that produces integer values."""
    return registered_int_application_with_options(canonical_name, arguments, [])


pub def registered_int_application_with_options(
    canonical_name: str,
    arguments: list[ColumnExpr],
    options: list[ScalarFunctionOption],
) -> IntColumnExpr:
    """Build one integer-producing scalar application with non-expression options."""
    entry = registered_function_entry(canonical_name)
    return int_column_expr(scalar_function_application(entry.canonical_name, arguments, options))


pub def registered_number_application(canonical_name: str, arguments: list[ColumnExpr]) -> NumberColumnExpr:
    """Build one scalar application that produces numeric values."""
    return registered_number_application_with_options(canonical_name, arguments, [])


pub def registered_number_application_with_options(
    canonical_name: str,
    arguments: list[ColumnExpr],
    options: list[ScalarFunctionOption],
) -> NumberColumnExpr:
    """Build one numeric scalar application with non-expression options."""
    entry = registered_function_entry(canonical_name)
    return number_column_expr(scalar_function_application(entry.canonical_name, arguments, options))


pub def registered_string_application(canonical_name: str, arguments: list[ColumnExpr]) -> StringColumnExpr:
    """Build one scalar application that produces string values."""
    return registered_string_application_with_options(canonical_name, arguments, [])


pub def registered_string_application_with_options(
    canonical_name: str,
    arguments: list[ColumnExpr],
    options: list[ScalarFunctionOption],
) -> StringColumnExpr:
    """Build one string-producing scalar application with non-expression options."""
    entry = registered_function_entry(canonical_name)
    return str_column_expr(scalar_function_application(entry.canonical_name, arguments, options))


pub def registered_timestamp_application(canonical_name: str, arguments: list[ColumnExpr]) -> TimestampColumnExpr:
    """Build one scalar application that produces timestamp values."""
    entry = registered_function_entry(canonical_name)
    return timestamp_column_expr(scalar_function_application(entry.canonical_name, arguments, []))


pub def registered_temporal_application(canonical_name: str, arguments: list[ColumnExpr]) -> TemporalColumnExpr:
    """Build one scalar application that produces date/time values that are not yet modeled as a specific primitive."""
    entry = registered_function_entry(canonical_name)
    return temporal_column_expr(scalar_function_application(entry.canonical_name, arguments, []))


pub def function_registry_entries() -> list[FunctionRegistryEntry]:
    """Return runtime registry entries for helpers loaded in the current process."""
    return function_registry.entries


pub def function_registry_entry(function_ref: str) -> Option[FunctionRegistryEntry]:
    """Return a loaded registry entry for one stable function reference when it is known."""
    for entry in function_registry.entries:
        if entry.function_ref == function_ref:
            return Some(entry)
    return None


pub def function_registry_entry_by_name(function_name: str) -> Option[FunctionRegistryEntry]:
    """Return a loaded core registry entry for one canonical or alias public function name."""
    return function_registry.entry_by_name(function_name)


pub def function_registry_function_refs() -> list[str]:
    """Return loaded function references in runtime registry order."""
    return [entry.function_ref for entry in function_registry.entries]


pub def function_registry_canonical_names() -> list[str]:
    """Return loaded canonical function names in runtime registry order."""
    return [entry.canonical_name for entry in function_registry.entries]


pub def function_registry_entry_count() -> int:
    """Return the number of loaded runtime registry entries."""
    return len(function_registry.entries)


pub def registered_substrait_mapped_function_refs() -> list[str]:
    """Return function references with a concrete Substrait extension mapping."""
    return [entry.function_ref for entry in function_registry.entries if entry.substrait.kind == SubstraitMappingKind.ExtensionFunction]
