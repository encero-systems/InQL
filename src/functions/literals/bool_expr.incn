"""
Boolean literal expression helper.

`bool_expr` is the typed literal spelling for boolean scalar values and is also used by predicate constants.
"""

from function_registry import (
    FunctionClass,
    FunctionLifecycle,
    FunctionNullBehavior,
    deterministic_spec,
    rewrite_mapping,
    v0_1,
)
from functions.registry import register_function
from projection_builders import BoolLiteralExpr, bool_expr as bool_expr_builder


@register_function(deterministic_spec(
    function_class=FunctionClass.Scalar,
    lifecycle=FunctionLifecycle(since=v0_1, changed=[], deprecated=None),
    null_behavior=FunctionNullBehavior.NonNullLiteral,
    substrait=rewrite_mapping("typed boolean literal expression"),
))
pub def bool_expr(value: bool) -> BoolLiteralExpr:
    """
    Build a boolean literal expression.

    Examples:
        literal_true = bool_expr(true)

    Parameters:
        value: Boolean value to embed in the expression tree.
    """
    return bool_expr_builder(value)


module tests:
    from projection_builders import ColumnExprKind, column_expr_kind
    def test_bool_expr_uses_structural_bool_literal() -> None:
        assert column_expr_kind(bool_expr(true)) == ColumnExprKind.BoolLiteral
