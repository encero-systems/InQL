"""Shared input normalization for date and time helpers."""

from projection_builders import ColumnExpr, int_expr


pub type IntColumn = Union[ColumnExpr, int]


pub def integer_component_expr(value: IntColumn) -> ColumnExpr:
    """Return one integer component as a scalar expression."""
    match value:
        int(number) => return int_expr(number)
        expr => return expr
