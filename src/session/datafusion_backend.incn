@derive(Clone)
enum DataFusionSourceRegistration(str):
    """DataFusion adapter registration path for one portable source format."""

    Csv = "csv"
    Parquet = "parquet"
    Arrow = "arrow"


@derive(Clone)
model MaterializedGeneratorRelation:
    """One generator relation that must be bridged through a DataFusion temp view for execution."""

    path: str
    rel: Rel
    extension: ExtensionSingleRel


@derive(Clone)
model MaterializedWindowRelation:
    """One nested window relation that must be bridged through a DataFusion temp view for execution."""

    path: str
    rel: Rel
    window_rel: ConsistentPartitionWindowRel
    output_columns: list[str]


model RelationChildPath:
    """One direct relation child paired with its materialization traversal path."""

    rel: Rel
    path: str


model PendingWindowRelation:
    """One window relation peeled from a nested window stack for sequential execution."""

    window_rel: ConsistentPartitionWindowRel
    input_columns: list[str]
    output_columns: list[str]


pub async def datafusion_execute_async(
    registrations: list[BackendRegistration],
    plan: Plan,
) -> Result[None, BackendError]:
    """Execute one Substrait plan via DataFusion and discard collected rows."""
    ctx = SessionContext.new()
    register_common_scalar_udfs(ctx.clone())
    register_format_udfs(ctx.clone())
    await _register_sources(ctx, registrations)?

    df = await _dataframe_from_plan(ctx, plan)?
    match await df.collect():
        Ok(_) => return Ok(None)
        Err(err) => return Err(backend_error(BackendErrorKind.BackendExecutionError, err.to_string()))


pub async def datafusion_collect_materialization_async(
    registrations: list[BackendRegistration],
    plan: Plan,
) -> Result[DataFrameMaterialization, BackendError]:
    """Execute one Substrait plan via DataFusion and return structured DataFrame materialization."""
    ctx = SessionContext.new()
    resolved_columns = root_names(plan.clone())
    register_common_scalar_udfs(ctx.clone())
    register_format_udfs(ctx.clone())
    await _register_sources(ctx, registrations)?

    df = await _dataframe_from_plan(ctx, plan)?
    match await df.clone().collect():
        Ok(batches) => match await df.to_string():
            Ok(rendered) =>
                mut row_count = 0
                for batch in batches:
                    row_count += _rust_usize_to_int(batch.num_rows())?
                return Ok(
                    DataFrameMaterialization(
                        resolved_columns=resolved_columns,
                        row_count=row_count,
                        preview_text=rendered,
                    ),
                )
            Err(err) => return Err(backend_error(BackendErrorKind.BackendExecutionError, err.to_string()))

        Err(err) => return Err(backend_error(BackendErrorKind.BackendExecutionError, err.to_string()))


pub async def datafusion_write_csv_async(
    registrations: list[BackendRegistration],
    plan: Plan,
    uri: str,
) -> Result[None, BackendError]:
    """Execute one plan and write result rows to a CSV sink URI via DataFusion."""
    ctx = SessionContext.new()
    register_common_scalar_udfs(ctx.clone())
    register_format_udfs(ctx.clone())
    await _register_sources(ctx, registrations)?

    df = await _dataframe_from_plan(ctx, plan)?
    match await df.write_csv(uri, DataFrameWriteOptions.new(), None):
        Ok(_) => return Ok(None)
        Err(err) => return Err(backend_error(BackendErrorKind.BackendSinkError, err.to_string()))


pub async def datafusion_write_parquet_async(
    registrations: list[BackendRegistration],
    plan: Plan,
    uri: str,
) -> Result[None, BackendError]:
    """Execute one plan and write result rows to a Parquet sink URI via DataFusion."""
    ctx = SessionContext.new()
    register_common_scalar_udfs(ctx.clone())
    register_format_udfs(ctx.clone())
    await _register_sources(ctx, registrations)?

    df = await _dataframe_from_plan(ctx, plan)?
    match await df.write_parquet(uri, DataFrameWriteOptions.new(), None):
        Ok(_) => return Ok(None)
        Err(err) => return Err(backend_error(BackendErrorKind.BackendSinkError, err.to_string()))


async def _dataframe_from_plan(ctx: SessionContext, plan: Plan) -> Result[RustDataFrame, BackendError]:
    """Build a DataFusion DataFrame, including InQL-owned relation bridges."""
    root = root_rel(plan.clone())
    match _window_rel(root.clone()):
        Some(window_rel) => return await _dataframe_from_window_rel(ctx, window_rel, root_names(plan.clone()))
        None => return await _dataframe_from_non_window_plan(ctx, plan)


async def _dataframe_from_non_window_plan(ctx: SessionContext, plan: Plan) -> Result[RustDataFrame, BackendError]:
    """Build a DataFusion DataFrame for plans that do not have a window root."""
    root = root_rel(plan.clone())
    # DataFusion's stock Substrait consumer cannot plan InQL generator ExtensionSingleRel nodes. Root generators can
    # execute directly; nested generators are first materialized and then replaced by execution-only temp reads.
    match _generator_extension(root):
        Some(extension) => return await _dataframe_from_generator_extension(ctx, extension)
        None =>
            mut rewritten_root = root_rel(plan.clone())
            mut rewritten_plan = plan.clone()
            materializations = _collect_materialized_generator_relations(rewritten_root.clone(), "root")
            if len(materializations) > 0:
                for materialization in materializations:
                    # The path key must match the later rewrite traversal so each temp read targets the exact generated
                    # subtree that was collected here.
                    table_name = _materialized_generator_table_name(materialization.path)
                    df = await _dataframe_from_generator_extension(ctx.clone(), materialization.extension)?
                    await _register_materialized_dataframe(ctx.clone(), table_name, df)?
                rewritten_root = _replace_materialized_generator_relations(rewritten_root, "root")
                rewritten_plan = plan_from_root_relation(rewritten_root.clone(), root_names(plan.clone()))

            window_materializations = _collect_materialized_window_relations(rewritten_root.clone(), "root")
            if len(window_materializations) == 0:
                return await _dataframe_from_standard_plan(ctx, rewritten_plan)

            for materialization in window_materializations:
                table_name = _materialized_window_table_name(materialization.path)
                df = await _dataframe_from_window_rel(
                    ctx.clone(),
                    materialization.window_rel,
                    materialization.output_columns,
                )?
                await _register_materialized_dataframe(ctx.clone(), table_name, df)?
            rewritten_root = _replace_materialized_window_relations(rewritten_root, "root")
            rewritten_plan = plan_from_root_relation(rewritten_root, root_names(plan))
            return await _dataframe_from_standard_plan(ctx, rewritten_plan)


async def _dataframe_from_plan_with_window_materialization(
    ctx: SessionContext,
    plan: Plan,
) -> Result[RustDataFrame, BackendError]:
    """Build a DataFrame for an adapter-local plan after bridging nested window relations."""
    root = root_rel(plan.clone())
    match _window_rel(root.clone()):
        Some(window_rel) => return await _dataframe_from_window_rel(ctx, window_rel, root_names(plan.clone()))
        None =>
            window_materializations = _collect_materialized_window_relations(root.clone(), "root")
            if len(window_materializations) == 0:
                return await _dataframe_from_standard_plan(ctx, plan)
            for materialization in window_materializations:
                table_name = _materialized_window_table_name(materialization.path)
                df = await _dataframe_from_window_rel(
                    ctx.clone(),
                    materialization.window_rel,
                    materialization.output_columns,
                )?
                await _register_materialized_dataframe(ctx.clone(), table_name, df)?
            rewritten_root = _replace_materialized_window_relations(root, "root")
            rewritten_plan = plan_from_root_relation(rewritten_root, root_names(plan))
            return await _dataframe_from_standard_plan(ctx, rewritten_plan)


async def _dataframe_from_standard_plan(ctx: SessionContext, plan: Plan) -> Result[RustDataFrame, BackendError]:
    """Build a DataFusion DataFrame through the stock Substrait consumer."""
    consumer_plan = _consumer_plan_from_current_plan(plan)?
    state = ctx.state()
    match await from_substrait_plan(state, consumer_plan):
        Ok(logical_plan) => match await ctx.execute_logical_plan(logical_plan):
            Ok(df) => return Ok(df)
            Err(err) => return Err(backend_error(BackendErrorKind.BackendExecutionError, err.to_string()))

        Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))


async def _dataframe_from_window_rel(
    ctx: SessionContext,
    window_rel: ConsistentPartitionWindowRel,
    output_columns: list[str],
) -> Result[RustDataFrame, BackendError]:
    """Build a DataFusion DataFrame for one or more nested Substrait window relations."""
    mut pending_windows: list[PendingWindowRelation] = []
    mut current_window = window_rel
    mut current_output_columns = output_columns
    mut child = _window_input_rel(current_window.clone())?
    while true:
        child_columns = relation_output_columns(child.clone())
        pending_windows.append(
            PendingWindowRelation(
                window_rel=current_window.clone(),
                input_columns=child_columns.clone(),
                output_columns=current_output_columns.clone(),
            ),
        )
        match _window_rel(child.clone()):
            Some(next_window) =>
                current_window = next_window
                current_output_columns = child_columns
                child = _window_input_rel(current_window.clone())?
            None =>
                base_plan = plan_from_root_relation(child, child_columns)
                mut current_df = await _dataframe_from_standard_plan(ctx.clone(), base_plan)?
                mut idx = len(pending_windows)
                while idx > 0:
                    idx -= 1
                    pending = pending_windows[idx]
                    current_df = _dataframe_from_window_api(
                        ctx.clone(),
                        current_df,
                        pending.input_columns,
                        pending.window_rel,
                        pending.output_columns,
                    )?
                return Ok(current_df)


def _dataframe_from_window_api(
    ctx: SessionContext,
    child_df: RustDataFrame,
    child_columns: list[str],
    window_rel: ConsistentPartitionWindowRel,
    output_columns: list[str],
) -> Result[RustDataFrame, BackendError]:
    """Apply one InQL window relation through DataFusion's typed expression API."""
    select_exprs = _window_select_exprs(ctx, child_columns, window_rel, output_columns)?
    match child_df.select(select_exprs):
        Ok(df) => return Ok(df)
        Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))


async def _dataframe_from_generator_extension(
    ctx: SessionContext,
    extension: ExtensionSingleRel,
) -> Result[RustDataFrame, BackendError]:
    """Build a DataFusion DataFrame for one InQL generator relation-extension root."""
    payload = _decode_generator_payload(extension.clone())?
    child = _generator_input_rel(extension.clone())?
    child_columns = relation_output_columns(child.clone())
    # Generator arguments are ordinary InQL scalar expressions. Project them into stable temp columns first so the
    # DataFusion unnest API can operate on columns rather than on arbitrary Substrait expressions.
    temp_columns = _generator_temp_columns(len(payload.arguments))
    projected_names = _generator_projected_root_names(
        child_columns,
        temp_columns.clone(),
        extension.clone(),
        payload.clone(),
    )?
    projected_rel = project_rel_with_expressions(child, payload.arguments)
    projected_plan = plan_from_root_relation(projected_rel, projected_names)
    projected_df = await _dataframe_from_plan_with_window_materialization(ctx, projected_plan)?
    return _apply_generator_dataframe_shape(projected_df, extension, payload, temp_columns)


def _collect_materialized_generator_relations(rel: Rel, path: str) -> list[MaterializedGeneratorRelation]:
    """Return generator relations nested below a non-generator root."""
    match _generator_extension(rel.clone()):
        Some(extension) => return [MaterializedGeneratorRelation(path=path, rel=rel, extension=extension)]
        None => return _collect_materialized_generator_children(rel, path)


def _collect_materialized_generator_children(rel: Rel, path: str) -> list[MaterializedGeneratorRelation]:
    """Return generator relations below direct children of one relation."""
    # This traversal must stay in lock-step with _replace_materialized_generator_children; the path segments are the
    # shared key between the discovery pass and the execution-plan rewrite pass.
    mut materializations: list[MaterializedGeneratorRelation] = []
    for child_path in _materialization_child_paths(rel, path):
        _extend_materializations(
            materializations,
            _collect_materialized_generator_relations(child_path.rel, child_path.path),
        )
    return materializations


def _materialization_child_paths(rel: Rel, path: str) -> list[RelationChildPath]:
    """Return direct relation children with path suffixes shared by materialization passes."""
    match rel.rel_type.clone():
        Some(RelType.Filter(filter_rel)) =>
            filter = filter_rel.as_ref().clone()
            if let Some(child) = filter.input:
                return [RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_filter")]
            return []
        Some(RelType.Project(project_rel)) =>
            project = project_rel.as_ref().clone()
            if let Some(child) = project.input:
                return [RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_project")]
            return []
        Some(RelType.Join(join_rel)) =>
            join = join_rel.as_ref().clone()
            mut children: list[RelationChildPath] = []
            if let Some(child) = join.left:
                children.append(RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_join_left"))
            if let Some(child) = join.right:
                children.append(RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_join_right"))
            return children
        Some(RelType.Cross(cross_rel)) =>
            cross = cross_rel.as_ref().clone()
            mut children: list[RelationChildPath] = []
            if let Some(child) = cross.left:
                children.append(RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_cross_left"))
            if let Some(child) = cross.right:
                children.append(RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_cross_right"))
            return children
        Some(RelType.Aggregate(aggregate_rel)) =>
            aggregate = aggregate_rel.as_ref().clone()
            if let Some(child) = aggregate.input:
                return [RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_aggregate")]
            return []
        Some(RelType.Sort(sort_rel)) =>
            sort = sort_rel.as_ref().clone()
            if let Some(child) = sort.input:
                return [RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_sort")]
            return []
        Some(RelType.Fetch(fetch_rel)) =>
            fetch = fetch_rel.as_ref().clone()
            if let Some(child) = fetch.input:
                return [RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_fetch")]
            return []
        Some(RelType.Set(set_rel)) =>
            mut children: list[RelationChildPath] = []
            for idx, input in enumerate(set_rel.inputs):
                children.append(RelationChildPath(rel=input, path=f"{path}_set_{idx}"))
            return children
        Some(RelType.ExtensionSingle(extension_rel)) =>
            extension = extension_rel.as_ref().clone()
            if let Some(child) = extension.input:
                return [RelationChildPath(rel=child.as_ref().clone(), path=f"{path}_extension")]
            return []
        _ => return []


def _extend_materializations(
    mut target: list[MaterializedGeneratorRelation],
    values: list[MaterializedGeneratorRelation],
) -> None:
    """Append collected materialization records while satisfying list clone requirements."""
    for value in values:
        target.append(value.clone())
    return


def _replace_materialized_generator_relations(rel: Rel, path: str) -> Rel:
    """Replace previously materialized generator relation nodes with temp-view reads."""
    # This is an adapter-only rewrite. The InQL semantic plan remains a generator extension relation; only DataFusion's
    # execution plan sees the temporary table scan.
    match _generator_extension(rel.clone()):
        Some(_) => return read_named_table_rel(_materialized_generator_table_name(path))
        None => return _replace_materialized_generator_children(rel, path)


def _replace_materialized_generator_children(rel: Rel, path: str) -> Rel:
    """Recursively rewrite generator-bearing children while preserving the surrounding relation node."""
    # Keep this dispatcher shallow. The relation-specific helpers own proto reconstruction details; this function owns
    # only the traversal choice.
    match rel.rel_type.clone():
        Some(RelType.Filter(filter_rel)) =>
            return _replace_filter_generator_child(rel, filter_rel.as_ref().clone(), path)
        Some(RelType.Project(project_rel)) =>
            return _replace_project_generator_child(rel, project_rel.as_ref().clone(), path)
        Some(RelType.Join(join_rel)) => return _replace_join_generator_children(join_rel.as_ref().clone(), path)
        Some(RelType.Cross(cross_rel)) => return _replace_cross_generator_children(cross_rel.as_ref().clone(), path)
        Some(RelType.Aggregate(aggregate_rel)) =>
            return _replace_aggregate_generator_child(rel, aggregate_rel.as_ref().clone(), path)
        Some(RelType.Sort(sort_rel)) => return _replace_sort_generator_child(rel, sort_rel.as_ref().clone(), path)
        Some(RelType.Fetch(fetch_rel)) => return _replace_fetch_generator_child(rel, fetch_rel.as_ref().clone(), path)
        Some(RelType.Set(set_rel)) => return _replace_set_generator_children(set_rel, path)
        Some(RelType.ExtensionSingle(extension_rel)) =>
            return _replace_extension_generator_child(rel, extension_rel.as_ref().clone(), path)
        _ => return rel


def _rewritten_generator_child(child: Box[Rel], path: str) -> Box[Rel]:
    """Return one boxed child after replacing any materialized generator subtree beneath it."""
    return Box.new(_replace_materialized_generator_relations(child.as_ref().clone(), path))


def _replace_filter_generator_child(original: Rel, filter: FilterRel, path: str) -> Rel:
    """Rebuild a FilterRel with its input child rewritten when present."""
    match filter.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Filter(
                        Box.new(
                            FilterRel(
                                common=filter.common,
                                input=Some(_rewritten_generator_child(child, f"{path}_filter")),
                                condition=filter.condition,
                                advanced_extension=filter.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_project_generator_child(original: Rel, project: ProjectRel, path: str) -> Rel:
    """Rebuild a ProjectRel with its input child rewritten when present."""
    match project.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Project(
                        Box.new(
                            ProjectRel(
                                common=project.common,
                                input=Some(_rewritten_generator_child(child, f"{path}_project")),
                                expressions=project.expressions,
                                advanced_extension=project.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_join_generator_children(join: JoinRel, path: str) -> Rel:
    """Rebuild a JoinRel with rewritten left and right inputs."""
    mut left = join.left
    mut right = join.right
    if let Some(child) = left:
        left = Some(_rewritten_generator_child(child, f"{path}_join_left"))
    if let Some(child) = right:
        right = Some(_rewritten_generator_child(child, f"{path}_join_right"))
    # Public InQL joins currently lower only inner joins; preserve that contract while rewriting child inputs.
    return Rel(
        rel_type=Some(
            RelType.Join(
                Box.new(
                    JoinRel(
                        common=join.common,
                        left=left,
                        right=right,
                        expression=join.expression,
                        post_join_filter=join.post_join_filter,
                        type=JoinType.Inner.into(),
                        advanced_extension=join.advanced_extension,
                    ),
                ),
            ),
        ),
    )


def _replace_cross_generator_children(cross: CrossRel, path: str) -> Rel:
    """Rebuild a CrossRel with rewritten left and right inputs."""
    mut left = cross.left
    mut right = cross.right
    if let Some(child) = left:
        left = Some(_rewritten_generator_child(child, f"{path}_cross_left"))
    if let Some(child) = right:
        right = Some(_rewritten_generator_child(child, f"{path}_cross_right"))
    return Rel(
        rel_type=Some(
            RelType.Cross(
                Box.new(
                    CrossRel(common=cross.common, left=left, right=right, advanced_extension=cross.advanced_extension),
                ),
            ),
        ),
    )


def _replace_aggregate_generator_child(original: Rel, aggregate: AggregateRel, path: str) -> Rel:
    """Rebuild an AggregateRel with its input child rewritten when present."""
    match aggregate.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Aggregate(
                        Box.new(
                            AggregateRel(
                                common=aggregate.common,
                                input=Some(_rewritten_generator_child(child, f"{path}_aggregate")),
                                groupings=aggregate.groupings,
                                measures=aggregate.measures,
                                grouping_expressions=aggregate.grouping_expressions,
                                advanced_extension=aggregate.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_sort_generator_child(original: Rel, sort: SortRel, path: str) -> Rel:
    """Rebuild a SortRel with its input child rewritten when present."""
    match sort.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Sort(
                        Box.new(
                            SortRel(
                                common=sort.common,
                                input=Some(_rewritten_generator_child(child, f"{path}_sort")),
                                sorts=sort.sorts,
                                advanced_extension=sort.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_fetch_generator_child(original: Rel, fetch: FetchRel, path: str) -> Rel:
    """Rebuild a FetchRel with its input child rewritten when present."""
    match fetch.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Fetch(
                        Box.new(
                            FetchRel(
                                common=fetch.common,
                                input=Some(_rewritten_generator_child(child, f"{path}_fetch")),
                                advanced_extension=fetch.advanced_extension,
                                offset_mode=fetch.offset_mode,
                                count_mode=fetch.count_mode,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_set_generator_children(set_rel: SetRel, path: str) -> Rel:
    """Rebuild a SetRel with every input child rewritten."""
    mut inputs: list[Rel] = []
    for idx, input in enumerate(set_rel.inputs):
        rewritten = _replace_materialized_generator_relations(input, f"{path}_set_{idx}")
        inputs.append(rewritten.clone())
    return Rel(
        rel_type=Some(
            RelType.Set(
                SetRel(
                    common=set_rel.common,
                    inputs=inputs,
                    op=set_rel.op,
                    advanced_extension=set_rel.advanced_extension,
                ),
            ),
        ),
    )


def _replace_extension_generator_child(original: Rel, extension: ExtensionSingleRel, path: str) -> Rel:
    """Rebuild a non-generator ExtensionSingleRel with its input child rewritten when present."""
    match extension.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.ExtensionSingle(
                        Box.new(
                            ExtensionSingleRel(
                                common=extension.common,
                                input=Some(_rewritten_generator_child(child, f"{path}_extension")),
                                detail=extension.detail,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _materialized_generator_table_name(path: str) -> str:
    """Return the internal DataFusion temp-view name for one materialized generator relation path."""
    return f"__inql_generator_materialized_{path}"


def _collect_materialized_window_relations(rel: Rel, path: str) -> list[MaterializedWindowRelation]:
    """Return window relations nested below a non-window root."""
    match _window_rel(rel.clone()):
        Some(window_rel) =>
            return [MaterializedWindowRelation(
                path=path,
                rel=rel.clone(),
                window_rel=window_rel,
                output_columns=relation_output_columns(rel),
            )]
        None => return _collect_materialized_window_children(rel, path)


def _collect_materialized_window_children(rel: Rel, path: str) -> list[MaterializedWindowRelation]:
    """Return window relations below direct children of one relation."""
    mut materializations: list[MaterializedWindowRelation] = []
    for child_path in _materialization_child_paths(rel, path):
        _extend_window_materializations(
            materializations,
            _collect_materialized_window_relations(child_path.rel, child_path.path),
        )
    return materializations


def _extend_window_materializations(
    mut target: list[MaterializedWindowRelation],
    values: list[MaterializedWindowRelation],
) -> None:
    """Append collected window materialization records while satisfying list clone requirements."""
    for value in values:
        target.append(value.clone())
    return


def _replace_materialized_window_relations(rel: Rel, path: str) -> Rel:
    """Replace previously materialized window relation nodes with temp-view reads."""
    match _window_rel(rel.clone()):
        Some(_) => return read_named_table_rel(_materialized_window_table_name(path))
        None => return _replace_materialized_window_children(rel, path)


def _replace_materialized_window_children(rel: Rel, path: str) -> Rel:
    """Recursively rewrite window-bearing children while preserving the surrounding relation node."""
    match rel.rel_type.clone():
        Some(RelType.Filter(filter_rel)) => return _replace_filter_window_child(rel, filter_rel.as_ref().clone(), path)
        Some(RelType.Project(project_rel)) =>
            return _replace_project_window_child(rel, project_rel.as_ref().clone(), path)
        Some(RelType.Join(join_rel)) => return _replace_join_window_children(join_rel.as_ref().clone(), path)
        Some(RelType.Cross(cross_rel)) => return _replace_cross_window_children(cross_rel.as_ref().clone(), path)
        Some(RelType.Aggregate(aggregate_rel)) =>
            return _replace_aggregate_window_child(rel, aggregate_rel.as_ref().clone(), path)
        Some(RelType.Sort(sort_rel)) => return _replace_sort_window_child(rel, sort_rel.as_ref().clone(), path)
        Some(RelType.Fetch(fetch_rel)) => return _replace_fetch_window_child(rel, fetch_rel.as_ref().clone(), path)
        Some(RelType.Set(set_rel)) => return _replace_set_window_children(set_rel, path)
        Some(RelType.ExtensionSingle(extension_rel)) =>
            return _replace_extension_window_child(rel, extension_rel.as_ref().clone(), path)
        _ => return rel


def _rewritten_window_child(child: Box[Rel], path: str) -> Box[Rel]:
    """Return one boxed child after replacing any materialized window subtree beneath it."""
    return Box.new(_replace_materialized_window_relations(child.as_ref().clone(), path))


def _replace_filter_window_child(original: Rel, filter: FilterRel, path: str) -> Rel:
    """Rebuild a FilterRel with its input child rewritten when present."""
    match filter.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Filter(
                        Box.new(
                            FilterRel(
                                common=filter.common,
                                input=Some(_rewritten_window_child(child, f"{path}_filter")),
                                condition=filter.condition,
                                advanced_extension=filter.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_project_window_child(original: Rel, project: ProjectRel, path: str) -> Rel:
    """Rebuild a ProjectRel with its input child rewritten when present."""
    match project.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Project(
                        Box.new(
                            ProjectRel(
                                common=project.common,
                                input=Some(_rewritten_window_child(child, f"{path}_project")),
                                expressions=project.expressions,
                                advanced_extension=project.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_join_window_children(join: JoinRel, path: str) -> Rel:
    """Rebuild a JoinRel with rewritten left and right inputs."""
    mut left = join.left
    mut right = join.right
    if let Some(child) = left:
        left = Some(_rewritten_window_child(child, f"{path}_join_left"))
    if let Some(child) = right:
        right = Some(_rewritten_window_child(child, f"{path}_join_right"))
    return Rel(
        rel_type=Some(
            RelType.Join(
                Box.new(
                    JoinRel(
                        common=join.common,
                        left=left,
                        right=right,
                        expression=join.expression,
                        post_join_filter=join.post_join_filter,
                        type=JoinType.Inner.into(),
                        advanced_extension=join.advanced_extension,
                    ),
                ),
            ),
        ),
    )


def _replace_cross_window_children(cross: CrossRel, path: str) -> Rel:
    """Rebuild a CrossRel with rewritten left and right inputs."""
    mut left = cross.left
    mut right = cross.right
    if let Some(child) = left:
        left = Some(_rewritten_window_child(child, f"{path}_cross_left"))
    if let Some(child) = right:
        right = Some(_rewritten_window_child(child, f"{path}_cross_right"))
    return Rel(
        rel_type=Some(
            RelType.Cross(
                Box.new(
                    CrossRel(common=cross.common, left=left, right=right, advanced_extension=cross.advanced_extension),
                ),
            ),
        ),
    )


def _replace_aggregate_window_child(original: Rel, aggregate: AggregateRel, path: str) -> Rel:
    """Rebuild an AggregateRel with its input child rewritten when present."""
    match aggregate.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Aggregate(
                        Box.new(
                            AggregateRel(
                                common=aggregate.common,
                                input=Some(_rewritten_window_child(child, f"{path}_aggregate")),
                                groupings=aggregate.groupings,
                                measures=aggregate.measures,
                                grouping_expressions=aggregate.grouping_expressions,
                                advanced_extension=aggregate.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_sort_window_child(original: Rel, sort: SortRel, path: str) -> Rel:
    """Rebuild a SortRel with its input child rewritten when present."""
    match sort.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Sort(
                        Box.new(
                            SortRel(
                                common=sort.common,
                                input=Some(_rewritten_window_child(child, f"{path}_sort")),
                                sorts=sort.sorts,
                                advanced_extension=sort.advanced_extension,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_fetch_window_child(original: Rel, fetch: FetchRel, path: str) -> Rel:
    """Rebuild a FetchRel with its input child rewritten when present."""
    match fetch.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.Fetch(
                        Box.new(
                            FetchRel(
                                common=fetch.common,
                                input=Some(_rewritten_window_child(child, f"{path}_fetch")),
                                advanced_extension=fetch.advanced_extension,
                                offset_mode=fetch.offset_mode,
                                count_mode=fetch.count_mode,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _replace_set_window_children(set_rel: SetRel, path: str) -> Rel:
    """Rebuild a SetRel with every input child rewritten."""
    mut inputs: list[Rel] = []
    for idx, input in enumerate(set_rel.inputs):
        rewritten = _replace_materialized_window_relations(input, f"{path}_set_{idx}")
        inputs.append(rewritten.clone())
    return Rel(
        rel_type=Some(
            RelType.Set(
                SetRel(
                    common=set_rel.common,
                    inputs=inputs,
                    op=set_rel.op,
                    advanced_extension=set_rel.advanced_extension,
                ),
            ),
        ),
    )


def _replace_extension_window_child(original: Rel, extension: ExtensionSingleRel, path: str) -> Rel:
    """Rebuild an ExtensionSingleRel with its input child rewritten when present."""
    match extension.input:
        Some(child) =>
            return Rel(
                rel_type=Some(
                    RelType.ExtensionSingle(
                        Box.new(
                            ExtensionSingleRel(
                                common=extension.common,
                                input=Some(_rewritten_window_child(child, f"{path}_extension")),
                                detail=extension.detail,
                            ),
                        ),
                    ),
                ),
            )
        None => return original


def _materialized_window_table_name(path: str) -> str:
    """Return the internal DataFusion temp-view name for one materialized window relation path."""
    return f"__inql_window_materialized_{path}"


async def _register_materialized_dataframe(
    ctx: SessionContext,
    table_name: str,
    df: RustDataFrame,
) -> Result[None, BackendError]:
    """Collect one bridged DataFrame into a MemTable so Substrait reads see concrete table scans."""
    match await df.clone().collect():
        Ok(batches) =>
            if len(batches) == 0:
                # Empty generator output still needs a registered relation for the rewritten temp ReadRel to resolve.
                match ctx.register_table(f"{table_name}", df.into_view()):
                    Ok(_) => return Ok(None)
                    Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))
            _register_materialized_schema_from_batch(f"{table_name}", batches[0])
            schema = batches[0].schema()
            # Non-empty outputs are frozen into a MemTable so the stock consumer reads a concrete table instead of an
            # InQL-specific generator extension relation.
            match MemTable.try_new(schema, [batches]):
                Ok(table) =>
                    match ctx.register_table(f"{table_name}", Arc.new(table)):
                        Ok(_) => return Ok(None)
                        Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))
                Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))
        Err(err) => return Err(backend_error(BackendErrorKind.BackendExecutionError, err.to_string()))


def _register_materialized_schema_from_batch(table_name: str, batch: RecordBatch) -> None:
    """Mirror one materialized DataFusion schema into the Substrait named-table schema registry."""
    # The rewritten ReadRel uses the same schema inference path as user-registered tables, so mirror DataFusion's batch
    # schema into that registry before the temporary plan is lowered.
    schema = batch.schema()
    mut columns: list[RowColumnSpec] = []
    for field in schema.fields():
        columns.append(
            RowColumnSpec(
                name=field.name().to_string(),
                kind=_substrait_kind_for_arrow_type_name(field.data_type().to_string()),
                nullable=field.is_nullable(),
            ),
        )
    register_named_table_schema(table_name, columns)
    return


def _substrait_kind_for_arrow_type_name(type_name: str) -> SubstraitPrimitiveKind:
    """Map the current DataFusion primitive output type names into InQL's minimal Substrait schema kinds."""
    if type_name == "Int64" or type_name == "Int32" or type_name == "UInt64" or type_name == "UInt32":
        return SubstraitPrimitiveKind.I64
    if type_name == "Float64" or type_name == "Float32":
        return SubstraitPrimitiveKind.F64
    if type_name == "Boolean":
        return SubstraitPrimitiveKind.Bool
    if type_name.contains("Timestamp"):
        return SubstraitPrimitiveKind.Timestamp
    return SubstraitPrimitiveKind.String


def _generator_projected_root_names(
    child_columns: list[str],
    temp_columns: list[str],
    extension: ExtensionSingleRel,
    payload: GeneratorExtensionPayload,
) -> Result[list[str], BackendError]:
    """Return temporary root names, including nested struct field names when Substrait requires them."""
    mut projected_names = _extended_columns(child_columns, temp_columns)
    match extension.detail:
        Some(detail) =>
            if _generator_expands_struct(detail.type_url):
                # Struct-expanding generators need field aliases present before DataFusion unnests the temporary struct
                # column; otherwise the consumer cannot name the generated fields deterministically.
                for output_column in payload.output_columns:
                    projected_names.append(f"{output_column}")
            return Ok(projected_names)
        None =>
            return Err(backend_error(BackendErrorKind.BackendPlanningError, "generator extension is missing detail"))


def _generator_extension(rel: Rel) -> Option[ExtensionSingleRel]:
    """Return the root generator extension relation when the plan root is an InQL generator."""
    match rel.rel_type:
        Some(RelType.ExtensionSingle(extension)) =>
            if let Some(detail) = extension.detail.clone():
                if is_generator_extension_uri(detail.type_url):
                    return Some(extension.as_ref().clone())
            return None
        _ => return None


def _window_rel(rel: Rel) -> Option[ConsistentPartitionWindowRel]:
    """Return the root window relation when the plan root is an InQL analytic window."""
    match rel.rel_type:
        Some(RelType.Window(window_rel)) => return Some(window_rel.as_ref().clone())
        _ => return None


def _window_input_rel(window_rel: ConsistentPartitionWindowRel) -> Result[Rel, BackendError]:
    """Return the child relation for one window relation."""
    match window_rel.input:
        Some(child) => return Ok(child.as_ref().clone())
        None => return Err(backend_error(BackendErrorKind.BackendPlanningError, "window relation is missing input"))


def _window_select_exprs(
    ctx: SessionContext,
    input_columns: list[str],
    window_rel: ConsistentPartitionWindowRel,
    output_columns: list[str],
) -> Result[list[DataFusionExpr], BackendError]:
    """Build the typed DataFusion projection for one lowered InQL window relation."""
    final_columns = _window_final_columns(input_columns.clone(), window_rel.clone(), output_columns)
    return Ok(
        [_window_select_expr(ctx.clone(), input_columns.clone(), window_rel.clone(), output_column)? for output_column in final_columns],
    )


def _window_select_expr(
    ctx: SessionContext,
    input_columns: list[str],
    window_rel: ConsistentPartitionWindowRel,
    output_column: str,
) -> Result[DataFusionExpr, BackendError]:
    """Build one typed DataFusion select expression for a final window output column."""
    match _window_function_for_output(window_rel.clone(), output_column):
        Some(window_function) =>
            function_name = window_function_name_from_anchor(window_function.function_reference)
            expr = _datafusion_window_expr(ctx, window_function, input_columns, window_rel)?
            return Ok(_datafusion_alias(_window_output_expr(function_name, expr), output_column))
        None => return Ok(_datafusion_column(output_column))


def _window_final_columns(
    input_columns: list[str],
    window_rel: ConsistentPartitionWindowRel,
    output_columns: list[str],
) -> list[str]:
    """Return requested root output columns, or derive add-only output columns when roots are absent."""
    if len(output_columns) > 0:
        return output_columns
    mut columns = input_columns
    for window_function in window_rel.window_functions:
        columns.append(_window_function_output_name(window_function.options))
    return columns


def _window_function_for_output(
    window_rel: ConsistentPartitionWindowRel,
    output_name: str,
) -> Option[WindowRelFunction]:
    """Return the lowered window function that owns one output alias."""
    for window_function in window_rel.window_functions:
        if _window_function_output_name(window_function.options) == output_name:
            return Some(window_function)
    return None


def _datafusion_window_expr(
    ctx: SessionContext,
    window_function: WindowRelFunction,
    input_columns: list[str],
    window_rel: ConsistentPartitionWindowRel,
) -> Result[DataFusionExpr, BackendError]:
    """Translate one Substrait window function into DataFusion's typed expression model."""
    function_name = window_function_name_from_anchor(window_function.function_reference)
    return Ok(
        DataFusionExpr.WindowFunction(
            Box.new(
                DataFusionWindowFunction(
                    fun=_datafusion_window_function_definition(ctx.clone(), function_name)?,
                    params=DataFusionWindowFunctionParams(
                        args=_datafusion_window_arguments(ctx.clone(), window_function.clone(), input_columns.clone())?,
                        partition_by=[_datafusion_expr(ctx.clone(), expr, input_columns.clone())? for expr in window_rel.partition_expressions],
                        order_by=[_datafusion_sort(ctx.clone(), sort, input_columns.clone())? for sort in window_rel.sorts],
                        window_frame=_datafusion_window_frame(window_function, len(window_rel.sorts) > 0)?,
                        filter=None,
                        null_treatment=_datafusion_null_treatment(window_function.options),
                        distinct=_datafusion_window_distinct(window_function.invocation),
                    ),
                ),
            ),
        ),
    )


def _datafusion_window_arguments(
    ctx: SessionContext,
    window_function: WindowRelFunction,
    input_columns: list[str],
) -> Result[list[DataFusionExpr], BackendError]:
    """Translate Substrait window arguments into DataFusion expressions."""
    function_name = window_function_name_from_anchor(window_function.function_reference)
    if function_name == "count" and len(window_function.arguments) == 0:
        return Ok([DataFusionExpr.Literal(ScalarValue.Int64(Some(1)), None)])
    return Ok(
        [_datafusion_function_argument(ctx.clone(), argument, input_columns.clone())? for argument in window_function.arguments],
    )


def _datafusion_function_argument(
    ctx: SessionContext,
    argument: FunctionArgument,
    input_columns: list[str],
) -> Result[DataFusionExpr, BackendError]:
    """Translate one value argument carried by a Substrait function call."""
    match argument.arg_type:
        Some(ArgType.Value(expr)) => return _datafusion_expr(ctx, expr, input_columns)
        _ =>
            return Err(
                backend_error(
                    BackendErrorKind.BackendPlanningError,
                    "window expression bridge only supports value arguments",
                ),
            )


def _datafusion_expr(
    ctx: SessionContext,
    expr: Expression,
    input_columns: list[str],
) -> Result[DataFusionExpr, BackendError]:
    """Translate Substrait scalar expressions needed by window arguments and boundaries."""
    field_index = field_index_from_expression(expr.clone())
    if field_index >= 0 and field_index < len(input_columns):
        return Ok(_datafusion_column(input_columns[field_index]))
    match expr.rex_type:
        Some(RexType.Literal(literal)) =>
            match literal.literal_type:
                Some(LiteralType.I64(value)) => return Ok(DataFusionExpr.Literal(ScalarValue.Int64(Some(value)), None))
                Some(LiteralType.Fp64(value)) =>
                    return Ok(DataFusionExpr.Literal(ScalarValue.Float64(Some(value)), None))
                Some(LiteralType.Boolean(value)) =>
                    return Ok(DataFusionExpr.Literal(ScalarValue.Boolean(Some(value)), None))
                Some(LiteralType.String(value)) =>
                    return Ok(DataFusionExpr.Literal(ScalarValue.Utf8(Some(f"{value}")), None))
                _ => pass
        Some(RexType.ScalarFunction(function)) =>
            return _datafusion_scalar_function_expr(ctx, function.function_reference, function.arguments, input_columns)
        _ => pass
    return Err(_unsupported_window_expr("window expression bridge cannot translate this scalar expression"))


def _datafusion_scalar_function_expr(
    ctx: SessionContext,
    function_reference: u32,
    arguments: list[FunctionArgument],
    input_columns: list[str],
) -> Result[DataFusionExpr, BackendError]:
    """Translate one registry-backed scalar function into DataFusion's typed expression model."""
    function_name = scalar_function_name_from_anchor(function_reference)
    rendered_args = _datafusion_function_arguments(ctx.clone(), arguments, input_columns)?
    match function_name:
        "add" => return _datafusion_binary_expr(DataFusionOperator.Plus, rendered_args)
        "subtract" => return _datafusion_binary_expr(DataFusionOperator.Minus, rendered_args)
        "multiply" => return _datafusion_binary_expr(DataFusionOperator.Multiply, rendered_args)
        "divide" => return _datafusion_binary_expr(DataFusionOperator.Divide, rendered_args)
        "modulus" => return _datafusion_binary_expr(DataFusionOperator.Modulo, rendered_args)
        "equal" => return _datafusion_binary_expr(DataFusionOperator.Eq, rendered_args)
        "not_equal" => return _datafusion_binary_expr(DataFusionOperator.NotEq, rendered_args)
        "gt" => return _datafusion_binary_expr(DataFusionOperator.Gt, rendered_args)
        "gte" => return _datafusion_binary_expr(DataFusionOperator.GtEq, rendered_args)
        "lt" => return _datafusion_binary_expr(DataFusionOperator.Lt, rendered_args)
        "lte" => return _datafusion_binary_expr(DataFusionOperator.LtEq, rendered_args)
        "equal_null" => return _datafusion_binary_expr(DataFusionOperator.IsNotDistinctFrom, rendered_args)
        "and" => return _datafusion_binary_expr(DataFusionOperator.And, rendered_args)
        "or" => return _datafusion_binary_expr(DataFusionOperator.Or, rendered_args)
        "not" | "negate" | "is_null" | "is_not_null" => return _datafusion_unary_expr(function_name, rendered_args)
        "between" => return _datafusion_between_expr(rendered_args)
        "abs" | "ceil" | "floor" | "round" => return _datafusion_common_math_expr(function_name, rendered_args)
        _ =>
            if let Ok(udf) = ctx.state().udf(function_name):
                return Ok(DataFusionExpr.ScalarFunction(DataFusionScalarFunction.new_udf(udf, rendered_args)))
            return Err(
                _unsupported_window_expr(
                    f"window expression bridge does not yet translate scalar function `{function_name}`",
                ),
            )


def _datafusion_function_arguments(
    ctx: SessionContext,
    arguments: list[FunctionArgument],
    input_columns: list[str],
) -> Result[list[DataFusionExpr], BackendError]:
    """Translate scalar function value arguments recursively."""
    return Ok([_datafusion_function_argument(ctx.clone(), argument, input_columns.clone())? for argument in arguments])


def _datafusion_binary_expr(
    operator: DataFusionOperator,
    rendered_args: list[DataFusionExpr],
) -> Result[DataFusionExpr, BackendError]:
    """Build one binary DataFusion expression."""
    if len(rendered_args) != 2:
        return Err(_unsupported_window_expr(f"{operator} requires two arguments"))
    return Ok(
        DataFusionExpr.BinaryExpr(
            DataFusionBinaryExpr.new(Box.new(rendered_args[0].clone()), operator, Box.new(rendered_args[1].clone())),
        ),
    )


def _datafusion_unary_expr(kind: str, rendered_args: list[DataFusionExpr]) -> Result[DataFusionExpr, BackendError]:
    """Build one unary DataFusion expression."""
    if len(rendered_args) != 1:
        return Err(_unsupported_window_expr(f"{kind} requires one argument"))
    if kind == "not":
        return Ok(DataFusionExpr.Not(Box.new(rendered_args[0].clone())))
    if kind == "negate":
        return Ok(DataFusionExpr.Negative(Box.new(rendered_args[0].clone())))
    if kind == "is_null":
        return Ok(DataFusionExpr.IsNull(Box.new(rendered_args[0].clone())))
    if kind == "is_not_null":
        return Ok(DataFusionExpr.IsNotNull(Box.new(rendered_args[0].clone())))
    return Err(_unsupported_window_expr(f"unknown unary expression `{kind}`"))


def _datafusion_between_expr(rendered_args: list[DataFusionExpr]) -> Result[DataFusionExpr, BackendError]:
    """Build one DataFusion BETWEEN expression."""
    if len(rendered_args) != 3:
        return Err(_unsupported_window_expr("between requires three arguments"))
    return Ok(
        DataFusionExpr.Between(
            DataFusionBetween.new(
                Box.new(rendered_args[0].clone()),
                false,
                Box.new(rendered_args[1].clone()),
                Box.new(rendered_args[2].clone()),
            ),
        ),
    )


def _datafusion_common_math_expr(
    function_name: str,
    rendered_args: list[DataFusionExpr],
) -> Result[DataFusionExpr, BackendError]:
    """Build one typed DataFusion expression for the RFC 018 math slice."""
    if function_name == "round":
        if len(rendered_args) < 1:
            return Err(_unsupported_window_expr("round requires at least one argument"))
        return Ok(datafusion_round(rendered_args))
    if len(rendered_args) != 1:
        return Err(_unsupported_window_expr(f"{function_name} requires one argument"))
    if function_name == "abs":
        return Ok(datafusion_abs(rendered_args[0].clone()))
    if function_name == "ceil":
        return Ok(datafusion_ceil(rendered_args[0].clone()))
    if function_name == "floor":
        return Ok(datafusion_floor(rendered_args[0].clone()))
    return Err(_unsupported_window_expr(f"unknown common math function `{function_name}`"))


def _datafusion_window_function_definition(
    ctx: SessionContext,
    function_name: str,
) -> Result[DataFusionWindowFunctionDefinition, BackendError]:
    """Resolve one InQL window function against DataFusion's function registry."""
    state = ctx.state()
    if let Ok(udwf) = state.udwf(function_name):
        return Ok(DataFusionWindowFunctionDefinition.WindowUDF(udwf))
    match state.udaf(function_name):
        Ok(udaf) => return Ok(DataFusionWindowFunctionDefinition.AggregateUDF(udaf))
        Err(err) =>
            return Err(
                backend_error(
                    BackendErrorKind.BackendPlanningError,
                    f"DataFusion does not expose window function `{function_name}`: {err.to_string()}",
                ),
            )


def _datafusion_sort(
    ctx: SessionContext,
    sort: SortField,
    input_columns: list[str],
) -> Result[DataFusionSort, BackendError]:
    """Translate one Substrait sort field for a DataFusion window expression."""
    mut sort_expr = _datafusion_column("")
    match sort.expr:
        Some(expr) =>
            sort_expr = _datafusion_expr(ctx, expr, input_columns)?
        None =>
            return Err(backend_error(BackendErrorKind.BackendPlanningError, "window sort field is missing expression"))
    match sort.sort_kind:
        Some(SortKind.Direction(direction)) => return Ok(_datafusion_sort_direction(sort_expr, direction))
        _ => return Ok(DataFusionSort.new(sort_expr, true, true))


def _datafusion_sort_direction(expr: DataFusionExpr, direction: RustI32) -> DataFusionSort:
    """Translate Substrait sort direction into DataFusion's sort expression flags."""
    asc_nulls_first: RustI32 = SortDirection.AscNullsFirst.into()
    asc_nulls_last: RustI32 = SortDirection.AscNullsLast.into()
    desc_nulls_first: RustI32 = SortDirection.DescNullsFirst.into()
    desc_nulls_last: RustI32 = SortDirection.DescNullsLast.into()
    if direction == asc_nulls_first:
        return DataFusionSort.new(expr, true, true)
    if direction == asc_nulls_last:
        return DataFusionSort.new(expr, true, false)
    if direction == desc_nulls_first:
        return DataFusionSort.new(expr, false, true)
    if direction == desc_nulls_last:
        return DataFusionSort.new(expr, false, false)
    return DataFusionSort.new(expr, true, true)


def _datafusion_window_frame(
    window_function: WindowRelFunction,
    has_ordering: bool,
) -> Result[DataFusionWindowFrame, BackendError]:
    """Translate Substrait window bounds into DataFusion's frame model."""
    bounds_type = _datafusion_window_frame_units(window_function.bounds_type)
    match bounds_type:
        Some(units) =>
            lower = _datafusion_window_bound(window_function.lower_bound, true)?
            upper = _datafusion_window_bound(window_function.upper_bound, false)?
            return Ok(DataFusionWindowFrame.new_bounds(units, lower, upper))
        None =>
            if has_ordering:
                return Ok(DataFusionWindowFrame.new(Some(false)))
            return Ok(DataFusionWindowFrame.new(None))


def _datafusion_window_frame_units(value: RustI32) -> Option[DataFusionWindowFrameUnits]:
    """Translate the Substrait window-frame unit discriminant."""
    rows: RustI32 = BoundsType.Rows.into()
    range_bounds: RustI32 = BoundsType.Range.into()
    if value == rows:
        return Some(DataFusionWindowFrameUnits.Rows)
    if value == range_bounds:
        return Some(DataFusionWindowFrameUnits.Range)
    return None


def _datafusion_window_bound(bound: Option[Bound], is_lower: bool) -> Result[DataFusionWindowFrameBound, BackendError]:
    """Translate one Substrait window-frame bound into DataFusion's frame model."""
    if let Some(value) = bound:
        if let Some(kind) = value.kind:
            match kind:
                BoundKind.Unbounded(_) =>
                    if is_lower:
                        return Ok(DataFusionWindowFrameBound.Preceding(ScalarValue.UInt64(None)))
                    return Ok(DataFusionWindowFrameBound.Following(ScalarValue.UInt64(None)))
                BoundKind.CurrentRow(_) => return Ok(DataFusionWindowFrameBound.CurrentRow)
                BoundKind.Preceding(preceding) =>
                    return Ok(
                        DataFusionWindowFrameBound.Preceding(
                            ScalarValue.UInt64(Some(_rust_i64_to_u64(preceding.offset)?)),
                        ),
                    )
                BoundKind.Following(following) =>
                    return Ok(
                        DataFusionWindowFrameBound.Following(
                            ScalarValue.UInt64(Some(_rust_i64_to_u64(following.offset)?)),
                        ),
                    )
    return Err(backend_error(BackendErrorKind.BackendPlanningError, "window frame bound is missing"))


def _datafusion_window_distinct(invocation: RustI32) -> bool:
    """Return whether a Substrait aggregate invocation requests DISTINCT."""
    distinct: RustI32 = AggregationInvocation.Distinct.into()
    return invocation == distinct


def _window_output_expr(function_name: str, expr: DataFusionExpr) -> DataFusionExpr:
    """Cast DataFusion unsigned analytic outputs to InQL's signed integer surface."""
    if _window_output_needs_i64_cast(function_name):
        return DataFusionExpr.Cast(DataFusionCast.new(Box.new(expr), ArrowDataType.Int64))
    return expr


def _datafusion_alias(expr: DataFusionExpr, output_name: str) -> DataFusionExpr:
    """Attach one InQL output name to a DataFusion expression."""
    return DataFusionExpr.Alias(DataFusionAlias(expr=Box.new(expr), relation=None, name=f"{output_name}", metadata=None))


def _datafusion_column(column_name: str) -> DataFusionExpr:
    """Build a typed DataFusion column reference."""
    return DataFusionExpr.Column(Column.from_name(f"{column_name}"))


def _datafusion_null_treatment(options: list[FunctionOption]) -> Option[DataFusionNullTreatment]:
    """Translate optional InQL null treatment metadata into DataFusion's window model."""
    for option in options:
        if option.name == WINDOW_NULL_TREATMENT_OPTION and len(option.preference) > 0:
            if option.preference[0] == "ignore_nulls":
                return Some(DataFusionNullTreatment.IgnoreNulls)
            if option.preference[0] == "respect_nulls":
                return Some(DataFusionNullTreatment.RespectNulls)
    return None


def _unsupported_window_expr(message: str) -> BackendError:
    """Build a backend planning diagnostic for unsupported window expression bridge shapes."""
    return backend_error(BackendErrorKind.BackendPlanningError, message)


def _window_output_needs_i64_cast(function_name: str) -> bool:
    """Return whether DataFusion's unsigned analytic result should be cast into InQL's i64 surface type."""
    return (
        function_name == "count"
        or function_name == "row_number"
        or function_name == "rank"
        or function_name == "dense_rank"
        or function_name == "ntile"
    )


def _window_function_output_name(options: list[FunctionOption]) -> str:
    """Return the output alias encoded by Substrait lowering."""
    for option in options:
        if option.name == WINDOW_OUTPUT_NAME_OPTION and len(option.preference) > 0:
            return option.preference[0]
    return ""


def _rust_i64_to_u64(value: RustI64) -> Result[RustU64, BackendError]:
    """Convert a non-negative Substrait frame offset into DataFusion's unsigned scalar value."""
    match RustU64.try_from(value):
        Ok(converted) => return Ok(converted)
        Err(_) =>
            return Err(backend_error(BackendErrorKind.BackendPlanningError, "window frame offset must be non-negative"))


def _generator_input_rel(extension: ExtensionSingleRel) -> Result[Rel, BackendError]:
    """Return the child relation for one generator extension."""
    match extension.input:
        Some(child) => return Ok(child.as_ref().clone())
        None => return Err(backend_error(BackendErrorKind.BackendPlanningError, "generator extension is missing input"))


def _decode_generator_payload(extension: ExtensionSingleRel) -> Result[GeneratorExtensionPayload, BackendError]:
    """Decode one InQL generator extension payload."""
    match extension.detail:
        Some(detail) =>
            match decode_generator_extension_payload(detail.value):
                Ok(payload) => return Ok(payload)
                Err(message) => return Err(backend_error(BackendErrorKind.BackendPlanningError, message))
        None =>
            return Err(backend_error(BackendErrorKind.BackendPlanningError, "generator extension is missing detail"))


def _apply_generator_dataframe_shape(
    df: RustDataFrame,
    extension: ExtensionSingleRel,
    payload: GeneratorExtensionPayload,
    temp_columns: list[str],
) -> Result[RustDataFrame, BackendError]:
    """Apply DataFusion unnest and aliasing for one lowered generator payload."""
    match extension.detail:
        Some(detail) =>
            # The first unnest converts arrays into rows. Inline/stack then need a second unnest to split the generated
            # struct values into separate output columns.
            mut current = _unnest_columns(df, temp_columns.clone(), _preserve_generator_nulls(detail.type_url))?
            if _generator_expands_struct(detail.type_url):
                current = _unnest_columns(current, [temp_columns[0]], _preserve_generator_nulls(detail.type_url))?
                return _rename_struct_generator_outputs(current, temp_columns[0], payload.output_columns)
            return _rename_flat_generator_outputs(current, temp_columns, payload.output_columns)
        None =>
            return Err(backend_error(BackendErrorKind.BackendPlanningError, "generator extension is missing detail"))


def _unnest_columns(df: RustDataFrame, columns: list[str], preserve_nulls: bool) -> Result[RustDataFrame, BackendError]:
    """Call DataFusion unnest with the InQL inner/outer null-preservation policy."""
    options = UnnestOptions.new().with_preserve_nulls(preserve_nulls)
    mut datafusion_columns: list[Column] = []
    for column in columns:
        datafusion_column = Column.from_name(f"{column}")
        datafusion_columns.append(datafusion_column.clone())
    # DataFusion exposes unnest through LogicalPlanBuilder rather than as a direct DataFrame method, so split the
    # DataFrame and rebuild it around the transformed logical plan.
    parts = df.into_parts()
    state = parts.0
    logical_plan = parts.1
    match LogicalPlanBuilder.from(logical_plan).unnest_columns_with_options(datafusion_columns, options):
        Ok(builder) =>
            match builder.build():
                Ok(next_plan) => return Ok(RustDataFrame.new(state, next_plan))
                Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))
        Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))


def _rename_flat_generator_outputs(
    df: RustDataFrame,
    temp_columns: list[str],
    output_columns: list[str],
) -> Result[RustDataFrame, BackendError]:
    """Rename generated scalar/list outputs from temporary names to InQL aliases."""
    if len(temp_columns) != len(output_columns):
        return Err(backend_error(BackendErrorKind.BackendPlanningError, "generator payload/output arity mismatch"))
    mut current = df
    for idx, output_column in enumerate(output_columns):
        match current.with_column_renamed(temp_columns[idx], output_column):
            Ok(next_df) =>
                current = next_df
            Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))
    return Ok(current)


def _rename_struct_generator_outputs(
    df: RustDataFrame,
    temp_column: str,
    output_columns: list[str],
) -> Result[RustDataFrame, BackendError]:
    """Rename generated struct fields from temporary qualified names to InQL aliases."""
    mut current = df
    # DataFusion names unnested struct fields as `temp.field`; the public InQL result should expose only the declared
    # generator output aliases.
    for output_column in output_columns:
        field_name = f"{temp_column}.{output_column}"
        match current.with_column_renamed(field_name, output_column):
            Ok(next_df) =>
                current = next_df
            Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))
    return Ok(current)


def _extended_columns(input_columns: list[str], appended_columns: list[str]) -> list[str]:
    """Return input columns followed by appended temporary generator columns."""
    mut columns: list[str] = []
    columns.extend(input_columns)
    columns.extend(appended_columns)
    return columns


def _generator_temp_columns(argument_count: int) -> list[str]:
    """Return stable temporary column aliases for lowered generator argument expressions."""
    return [f"__inql_generator_arg_{idx}" for idx in range(argument_count)]


def _preserve_generator_nulls(extension_uri: str) -> bool:
    """Return whether DataFusion unnest should preserve null/empty inputs for this generator."""
    return extension_uri == EXPLODE_OUTER_EXTENSION_URI or extension_uri == POSEXPLODE_OUTER_EXTENSION_URI or extension_uri == INLINE_OUTER_EXTENSION_URI


def _generator_expands_struct(extension_uri: str) -> bool:
    """Return whether the generator result should expand a struct value into multiple columns."""
    return extension_uri == INLINE_EXTENSION_URI or extension_uri == INLINE_OUTER_EXTENSION_URI or extension_uri == STACK_EXTENSION_URI


async def _register_sources(
    ctx: SessionContext,
    registrations: list[BackendRegistration],
) -> Result[None, BackendError]:
    """Register all logical sources on the DataFusion context before execution."""
    for registration in registrations:
        await _register_one(ctx, registration.logical_name, registration.source)?
    return Ok(None)


async def _register_one(ctx: SessionContext, logical_name: str, source: TableSource) -> Result[None, BackendError]:
    """Register one logical source through the DataFusion adapter source mapping."""
    match datafusion_registration_for_source(source):
        DataFusionSourceRegistration.Csv =>
            csv_opts = CsvReadOptions.new().has_header(true)
            match await ctx.register_csv(logical_name, source.uri, csv_opts):
                Ok(_) => return Ok(None)
                Err(err) => return Err(backend_error(BackendErrorKind.BackendRegistrationError, err.to_string()))
        DataFusionSourceRegistration.Parquet =>
            parquet_opts = ParquetReadOptions.default()
            match await ctx.register_parquet(logical_name, source.uri, parquet_opts):
                Ok(_) => return Ok(None)
                Err(err) => return Err(backend_error(BackendErrorKind.BackendRegistrationError, err.to_string()))
        DataFusionSourceRegistration.Arrow =>
            arrow_opts = ArrowReadOptions.default()
            match await ctx.register_arrow(logical_name, source.uri, arrow_opts):
                Ok(_) => return Ok(None)
                Err(err) => return Err(backend_error(BackendErrorKind.BackendRegistrationError, err.to_string()))


def datafusion_registration_for_source(source: TableSource) -> DataFusionSourceRegistration:
    """Return the DataFusion adapter registration path for one source descriptor."""
    match source.source_kind:
        SourceKind.Csv => return DataFusionSourceRegistration.Csv
        SourceKind.Parquet => return DataFusionSourceRegistration.Parquet
        SourceKind.Arrow => return DataFusionSourceRegistration.Arrow


def _consumer_plan_from_current_plan(plan: Plan) -> Result[ConsumerPlan, BackendError]:
    """Decode the producer-side plan bytes into DataFusion's consumer Plan type."""
    encoded = _datafusion_producer_plan(plan).encode_to_vec()
    match ConsumerPlan.decode(encoded.as_slice()):
        Ok(decoded) => return Ok(decoded)
        Err(err) => return Err(backend_error(BackendErrorKind.BackendPlanningError, err.to_string()))


def _datafusion_producer_plan(plan: Plan) -> Plan:
    """Return a producer plan with extension names adapted for the DataFusion consumer only."""
    # Keep InQL/Substrait plans semantically owned by InQL. This rewrite exists only because DataFusion's Substrait
    # consumer recognizes different implementation names for these aggregate functions.
    return Plan(
        version=plan.version,
        extension_urns=plan.extension_urns,
        extensions=[_datafusion_extension_declaration(extension) for extension in plan.extensions],
        relations=plan.relations,
        advanced_extensions=plan.advanced_extensions,
        expected_type_urls=plan.expected_type_urls,
        parameter_bindings=plan.parameter_bindings,
        type_aliases=plan.type_aliases,
    )


def _datafusion_extension_declaration(extension: SimpleExtensionDeclaration) -> SimpleExtensionDeclaration:
    """Return one extension declaration adapted to DataFusion implementation names when required."""
    match extension.mapping_type:
        Some(MappingType.ExtensionFunction(function)) =>
            if function.name == SUBSTRAIT_APPROX_COUNT_DISTINCT_FUNCTION_NAME:
                return _renamed_datafusion_extension_function(function, DATAFUSION_APPROX_COUNT_DISTINCT_FUNCTION_NAME)
            if function.name == SUBSTRAIT_APPROX_PERCENTILE_FUNCTION_NAME:
                return _renamed_datafusion_extension_function(function, DATAFUSION_APPROX_PERCENTILE_FUNCTION_NAME)
            return SimpleExtensionDeclaration(mapping_type=Some(MappingType.ExtensionFunction(function)))
        _ => return extension


def _renamed_datafusion_extension_function(
    function: ExtensionFunction,
    datafusion_name: str,
) -> SimpleExtensionDeclaration:
    """Return one extension-function declaration preserving anchor and URN while changing the consumer name."""
    return SimpleExtensionDeclaration(
        mapping_type=Some(
            MappingType.ExtensionFunction(
                ExtensionFunction(
                    extension_urn_reference=function.extension_urn_reference,
                    function_anchor=function.function_anchor,
                    name=datafusion_name,
                ),
            ),
        ),
    )


def _rust_usize_to_int(value: RustUsize) -> Result[int, BackendError]:
    """Convert one Rust `usize` count into Incan `int` through a checked `i64` boundary."""
    match RustI64.try_from(value):
        Ok(converted) => return Ok(converted.into())
        Err(_) => return Err(backend_error(BackendErrorKind.BackendExecutionError, "row count does not fit Incan int"))
