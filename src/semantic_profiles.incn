pub def assess_profile_for_target(
    plan_target: SemanticTarget,
    profile: SemanticProfile,
    affected_targets: list[SemanticTarget] = [],
    evidence_refs: list[str] = [],
) -> SemanticProfileAssessment:
    """Assess one plan target against a profile using the profile's declared dimension states."""
    return profile_assessment(
        plan_target,
        profile.profile_id,
        profile.dimensions,
        _combined_assessment_state(profile.dimensions),
        affected_targets=affected_targets,
        confidence=profile.confidence,
        evidence_refs=evidence_refs,
    )


pub def profile_assessment(
    plan_target: SemanticTarget,
    profile_id: str,
    dimensions: list[SemanticProfileDimension],
    state: SemanticProfileAssessmentState = SemanticProfileAssessmentState.Unknown,
    affected_targets: list[SemanticTarget] = [],
    confidence: SemanticProfileConfidence = SemanticProfileConfidence.Unknown,
    diagnostics: list[ExecutionDiagnostic] = [],
    evidence_refs: list[str] = [],
) -> SemanticProfileAssessment:
    """Create one explicit profile assessment record."""
    return SemanticProfileAssessment(
        assessment_id=f"profile-assessment:{plan_target.target_id}:{profile_id}:{state.value()}",
        plan_target=plan_target,
        profile_id=profile_id,
        affected_targets=affected_targets,
        dimensions=dimensions,
        state=state,
        confidence=confidence,
        diagnostics=diagnostics,
        evidence_refs=evidence_refs,
    )


pub def coverage_record_for_profile(record: AdapterCoverageRecord, profile: SemanticProfile) -> AdapterCoverageRecord:
    """Return a coverage record that explicitly cites the semantic profile used for evaluation."""
    return AdapterCoverageRecord(
        coverage_id=record.coverage_id,
        requirement=record.requirement,
        adapter_name=record.adapter_name,
        adapter_version=record.adapter_version,
        semantic_profile_id=Some(profile.profile_id),
        state=record.state,
        diagnostics=record.diagnostics,
        evidence_refs=record.evidence_refs,
    )


def _exact_dimension(
    kind: SemanticProfileDimensionKind,
    declared_behavior: str,
    evidence_refs: list[str],
) -> SemanticProfileDimension:
    """Return an exact IncQL-authored dimension for built-in baseline profiles."""
    return semantic_dimension(
        kind,
        declared_behavior,
        state=SemanticProfileDimensionState.Exact,
        source=MetadataSource.IncQL,
        confidence=SemanticProfileConfidence.Declared,
        evidence_refs=evidence_refs,
    )


def _combined_assessment_state(dimensions: list[SemanticProfileDimension]) -> SemanticProfileAssessmentState:
    """Return a conservative assessment state for a set of profile dimensions."""
    if len(dimensions) == 0:
        return SemanticProfileAssessmentState.Unknown
    # Unknown outranks every other state: profile absence must never look like compatibility.
    mut constrained = false
    mut matched = false
    mut not_applicable = false
    for dimension in dimensions:
        if dimension.state == SemanticProfileDimensionState.Unknown:
            return SemanticProfileAssessmentState.Unknown
        if dimension.state == SemanticProfileDimensionState.Constrained:
            constrained = true
        if dimension.state == SemanticProfileDimensionState.Exact:
            matched = true
        if dimension.state == SemanticProfileDimensionState.NotApplicable:
            not_applicable = true
    if constrained:
        return SemanticProfileAssessmentState.Constrained
    if matched:
        return SemanticProfileAssessmentState.Matched
    if not_applicable:
        return SemanticProfileAssessmentState.NotApplicable
    return SemanticProfileAssessmentState.Unknown


def _profile_id(
    target_class: SemanticProfileTargetClass,
    profile_name: str,
    target_version: Option[str],
    target_configuration_fingerprint: Option[str],
) -> str:
    """Return a deterministic local profile id."""
    version = _option_str_text(target_version)
    fingerprint = _option_str_text(target_configuration_fingerprint)
    return f"semantic-profile:{target_class.value()}:{profile_name}:{version}:{fingerprint}"


def _option_str_text(value: Option[str]) -> str:
    """Return stable text for optional string fields."""
    if let Some(inner) = value:
        return inner
    return ""


def _dimension_json_values(dimensions: list[SemanticProfileDimension]) -> list[JsonValue]:
    """Return JSON values for semantic profile dimensions."""
    return [dimension.to_json_value() for dimension in dimensions]


def _target_id_json_values(targets: list[SemanticTarget]) -> list[JsonValue]:
    """Return JSON string values for semantic target identifiers."""
    return [JsonValue.str(target.target_id) for target in targets]


def _strings_to_json_values(values: list[str]) -> list[JsonValue]:
    """Return JSON string values."""
    return [JsonValue.str(value) for value in values]


def _json_error_to_io_error(error: JsonError) -> IoError:
    """Convert JSON serialization errors into the filesystem error shape used by write helpers."""
    return IoError(kind="invalid_data", detail=error.message(), operation="json", position=-1, path=None)
