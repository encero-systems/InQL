"""
Interoperability semantic profile records.

Semantic profiles describe the environment a plan is authored for, compared with, executed under, or exchanged with.
They are evidence context, not alternative owners of IncQL relational semantics.
"""

from std.fs import IoError, Path
from std.json import JsonError, JsonValue, dumps_pretty
from evidence import AdapterCoverageRecord, ExecutionDiagnostic, MetadataLifecycle, MetadataSource, SemanticTarget

pub const SEMANTIC_PROFILE_SCHEMA_VERSION: str = "incql.semantic-profile.v0.1"


@derive(Clone)
pub enum SemanticProfileTargetClass(str):
    """Environment class described by a semantic profile."""

    IncqlBaseline = "incql_baseline"
    ClientProtocol = "client_protocol"
    PlanIngressFrontend = "plan_ingress_frontend"
    ExecutionEngine = "execution_engine"
    AdapterBinding = "adapter_binding"
    SqlDialect = "sql_dialect"
    CatalogSchemaSystem = "catalog_schema_system"
    TransformationProject = "transformation_project"
    InterchangeConsumer = "interchange_consumer"
    ConformanceBaseline = "conformance_baseline"


@derive(Clone)
pub enum SemanticProfileDimensionKind(str):
    """Semantic dimensions that can affect interoperability evidence."""

    TypeSystem = "type_system"
    NumericDecimal = "numeric_decimal"
    TemporalCalendar = "temporal_calendar"
    BooleanNullNan = "boolean_null_nan"
    StringComparison = "string_comparison"
    IdentifierResolution = "identifier_resolution"
    SchemaCatalog = "schema_catalog"
    TransformationProject = "transformation_project"
    ClientSessionState = "client_session_state"
    RelationOrdering = "relation_ordering"
    AggregateGrouping = "aggregate_grouping"
    WindowSemantics = "window_semantics"
    NestedSemiStructured = "nested_semi_structured"
    FunctionOperatorIdentity = "function_operator_identity"
    ExtensionFallback = "extension_fallback"
    PlanStageObservability = "plan_stage_observability"


@derive(Clone)
pub enum SemanticProfileDimensionState(str):
    """How precisely one profile declares a semantic dimension."""

    Exact = "exact"
    Constrained = "constrained"
    Unknown = "unknown"
    NotApplicable = "not_applicable"


@derive(Clone)
pub enum SemanticProfileConfidence(str):
    """Confidence attached to a semantic profile or assessment."""

    Declared = "declared"
    Attested = "attested"
    Observed = "observed"
    Inferred = "inferred"
    Unknown = "unknown"


@derive(Clone)
pub enum SemanticProfileAssessmentState(str):
    """Assessment state for a plan or target checked against a semantic profile."""

    Matched = "matched"
    Constrained = "constrained"
    Mismatched = "mismatched"
    Unknown = "unknown"
    NotApplicable = "not_applicable"


@derive(Clone)
pub model SemanticProfileDimension:
    """One structured semantic dimension inside an interoperability profile."""

    pub dimension_id: str
    pub kind: SemanticProfileDimensionKind
    pub lifecycle: MetadataLifecycle
    pub state: SemanticProfileDimensionState
    pub declared_behavior: str
    pub source: MetadataSource
    pub confidence: SemanticProfileConfidence
    pub diagnostics: list[ExecutionDiagnostic]
    pub evidence_refs: list[str]

    def to_json_value(self) -> JsonValue:
        """Return the stable JSON shape for this profile dimension."""
        mut entries: Dict[str, JsonValue] = {}
        entries["dimension_id"] = JsonValue.str(self.dimension_id)
        entries["kind"] = JsonValue.str(self.kind.value())
        entries["lifecycle"] = JsonValue.str(self.lifecycle.value())
        entries["state"] = JsonValue.str(self.state.value())
        entries["declared_behavior"] = JsonValue.str(self.declared_behavior)
        entries["source"] = JsonValue.str(self.source.value())
        entries["confidence"] = JsonValue.str(self.confidence.value())
        entries["diagnostic_count"] = JsonValue.int(len(self.diagnostics))
        entries["evidence_refs"] = JsonValue.array(_strings_to_json_values(self.evidence_refs))
        return JsonValue.object(entries)


@derive(Clone)
pub model SemanticProfile:
    """Versioned semantic environment profile used by coverage, execution, bundle, and exchange evidence."""

    pub schema_version: str
    pub profile_id: str
    pub target_class: SemanticProfileTargetClass
    pub profile_name: str
    pub source: MetadataSource
    pub target_version: Option[str]
    pub target_configuration_fingerprint: Option[str]
    pub dimensions: list[SemanticProfileDimension]
    pub confidence: SemanticProfileConfidence
    pub diagnostics: list[ExecutionDiagnostic]
    pub evidence_refs: list[str]

    def to_json_value(self) -> JsonValue:
        """Return the stable JSON shape for this semantic profile."""
        mut entries: Dict[str, JsonValue] = {}
        entries["schema_version"] = JsonValue.str(self.schema_version)
        entries["profile_id"] = JsonValue.str(self.profile_id)
        entries["target_class"] = JsonValue.str(self.target_class.value())
        entries["profile_name"] = JsonValue.str(self.profile_name)
        entries["source"] = JsonValue.str(self.source.value())
        entries["target_version"] = JsonValue.str(_option_str_text(self.target_version))
        entries["target_configuration_fingerprint"] = JsonValue.str(
            _option_str_text(self.target_configuration_fingerprint),
        )
        entries["dimensions"] = JsonValue.array(_dimension_json_values(self.dimensions))
        entries["confidence"] = JsonValue.str(self.confidence.value())
        entries["diagnostic_count"] = JsonValue.int(len(self.diagnostics))
        entries["evidence_refs"] = JsonValue.array(_strings_to_json_values(self.evidence_refs))
        return JsonValue.object(entries)

    def to_json_text(self) -> Result[str, IoError]:
        """Serialize this semantic profile as pretty JSON text."""
        return dumps_pretty(self.to_json_value()).map_err(_json_error_to_io_error)

    def write(self, path: str) -> Result[None, IoError]:
        """Write this semantic profile JSON to a local filesystem path."""
        return Path(path).write_text(self.to_json_text()?, "utf-8", "strict", None)


@derive(Clone)
pub model SemanticProfileAssessment:
    """Assessment of one plan or target under a semantic profile."""

    pub assessment_id: str
    pub plan_target: SemanticTarget
    pub profile_id: str
    pub affected_targets: list[SemanticTarget]
    pub dimensions: list[SemanticProfileDimension]
    pub state: SemanticProfileAssessmentState
    pub confidence: SemanticProfileConfidence
    pub diagnostics: list[ExecutionDiagnostic]
    pub evidence_refs: list[str]

    def to_json_value(self) -> JsonValue:
        """Return the stable JSON shape for this profile assessment."""
        mut entries: Dict[str, JsonValue] = {}
        entries["assessment_id"] = JsonValue.str(self.assessment_id)
        entries["plan_target_id"] = JsonValue.str(self.plan_target.target_id)
        entries["profile_id"] = JsonValue.str(self.profile_id)
        entries["affected_target_ids"] = JsonValue.array(_target_id_json_values(self.affected_targets))
        entries["dimensions"] = JsonValue.array(_dimension_json_values(self.dimensions))
        entries["state"] = JsonValue.str(self.state.value())
        entries["confidence"] = JsonValue.str(self.confidence.value())
        entries["diagnostic_count"] = JsonValue.int(len(self.diagnostics))
        entries["evidence_refs"] = JsonValue.array(_strings_to_json_values(self.evidence_refs))
        return JsonValue.object(entries)


pub def semantic_dimension(
    kind: SemanticProfileDimensionKind,
    declared_behavior: str,
    state: SemanticProfileDimensionState = SemanticProfileDimensionState.Unknown,
    lifecycle: MetadataLifecycle = MetadataLifecycle.Analyzed,
    source: MetadataSource = MetadataSource.IncQL,
    confidence: SemanticProfileConfidence = SemanticProfileConfidence.Declared,
    diagnostics: list[ExecutionDiagnostic] = [],
    evidence_refs: list[str] = [],
) -> SemanticProfileDimension:
    """Create one semantic profile dimension."""
    return SemanticProfileDimension(
        dimension_id=f"semantic-dimension:{kind.value()}:{state.value()}:{source.value()}",
        kind=kind,
        lifecycle=lifecycle,
        state=state,
        declared_behavior=declared_behavior,
        source=source,
        confidence=confidence,
        diagnostics=diagnostics,
        evidence_refs=evidence_refs,
    )


pub def semantic_profile(
    target_class: SemanticProfileTargetClass,
    profile_name: str,
    source: MetadataSource = MetadataSource.User,
    target_version: Option[str] = None,
    target_configuration_fingerprint: Option[str] = None,
    dimensions: list[SemanticProfileDimension] = [],
    confidence: SemanticProfileConfidence = SemanticProfileConfidence.Declared,
    diagnostics: list[ExecutionDiagnostic] = [],
    evidence_refs: list[str] = [],
) -> SemanticProfile:
    """Create one versioned semantic profile record."""
    return SemanticProfile(
        schema_version=SEMANTIC_PROFILE_SCHEMA_VERSION,
        profile_id=_profile_id(target_class, profile_name, target_version, target_configuration_fingerprint),
        target_class=target_class,
        profile_name=profile_name,
        source=source,
        target_version=target_version,
        target_configuration_fingerprint=target_configuration_fingerprint,
        dimensions=dimensions,
        confidence=confidence,
        diagnostics=diagnostics,
        evidence_refs=evidence_refs,
    )


pub def incql_baseline_profile(version: str = "current", evidence_refs: list[str] = []) -> SemanticProfile:
    """Return the local IncQL baseline profile used when no external target owns semantics."""
    return semantic_profile(
        SemanticProfileTargetClass.IncqlBaseline,
        "incql",
        source=MetadataSource.IncQL,
        target_version=Some(version),
        dimensions=[_exact_dimension(
            SemanticProfileDimensionKind.TypeSystem,
            "IncQL typed scalar and relation model",
            evidence_refs,
        ), _exact_dimension(
            SemanticProfileDimensionKind.FunctionOperatorIdentity,
            "IncQL function registry identity",
            evidence_refs,
        ), _exact_dimension(
            SemanticProfileDimensionKind.RelationOrdering,
            "Relations are unordered unless explicitly ordered",
            evidence_refs,
        ), _exact_dimension(
            SemanticProfileDimensionKind.PlanStageObservability,
            "Prism inspection emits local plan evidence",
            evidence_refs,
        )],
        confidence=SemanticProfileConfidence.Declared,
        evidence_refs=evidence_refs,
    )


pub def adapter_binding_profile(
    adapter_name: str,
    adapter_version: Option[str] = None,
    target_configuration_fingerprint: Option[str] = None,
    dimensions: list[SemanticProfileDimension] = [],
    evidence_refs: list[str] = [],
) -> SemanticProfile:
    """Return a semantic profile for one adapter binding."""
    return semantic_profile(
        SemanticProfileTargetClass.AdapterBinding,
        adapter_name,
        source=MetadataSource.Adapter,
        target_version=adapter_version,
        target_configuration_fingerprint=target_configuration_fingerprint,
        dimensions=dimensions,
        confidence=SemanticProfileConfidence.Declared,
        evidence_refs=evidence_refs,
    )


pub def execution_engine_profile(
