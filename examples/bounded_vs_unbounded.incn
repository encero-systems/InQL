"""Example: bounded vs unbounded model-carrier contracts."""

from functions import col, eq, lit
from dataset import DataSet, BoundedDataSet, UnboundedDataSet
from models import Order, Event


def open_batch_orders(orders: BoundedDataSet[Order]) -> BoundedDataSet[Order]:
    """Batch helpers can require finite Order data explicitly."""
    return orders.filter(eq(col("status"), lit("open")))


def order_snapshot(orders: BoundedDataSet[Order]) -> BoundedDataSet[Order]:
    """Snapshot helpers can keep boundedness in the return type."""
    return open_batch_orders(orders).limit(100)


def high_priority_events(events: UnboundedDataSet[Event]) -> UnboundedDataSet[Event]:
    """Streaming helpers keep the event-stream carrier visible."""
    return events.filter(eq(col("severity"), lit("high")))


def event_stream_window(events: UnboundedDataSet[Event]) -> UnboundedDataSet[Event]:
    """Unbounded pipelines can still use row-local transforms."""
    return high_priority_events(events).limit(1000)


def require_batch_orders(orders: BoundedDataSet[Order]) -> None:
    """Sink boundaries can demand a bounded Order carrier."""
    _ = orders


def require_event_stream(events: UnboundedDataSet[Event]) -> None:
    """Sink boundaries can demand an unbounded Event carrier."""
    _ = events


def pass_through_any_model[T](data: DataSet[T]) -> DataSet[T]:
    """Generic helpers stay carrier-neutral when they only need shared DataSet operations."""
    return data


def main() -> None:
    pass
